# Postgres connection string used by the API. Matches the credentials in
# docker-compose.yml; override in production.
DATABASE_URL=postgres://mt:mt@localhost:5432/mt_commerce

# Redis connection string. Used for rate limiting, session storage, and the
# BullMQ job queue.
REDIS_URL=redis://localhost:6379

# Application environment. Affects logging output (pretty in dev, JSON in prod)
# and whether dev-only routes (Swagger UI) are mounted.
NODE_ENV=development

# Pino log level. One of: trace, debug, info, warn, error, fatal, silent.
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins. The committed default covers
# the local admin (Vite) and storefront (Astro). Do NOT use "*" in production.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Whether the API is behind a trusted reverse proxy. When true, the rate
# limiter honors X-Forwarded-For for the client IP. Set to false unless you
# control the proxy in front of the API; otherwise clients can spoof their IP.
TRUST_PROXY=false
