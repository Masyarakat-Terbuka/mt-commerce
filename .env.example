# Postgres connection string used by the API. Matches the credentials in
# docker-compose.yml; override in production.
DATABASE_URL=postgres://mt:mt@localhost:5432/mt_commerce

# Redis connection string. Used for rate limiting, session storage, and the
# BullMQ job queue.
REDIS_URL=redis://localhost:6379

# Application environment. Affects logging output (pretty in dev, JSON in prod)
# and whether dev-only routes (Swagger UI) are mounted.
NODE_ENV=development

# Pino log level. One of: trace, debug, info, warn, error, fatal, silent.
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins. The committed default covers
# the local admin (Vite) and storefront (Astro). Do NOT use "*" in production.
CORS_ORIGIN=http://localhost:5173,http://localhost:4321,http://localhost:3000

# Whether the API is behind a trusted reverse proxy. When true, the rate
# limiter honors X-Forwarded-For for the client IP. Set to false unless you
# control the proxy in front of the API; otherwise clients can spoof their IP.
TRUST_PROXY=false

# ---- Authentication (Better Auth) -------------------------------------------

# Secret used by Better Auth to sign session cookies and encrypt verification
# tokens. MUST be at least 32 characters and unique per deployment.
# DO NOT use the placeholder below in production. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=development-only-secret-change-me-to-32-chars

# Optional. Base URL the API is reachable at. Better Auth uses this to build
# callback URLs and verify the Origin header. Leave unset in dev — env.ts
# constructs http://localhost:$PORT. REQUIRED in production.
# BETTER_AUTH_URL=https://api.example.com

# Cookie name for the session. Default: mt_session.
SESSION_COOKIE_NAME=mt_session

# Whether to mark the session cookie as Secure. Defaults to true when
# NODE_ENV=production, false otherwise. Force true here only if you have
# TLS termination in front of the API in dev.
# SESSION_COOKIE_SECURE=false

# ---- Tax (placeholder) ------------------------------------------------------

# Indonesian PPN rate the cart applies as a flat placeholder during cart
# total computation. Default 0.11 (= 11%). The dedicated tax module will
# replace this with per-item / per-region / per-exemption rate selection.
TAX_PPN_RATE=0.11

# ---- Notifications ----------------------------------------------------------

# SMTP host for outbound email. Leave unset in dev — the notification module
# falls back to a console channel that logs the email instead of sending.
# REQUIRED in production: the SMTP adapter throws on construction if missing.
# SMTP_HOST=smtp.example.com

# SMTP port. Default 587 (STARTTLS); use 465 for implicit TLS.
SMTP_PORT=587

# SMTP credentials. Leave unset for relays that accept unauthenticated
# submission from the application host.
# SMTP_USER=
# SMTP_PASS=

# `From:` header for outbound email. Placeholder is dev-only — set this to
# an address the SMTP relay accepts in production.
SMTP_FROM=noreply@example.com

# Default channel used when a notification call does not pin one. `console`
# logs the email; `smtp` sends through SMTP_HOST. Defaults to `console` in
# dev/test and `smtp` in production.
# NOTIFICATION_DEFAULT_CHANNEL=console
