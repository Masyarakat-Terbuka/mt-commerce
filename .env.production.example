# =============================================================================
# mt-commerce — production environment template.
#
# DO NOT COMMIT the filled-in `.env.production` file. It contains secrets.
# Copy this file to `.env.production`, fill in the values, then:
#
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# Generate secrets with:
#   openssl rand -base64 32
# =============================================================================

# ---- Domain + TLS -----------------------------------------------------------

# Apex domain. The compose file routes:
#   ${DOMAIN}            → storefront
#   admin.${DOMAIN}      → admin SPA
#   api.${DOMAIN}        → API
# All three subdomains must have public DNS A/AAAA records pointing at this
# host before `up -d` runs, so Caddy can complete the ACME challenge.
DOMAIN=mystore.example.com

# Email that Let's Encrypt uses for cert-expiry notices. Use a real, monitored
# inbox; if certs ever fail to renew, this is where the warning lands.
ACME_EMAIL=ops@example.com

# ---- Database ---------------------------------------------------------------

# Credentials for the bundled `postgres` service. The host name `postgres`
# resolves on the internal docker network; do not expose it on the host.
POSTGRES_USER=mt
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=mt_commerce

# Connection string the API uses. Must match the credentials above.
DATABASE_URL=postgres://mt:change-me-postgres-password@postgres:5432/mt_commerce

# ---- Redis ------------------------------------------------------------------

# Connection string the API uses. Internal docker hostname.
REDIS_URL=redis://redis:6379

# ---- API authentication -----------------------------------------------------

# Better Auth secret. MUST be at least 32 characters and unique per deploy.
# Rotate by following docs/deployment/firewall-ssl.md.
#   openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-output-of-openssl-rand-base64-32

# ---- Logging ----------------------------------------------------------------

# Pino log level. One of: trace, debug, info, warn, error, fatal, silent.
LOG_LEVEL=info

# ---- Tax --------------------------------------------------------------------

# Indonesian PPN rate the cart applies as a flat placeholder (0..1).
TAX_PPN_RATE=0.11

# ---- Notifications (SMTP) ---------------------------------------------------

# REQUIRED in production: the SMTP adapter throws on construction if SMTP_HOST
# is missing when NODE_ENV=production. Use a transactional provider
# (Postmark, SendGrid, Mailgun) or your own relay.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mystore.example.com

# `smtp` for production; `console` only for staging-without-mail-provider.
NOTIFICATION_DEFAULT_CHANNEL=smtp

# ---- Optional plugins -------------------------------------------------------
# These only need values when the matching plugin is wired into
# apps/api/mt-commerce.config.ts. Leave blank if not using.

# Midtrans (payment).
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MODE=sandbox

# Biteship (shipping).
BITESHIP_API_KEY=

# WhatsApp Cloud API (notifications).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ---- Uploads ----------------------------------------------------------------

# Public origin of this API. Used to build absolute URLs for uploaded product
# images. Must match the api subdomain that Caddy serves. Already set in
# docker-compose.prod.yml from ${DOMAIN}; override only for atypical
# deployments.
# API_PUBLIC_URL=https://api.mystore.example.com

# Maximum upload size in bytes. Default 5 MiB (5242880). The route returns
# 413 above this; raise only if your operators upload larger images and your
# storage budget tolerates it.
MAX_UPLOAD_BYTES=5242880
