# Postgres connection string. Matches docker-compose.yml in the repo root.
DATABASE_URL=postgres://mt:mt@localhost:5432/mt_commerce

# Redis connection string. Used for rate limiting (production) and BullMQ jobs.
REDIS_URL=redis://localhost:6379

# Application environment. "development" enables Swagger UI at /docs and pretty
# log output. "production" emits JSON logs and disables dev-only routes.
NODE_ENV=development

# Pino log level. One of: trace, debug, info, warn, error, fatal, silent.
LOG_LEVEL=info

# HTTP port the API listens on.
PORT=8000

# Comma-separated list of allowed CORS origins. The committed default covers
# the local admin (Vite) and storefront (Astro). Do NOT use "*" in production.
# Example: https://admin.example.com,https://shop.example.com
CORS_ORIGIN=http://localhost:5173,http://localhost:4321,http://localhost:3000

# Whether the API is behind a trusted reverse proxy. When true, the rate
# limiter honors X-Forwarded-For for the client IP. Set to false unless you
# control the proxy in front of the API; otherwise clients can spoof their IP.
TRUST_PROXY=false

# ---- Authentication (Better Auth) -------------------------------------------

# Secret used by Better Auth to sign session cookies and encrypt verification
# tokens. MUST be at least 32 characters and unique per deployment.
# DO NOT use the placeholder below in production. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=development-only-secret-change-me-to-32-chars

# Optional. Base URL the API is reachable at. Better Auth uses this to build
# callback URLs and verify the Origin header. Leave unset in dev — env.ts
# constructs http://localhost:$PORT. REQUIRED in production.
# BETTER_AUTH_URL=https://api.example.com

# Cookie name for the session. Default: mt_session.
SESSION_COOKIE_NAME=mt_session

# Whether to mark the session cookie as Secure. Defaults to true when
# NODE_ENV=production, false otherwise. Force true here only if you have
# TLS termination in front of the API in dev.
# SESSION_COOKIE_SECURE=false

# ---- Tax (placeholder) ------------------------------------------------------

# Indonesian PPN (Pajak Pertambahan Nilai) rate the cart applies as a flat
# placeholder during cart total computation. Default 0.11 (= 11%).
#
# This is intentionally a single global rate — the dedicated tax module (see
# docs/v0.1-checklist.md "Tax") will replace it with per-item / per-region /
# per-exemption rate selection driven by `tax_rates` and `tax_exemptions`.
# Until that ships, change this value to dial PPN without a code change.
# Must be a decimal in [0, 1].
TAX_PPN_RATE=0.11

# ---- Notifications ----------------------------------------------------------

# SMTP host for outbound email (verification, order confirmation, etc.).
# Leave unset in dev — the notification module falls back to the console
# channel and logs the email at info level. REQUIRED in production: the
# SMTP adapter throws on construction if the host is missing when
# NODE_ENV=production, so the API refuses to start without explicit config.
# SMTP_HOST=smtp.example.com

# SMTP port. Default 587 (STARTTLS). Use 465 for implicit TLS.
SMTP_PORT=587

# SMTP credentials. Leave unset for relays that accept unauthenticated
# submission from the application host (e.g. internal Postfix on localhost).
# SMTP_USER=
# SMTP_PASS=

# `From:` header for outbound email. The placeholder is dev-only — set this
# to an address the SMTP relay accepts for delivery in production.
SMTP_FROM=noreply@example.com

# Default channel used by the notification service when the caller does not
# pin one. `console` logs the email; `smtp` sends through SMTP_HOST. Defaults
# to `console` in dev/test and `smtp` in production.
# NOTIFICATION_DEFAULT_CHANNEL=console

# ---- Uploads ----------------------------------------------------------------

# Directory product image uploads are written to. Resolved relative to
# `apps/api/` when the API is started from there (the typical dev case);
# absolute paths are honored as-is.
# UPLOAD_DIR=./uploads

# Public origin of this API. Used to construct absolute URLs for uploaded
# images so the storefront can render them as-is. Defaults to
# `http://localhost:${PORT}` in dev; production deployments must pin this.
# API_PUBLIC_URL=http://localhost:8000

# Maximum upload size in bytes. Default 5 MiB (5242880). The route returns
# 413 above this.
# MAX_UPLOAD_BYTES=5242880
