---
/**
 * ProductCard — server-rendered card.
 *
 * Photography is the visual heavyweight. Below the image, two flat lines:
 *   1. Title (body weight 500), 1 line, ellipsized.
 *   2. Price (price-figure, tabular nums) + optional compare-at strike.
 *
 * The whole card is the link target — no "Add to cart" button on the card.
 * Hover only darkens the border and the title; no scale, no shadow.
 *
 * The image is a 1:1 aspect ratio so cards align cleanly across rows; the
 * `<img>` lazy-loads outside the first viewport. When a product has no
 * `imageUrl`, we render a calm cream placeholder rather than a generic
 * gray box, so even an unphotographed product fits the aesthetic.
 */
import Price from "./Price.astro";
import { createTranslator, resolveLocale, localePath, type Locale } from "@/lib/i18n";
import type { StoreProduct } from "@/lib/api";

export interface Props {
  product: StoreProduct;
  /**
   * The image of the first card in a grid is above the fold; pass
   * `eager` so the LCP isn't deferred unnecessarily. Default lazy.
   */
  loading?: "eager" | "lazy";
}

const { product, loading = "lazy" } = Astro.props;
const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);
const title = product.title[locale];
const alt = product.imageAlt[locale];

// Compare-at sourced from the first variant — the SDK does not expose a
// product-level compare-at; per-variant is what's available today.
const firstVariant = product.variants[0];
const compareAt = firstVariant?.compareAt;
---

<a
  href={localePath(locale, `/products/${product.slug}`)}
  class="group block"
>
  <div
    class="aspect-square w-full overflow-hidden border border-line bg-paper transition-colors duration-150 group-hover:border-line-strong"
  >
    {
      product.hasImage ? (
        <img
          src={product.imageUrl}
          alt={alt}
          loading={loading}
          decoding="async"
          class="h-full w-full object-cover"
        />
      ) : (
        <div class="flex h-full w-full flex-col items-center justify-center gap-1 bg-cream px-4 text-center">
          <span class="t-body line-clamp-2 font-medium text-fg">{title}</span>
          <span class="t-caption text-faint">{t("products.card.photo_coming_soon")}</span>
        </div>
      )
    }
  </div>
  <div class="mt-3 space-y-1">
    <h3 class="t-body line-clamp-1 text-fg transition-colors duration-150 group-hover:text-accent">
      {title}
    </h3>
    <div class="flex items-baseline gap-2 t-body">
      <Price money={product.basePrice} />
      {compareAt && <Price money={compareAt} strike />}
    </div>
  </div>
</a>
