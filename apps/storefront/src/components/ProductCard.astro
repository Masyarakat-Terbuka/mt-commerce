---
/**
 * ProductCard — server-rendered card.
 *
 * Photography is the visual heavyweight. Below the image, two flat lines:
 *   1. Title (`t-body`, weight 400, single line, line-clamp-1).
 *   2. Price (`price-figure`, muted, tabular nums) + optional compare-at strike.
 *
 * The whole card is the link target — no "Add to cart" button on the card.
 * Hover only lowers the image opacity to 0.9 and shifts the title to accent.
 * No border, no shadow, no scale, no shadow-on-hover. Saturdays NYC's
 * cards drop borders entirely — the photo's edge IS the card's edge.
 *
 * The image is a 1:1 aspect ratio so cards align cleanly across rows;
 * `<img>` lazy-loads outside the first viewport. When a product has no
 * `imageUrl`, we render a calm cream tile with just the title centered —
 * no caption, no "photo coming soon" line. The cream tile + title speaks
 * for itself, and the missing photo reads as intentional rather than broken.
 *
 * View-transition pairing: each card's `<img>` carries
 * `view-transition-name: pdp-image-<slug>`. The matching name lives on
 * the PDP hero (`ProductDetail.tsx`), so the browser morphs the clicked
 * card image into the hero across the Astro `ClientRouter` swap —
 * rather than cross-fading two unrelated rectangles. Browsers without
 * View Transitions support fall through to a normal page swap.
 */
import Price from "./Price.astro";
import QuickAddButton from "@/islands/QuickAddButton";
import {
  resolveLocale,
  localePath,
  createTranslator,
  type Locale,
} from "@/lib/i18n";
import type { StoreProduct } from "@/lib/api";

export interface Props {
  product: StoreProduct;
  /**
   * The image of the first card in a grid is above the fold; pass
   * `eager` so the LCP isn't deferred unnecessarily. Default lazy.
   */
  loading?: "eager" | "lazy";
}

const { product, loading = "lazy" } = Astro.props;
const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);
const title = product.title[locale];
const alt = product.imageAlt[locale];

// Compare-at sourced from the first variant — the SDK does not expose a
// product-level compare-at; per-variant is what's available today.
const firstVariant = product.variants[0];
const compareAt = firstVariant?.compareAt;

// Quick-add only renders for single-variant products. Zero-variant
// products (an admin edge case where the SKU is unconfigured) and
// multi-variant products keep their plain-link card behavior — see
// `QuickAddButton` for the rationale.
const variantCount = product.variants.length;
const quickAddVariantId = variantCount === 1 ? firstVariant!.id : null;

/**
 * Build a `srcset` for the card image. Demo product images come from
 * Unsplash, which honours `?w=&q=` query params for server-side resizing.
 * Mobile rendered each card at ~165 px CSS but received a 1200 px asset —
 * Lighthouse `uses-responsive-images` flagged ~800 KiB savings.
 *
 * We strip the existing `?w=&q=` and replace with three widths. `sizes`
 * tells the browser the actual rendered width per breakpoint:
 *   - `lg+` (≥1024 px): 4-up grid → ~25vw per card
 *   - `md`  (≥768 px):  3-up grid → ~33vw per card
 *   - mobile:           2-up grid → ~50vw per card
 * Other Unsplash params (`auto=format`, `fit=crop`) ride along;
 * non-Unsplash hosts simply get the original `src` (the srcset still
 * works because the browser falls back when widths don't apply).
 *
 * Card CSS widths at the breakpoint extremes:
 *   - 1440 px viewport, 4-up: ~330 px → 600w covers @2x DPR
 *   - 360 px viewport,  2-up: ~165 px → 300w covers @2x DPR
 * So the 300/600/900w ladder still fits the new 4-up layout.
 */
function unsplashSrcset(url: string): {
  src: string;
  srcset: string;
  sizes: string;
} {
  const base = url.split("?")[0]!;
  const sizes = "(min-width: 1024px) 25vw, (min-width: 768px) 33vw, 50vw";
  if (!base.includes("images.unsplash.com")) {
    return { src: url, srcset: url, sizes };
  }
  const at = (w: number, q: number) =>
    `${base}?w=${w}&q=${q}&auto=format&fit=crop`;
  return {
    src: at(600, 75),
    srcset: [
      `${at(300, 70)} 300w`,
      `${at(600, 75)} 600w`,
      `${at(900, 78)} 900w`,
    ].join(", "),
    sizes,
  };
}

const cardImg = product.hasImage ? unsplashSrcset(product.imageUrl) : null;
---

<a href={localePath(locale, `/products/${product.slug}`)} class="group block">
  <div class="bg-cream relative aspect-square w-full overflow-hidden">
    {
      cardImg ? (
        <img
          src={cardImg.src}
          srcset={cardImg.srcset}
          sizes={cardImg.sizes}
          alt={alt}
          loading={loading}
          decoding="async"
          style={`view-transition-name: pdp-image-${product.slug};`}
          class="h-full w-full object-cover transition-opacity duration-200 group-hover:opacity-90"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center px-6 text-center">
          <span class="t-body text-fg line-clamp-2">{title}</span>
        </div>
      )
    }
    {
      /*
        Quick-add overlay. Hydrates only when the card scrolls into
        view (`client:visible`) so a 12-card grid does not pay 12
        hydration costs upfront. The island returns null for
        multi-variant and zero-variant products, so the SSR markup
        is identical regardless and there is no layout shift after
        hydration.
      */
    }
    <QuickAddButton
      client:visible
      variantId={quickAddVariantId}
      variantCount={variantCount}
      productTitle={title}
      productImageUrl={product.hasImage ? product.imageUrl : null}
      productImageAlt={alt}
      label={t("quick_add.label")}
      successLabel={t("quick_add.success")}
      errorLabel={t("quick_add.error")}
    />
  </div>
  <div class="mt-4 space-y-1">
    {
      /*
      Card title is `h3` so it sits one level below the section's `h2`
      (e.g. "Pilihan terbaru" / "Hasil pencarian"). Pages that use
      `ProductCard` must render that `h2` to keep heading order valid.
    */
    }
    <h3
      class="t-body text-fg group-hover:text-accent line-clamp-1 transition-colors duration-200"
    >
      {title}
    </h3>
    <div class="t-body flex items-baseline gap-2">
      <Price money={product.basePrice} muted />
      {compareAt && <Price money={compareAt} strike />}
    </div>
  </div>
</a>
