---
/**
 * ProductCard — server-rendered card.
 *
 * Photography is the visual heavyweight. Below the image, two flat lines:
 *   1. Title (`t-body`, weight 400, single line, line-clamp-1).
 *   2. Price (`price-figure`, muted, tabular nums) + optional compare-at strike.
 *
 * The whole card is the link target — no "Add to cart" button on the card.
 * Hover only lowers the image opacity to 0.9 and shifts the title to accent.
 * No border, no shadow, no scale, no shadow-on-hover. Saturdays NYC's
 * cards drop borders entirely — the photo's edge IS the card's edge.
 *
 * The image is a 1:1 aspect ratio so cards align cleanly across rows;
 * `<img>` lazy-loads outside the first viewport. When a product has no
 * `imageUrl`, we render a calm cream tile with just the title centered —
 * no caption, no "photo coming soon" line. The cream tile + title speaks
 * for itself, and the missing photo reads as intentional rather than broken.
 */
import Price from "./Price.astro";
import { resolveLocale, localePath, type Locale } from "@/lib/i18n";
import type { StoreProduct } from "@/lib/api";

export interface Props {
  product: StoreProduct;
  /**
   * The image of the first card in a grid is above the fold; pass
   * `eager` so the LCP isn't deferred unnecessarily. Default lazy.
   */
  loading?: "eager" | "lazy";
}

const { product, loading = "lazy" } = Astro.props;
const locale: Locale = resolveLocale(Astro.currentLocale);
const title = product.title[locale];
const alt = product.imageAlt[locale];

// Compare-at sourced from the first variant — the SDK does not expose a
// product-level compare-at; per-variant is what's available today.
const firstVariant = product.variants[0];
const compareAt = firstVariant?.compareAt;

/**
 * Build a `srcset` for the card image. Demo product images come from
 * Unsplash, which honours `?w=&q=` query params for server-side resizing.
 * Mobile rendered each card at ~165 px CSS but received a 1200 px asset —
 * Lighthouse `uses-responsive-images` flagged ~800 KiB savings.
 *
 * We strip the existing `?w=&q=` and replace with three widths. `sizes`
 * tells the browser to expect a 2-up grid on mobile (50vw) and 3-up on
 * desktop (33vw). Other Unsplash params (`auto=format`, `fit=crop`) ride
 * along; non-Unsplash hosts simply get the original `src` (the srcset
 * still works because the browser falls back when widths don't apply).
 */
function unsplashSrcset(url: string): { src: string; srcset: string; sizes: string } {
  const base = url.split("?")[0]!;
  if (!base.includes("images.unsplash.com")) {
    return { src: url, srcset: url, sizes: "(min-width: 768px) 33vw, 50vw" };
  }
  const at = (w: number, q: number) =>
    `${base}?w=${w}&q=${q}&auto=format&fit=crop`;
  return {
    src: at(600, 75),
    srcset: [`${at(300, 70)} 300w`, `${at(600, 75)} 600w`, `${at(900, 78)} 900w`].join(", "),
    sizes: "(min-width: 768px) 33vw, 50vw",
  };
}

const cardImg = product.hasImage ? unsplashSrcset(product.imageUrl) : null;
---

<a
  href={localePath(locale, `/products/${product.slug}`)}
  class="group block"
>
  <div class="aspect-square w-full overflow-hidden bg-cream">
    {
      cardImg ? (
        <img
          src={cardImg.src}
          srcset={cardImg.srcset}
          sizes={cardImg.sizes}
          alt={alt}
          loading={loading}
          decoding="async"
          class="h-full w-full object-cover transition-opacity duration-200 group-hover:opacity-90"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center px-6 text-center">
          <span class="t-body line-clamp-2 text-fg">{title}</span>
        </div>
      )
    }
  </div>
  <div class="mt-4 space-y-1">
    {/*
      Card title is `h3` so it sits one level below the section's `h2`
      (e.g. "Pilihan terbaru" / "Hasil pencarian"). Pages that use
      `ProductCard` must render that `h2` to keep heading order valid.
    */}
    <h3 class="t-body line-clamp-1 text-fg transition-colors duration-200 group-hover:text-accent">
      {title}
    </h3>
    <div class="flex items-baseline gap-2 t-body">
      <Price money={product.basePrice} muted />
      {compareAt && <Price money={compareAt} strike />}
    </div>
  </div>
</a>
