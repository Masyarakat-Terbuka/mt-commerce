---
/**
 * Pagination — text-only, tiny, breathing room above and below.
 *
 * Renders as `← Sebelumnya · 1 · 2 · 3 · Selanjutnya →`. No buttons,
 * no borders. The active page is the only one rendered with full-strength
 * foreground; siblings stay muted. Disabled prev/next fade further.
 *
 * Sits in `.t-caption` (12px) instead of `.t-body` so it reads as a
 * navigational footnote rather than a primary action — fits the editorial
 * tone of the listing page.
 */
import { createTranslator, resolveLocale, type Locale } from "@/lib/i18n";
import { paginationItems } from "@/lib/pagination";

export interface Props {
  page: number;
  totalPages: number;
  /**
   * Base URL the page numbers append to. Should already include any active
   * filters as query string except `page`. The component appends `?page=N`
   * (or `&page=N` if the URL already has a query string).
   */
  baseUrl: string;
}

const { page, totalPages, baseUrl } = Astro.props;
const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);

function buildHref(p: number): string {
  const sep = baseUrl.includes("?") ? "&" : "?";
  return `${baseUrl}${sep}page=${p}`;
}

// Truncate to `1 … current-1 current current+1 … last` for deep ranges so
// the row stays a navigational footnote, not a wall of digits.
const items = paginationItems(page, totalPages);
const hasPrev = page > 1;
const hasNext = page < totalPages;
---

{
  totalPages > 1 && (
    <nav
      class="t-caption mt-20 flex items-center justify-center gap-4"
      aria-label="Pagination"
    >
      <a
        href={hasPrev ? buildHref(page - 1) : undefined}
        aria-disabled={!hasPrev}
        class:list={[
          "transition-colors duration-150",
          hasPrev
            ? "text-fg hover:text-accent"
            : "text-faint pointer-events-none",
        ]}
      >
        &larr; {t("products.list.pagination.prev")}
      </a>

      <span class="text-faint" aria-hidden="true">
        ·
      </span>

      <ul class="flex items-center gap-4">
        {items.map((item) =>
          item.type === "ellipsis" ? (
            <li aria-hidden="true" class="text-faint">
              …
            </li>
          ) : (
            <li>
              <a
                href={buildHref(item.page)}
                aria-current={item.page === page ? "page" : undefined}
                class:list={[
                  "price-figure transition-colors duration-150",
                  item.page === page
                    ? "text-fg"
                    : "text-faint hover:text-accent",
                ]}
              >
                {item.page}
              </a>
            </li>
          ),
        )}
      </ul>

      <span class="text-faint" aria-hidden="true">
        ·
      </span>

      <a
        href={hasNext ? buildHref(page + 1) : undefined}
        aria-disabled={!hasNext}
        class:list={[
          "transition-colors duration-150",
          hasNext
            ? "text-fg hover:text-accent"
            : "text-faint pointer-events-none",
        ]}
      >
        {t("products.list.pagination.next")} &rarr;
      </a>
    </nav>
  )
}
