---
/**
 * Pagination — text-only.
 *
 * Renders as `← Sebelumnya · 1 2 3 · Selanjutnya →`. No buttons-with-borders;
 * the calm direction calls for typographic restraint here too. The active
 * page is the only one rendered with full-strength foreground; siblings stay
 * muted, and disabled prev/next fade further.
 */
import { createTranslator, resolveLocale, type Locale } from "@/lib/i18n";

export interface Props {
  page: number;
  totalPages: number;
  /**
   * Base URL the page numbers append to. Should already include any active
   * filters as query string except `page`. The component appends `?page=N`
   * (or `&page=N` if the URL already has a query string).
   */
  baseUrl: string;
}

const { page, totalPages, baseUrl } = Astro.props;
const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);

function buildHref(p: number): string {
  const sep = baseUrl.includes("?") ? "&" : "?";
  return `${baseUrl}${sep}page=${p}`;
}

const pages = Array.from({ length: totalPages }, (_, i) => i + 1);
const hasPrev = page > 1;
const hasNext = page < totalPages;
---

{
  totalPages > 1 && (
    <nav class="mt-12 flex items-center justify-center gap-3 t-body" aria-label="Pagination">
      <a
        href={hasPrev ? buildHref(page - 1) : undefined}
        aria-disabled={!hasPrev}
        class:list={[
          "transition-colors duration-150",
          hasPrev ? "text-fg hover:text-accent" : "pointer-events-none text-faint",
        ]}
      >
        &larr; {t("products.list.pagination.prev")}
      </a>

      <span class="text-faint" aria-hidden="true">·</span>

      <ul class="flex items-center gap-3">
        {pages.map((p) => (
          <li>
            <a
              href={buildHref(p)}
              aria-current={p === page ? "page" : undefined}
              class:list={[
                "price-figure transition-colors duration-150",
                p === page ? "font-medium text-fg" : "text-muted hover:text-accent",
              ]}
            >
              {p}
            </a>
          </li>
        ))}
      </ul>

      <span class="text-faint" aria-hidden="true">·</span>

      <a
        href={hasNext ? buildHref(page + 1) : undefined}
        aria-disabled={!hasNext}
        class:list={[
          "transition-colors duration-150",
          hasNext ? "text-fg hover:text-accent" : "pointer-events-none text-faint",
        ]}
      >
        {t("products.list.pagination.next")} &rarr;
      </a>
    </nav>
  )
}
