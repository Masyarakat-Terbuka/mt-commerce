---
/**
 * Header — typographic, sticky, calm.
 *
 * Layout:
 *   - Left: word-mark "mt-commerce" (weight 600).
 *   - Center: nav links (Beranda · Produk · Tentang) on desktop only.
 *   - Right: search toggle, cart link with count badge, language switcher,
 *     account link.
 *
 * Interaction:
 *   - The search button is a `<details>` toggle. Opening it expands the
 *     header by ~56px and reveals an inline `<input>` that submits to
 *     `/products?q=…`. No JS, no React island; the browser handles the
 *     toggle and the form's GET submit handles the navigation.
 *   - Mobile collapses the nav into another `<details>` next to the
 *     word-mark. The search icon stays visible at every breakpoint.
 *
 * The cart count is left at zero in markup until the cart store lands;
 * the badge structure is in place so the eventual store can hydrate it
 * without restyling the header.
 */
import { createTranslator, resolveLocale, localePath, type Locale } from "@/lib/i18n";

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);

const homeHref = localePath(locale, "/");
const productsHref = localePath(locale, "/products");
const aboutHref = localePath(locale, "/about");
const cartHref = localePath(locale, "/cart");
const accountHref = localePath(locale, "/account");
const searchAction = localePath(locale, "/products");

// Build language switcher hrefs by stripping the locale prefix from the
// current path and re-prefixing for the target locale.
const currentPath = Astro.url.pathname;
const stripped = currentPath.replace(/^\/(en|id)(?=\/|$)/, "") || "/";
const idHref = localePath("id", stripped);
const enHref = localePath("en", stripped);
---

<header
  class="sticky top-0 z-40 border-b border-line bg-cream/95 backdrop-blur supports-[backdrop-filter]:bg-cream/80"
>
  <div class="mx-auto flex h-14 max-w-[1280px] items-center justify-between gap-4 px-4 md:h-16 md:px-8">
    {/* Left cluster: mobile menu + word-mark */}
    <div class="flex items-center gap-3">
      <details class="relative md:hidden">
        <summary
          class="flex h-9 w-9 cursor-pointer list-none items-center justify-center text-fg [&::-webkit-details-marker]:hidden"
          aria-label={t("nav.menu")}
        >
          {/* Three-line menu glyph drawn in CSS, no icon font. */}
          <span class="block h-px w-5 bg-fg before:mb-1.5 before:block before:h-px before:w-5 before:bg-fg before:content-[''] after:mt-1.5 after:block after:h-px after:w-5 after:bg-fg after:content-['']"></span>
        </summary>
        <nav
          class="absolute left-0 top-full z-30 mt-px w-[calc(100vw-2rem)] border border-line bg-paper p-4"
          aria-label="Mobile"
        >
          <ul class="flex flex-col gap-3 t-body">
            <li><a class="block py-1 hover:text-accent" href={homeHref}>{t("nav.home")}</a></li>
            <li><a class="block py-1 hover:text-accent" href={productsHref}>{t("nav.products")}</a></li>
            <li><a class="block py-1 hover:text-accent" href={aboutHref}>{t("nav.about")}</a></li>
          </ul>
        </nav>
      </details>

      <a href={homeHref} class="text-[15px] font-semibold tracking-tight text-fg">
        mt-commerce
      </a>
    </div>

    {/* Center: desktop nav */}
    <nav class="hidden md:block" aria-label="Primary">
      <ul class="flex items-center gap-8 t-body text-fg">
        <li>
          <a class="transition-colors duration-150 hover:text-accent" href={homeHref}>{t("nav.home")}</a>
        </li>
        <li>
          <a class="transition-colors duration-150 hover:text-accent" href={productsHref}>{t("nav.products")}</a>
        </li>
        <li>
          <a class="transition-colors duration-150 hover:text-accent" href={aboutHref}>{t("nav.about")}</a>
        </li>
      </ul>
    </nav>

    {/* Right cluster: search, cart, language, account */}
    <div class="flex items-center gap-1 md:gap-2">
      <details class="group relative">
        <summary
          class="flex h-9 w-9 cursor-pointer list-none items-center justify-center text-fg transition-colors duration-150 hover:text-accent [&::-webkit-details-marker]:hidden"
          aria-label={t("nav.search")}
        >
          {/* Magnifier glyph as inline SVG so we don't add an icon dep. */}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </summary>
        <form
          method="get"
          action={searchAction}
          class="absolute right-0 top-full z-30 mt-px flex w-[min(380px,calc(100vw-2rem))] items-center gap-2 border border-line bg-paper p-3"
          role="search"
        >
          <label class="t-caption uppercase tracking-wide text-muted" for="header-search">
            {t("nav.search")}
          </label>
          <input
            id="header-search"
            type="search"
            name="q"
            autocomplete="off"
            class="flex-1 border-b border-line bg-transparent py-1 t-body text-fg outline-none transition-colors duration-150 focus:border-accent"
          />
          <button type="submit" class="t-caption uppercase tracking-wide text-fg hover:text-accent">
            &rarr;
          </button>
        </form>
      </details>

      <a
        href={cartHref}
        class="flex h-9 items-center gap-1.5 px-2 t-body text-fg transition-colors duration-150 hover:text-accent"
        aria-label={t("nav.cart")}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6L18 2H6Z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        <span class="hidden md:inline">{t("nav.cart")}</span>
      </a>

      <div class="hidden items-center gap-0.5 t-caption uppercase tracking-wide md:flex">
        <a
          href={idHref}
          aria-current={locale === "id" ? "true" : undefined}
          class:list={[
            "px-2 py-1 transition-colors duration-150",
            locale === "id" ? "text-fg" : "text-muted hover:text-fg",
          ]}
        >
          ID
        </a>
        <span class="text-faint" aria-hidden="true">·</span>
        <a
          href={enHref}
          aria-current={locale === "en" ? "true" : undefined}
          class:list={[
            "px-2 py-1 transition-colors duration-150",
            locale === "en" ? "text-fg" : "text-muted hover:text-fg",
          ]}
        >
          EN
        </a>
      </div>

      <a
        href={accountHref}
        class="hidden h-9 items-center px-2 t-caption uppercase tracking-wide text-fg transition-colors duration-150 hover:text-accent md:flex"
      >
        {t("nav.account")}
      </a>
    </div>
  </div>
</header>
