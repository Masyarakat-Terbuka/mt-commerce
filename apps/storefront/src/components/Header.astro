---
/**
 * Header — single thin bar, sticky, calm.
 *
 * Layout (left → right):
 *   - Mobile menu toggle (mobile only)
 *   - Lowercase wordmark "mt-commerce" — `t-body` weight 400, no styling
 *   - Center nav: Beranda · Produk · Tentang (`t-body` weight 400, +0.02em
 *     tracking, generous gap)
 *   - Right cluster: small magnifier, cart icon with optional count dot,
 *     account link, locale toggle (`id · en` lowercase, tiny)
 *
 * Surface: `bg-cream` (matches body) with a 1px hairline bottom border.
 * No backdrop blur, no transparency tricks, no drop shadow — the header
 * sits on top of the same cream the body uses, so it just dissolves into
 * the page.
 *
 * The cart count is left at zero in markup until the cart store lands;
 * the dot structure is in place so the eventual store can hydrate it
 * without restyling the header.
 */
import { createTranslator, resolveLocale, localePath, type Locale } from "@/lib/i18n";
import CartCountBadge from "@/islands/CartCountBadge.tsx";
import CartDrawer from "@/islands/CartDrawer.tsx";
import Icon from "@/components/Icon.astro";
// Hugeicons mirror the admin's icon vocabulary so glyphs match across apps.
// Inline rendering through <Icon /> keeps the .astro tree React-island-free.
import { Search01Icon, ShoppingBag01Icon } from "@hugeicons/core-free-icons";

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);

const homeHref = localePath(locale, "/");
const productsHref = localePath(locale, "/products");
const aboutHref = localePath(locale, "/about");
const cartHref = localePath(locale, "/cart");
const accountHref = localePath(locale, "/account");
const searchAction = localePath(locale, "/products");

// Build language switcher hrefs by stripping the locale prefix from the
// current path and re-prefixing for the target locale.
const currentPath = Astro.url.pathname;
const stripped = currentPath.replace(/^\/(en|id)(?=\/|$)/, "") || "/";
const idHref = localePath("id", stripped);
const enHref = localePath("en", stripped);

const checkoutHref = localePath(locale, "/checkout");
const intlLocale = locale === "id" ? "id-ID" : "en-US";
---

<header class="sticky top-0 z-40 border-b border-line bg-cream">
  <div class="mx-auto flex h-14 max-w-[1280px] items-center justify-between gap-4 px-5 md:h-16 md:px-8">
    {/* Left cluster: mobile menu + lowercase wordmark */}
    <div class="flex items-center gap-3">
      <details class="relative md:hidden">
        <summary
          class="flex h-9 w-9 cursor-pointer list-none items-center justify-center text-fg [&::-webkit-details-marker]:hidden"
          aria-label={t("nav.menu")}
        >
          {/* Two thin lines — calmer than the usual three. */}
          <span class="block h-px w-5 bg-fg before:mb-1.5 before:block before:h-px before:w-5 before:bg-fg before:content-['']"></span>
        </summary>
        <nav
          class="absolute left-0 top-full z-30 mt-px w-[calc(100vw-2.5rem)] border-b border-line bg-cream px-5 py-6"
          aria-label="Mobile"
        >
          <ul class="flex flex-col gap-4 t-body">
            <li><a class="block hover:text-accent" href={homeHref}>{t("nav.home")}</a></li>
            <li><a class="block hover:text-accent" href={productsHref}>{t("nav.products")}</a></li>
            <li><a class="block hover:text-accent" href={aboutHref}>{t("nav.about")}</a></li>
            <li><a class="block hover:text-accent" href={accountHref}>{t("nav.account")}</a></li>
          </ul>
        </nav>
      </details>

      {/*
        Brand lockup: small logo tile + lowercase wordmark. The mark is a
        white door silhouette on a black tile (~28px square) — used as a
        modest accent rather than the wordmark itself, so the dark block
        doesn't dominate the cream header. `loading="eager"` because it's
        above the fold on every page.
      */}
      <a
        href={homeHref}
        aria-label={t("nav.home")}
        class="flex items-center gap-2 text-fg transition-colors duration-150 hover:text-accent"
      >
        <img
          src="/logo.png"
          alt=""
          width="28"
          height="28"
          loading="eager"
          decoding="async"
          class="size-7 rounded-sm"
        />
        <span class="t-body font-normal lowercase tracking-tight">
          mt-commerce
        </span>
      </a>
    </div>

    {/* Center: desktop nav. Tracking is wider than body to feel architectural. */}
    <nav class="hidden md:block" aria-label="Primary">
      <ul class="flex items-center gap-10 t-body text-fg">
        <li>
          <a
            class="tracking-[0.01em] transition-colors duration-150 hover:text-accent"
            href={homeHref}
          >
            {t("nav.home")}
          </a>
        </li>
        <li>
          <a
            class="tracking-[0.01em] transition-colors duration-150 hover:text-accent"
            href={productsHref}
          >
            {t("nav.products")}
          </a>
        </li>
        <li>
          <a
            class="tracking-[0.01em] transition-colors duration-150 hover:text-accent"
            href={aboutHref}
          >
            {t("nav.about")}
          </a>
        </li>
      </ul>
    </nav>

    {/* Right cluster: search, cart, account, locale toggle */}
    <div class="flex items-center gap-1">
      <details class="group relative">
        <summary
          class="flex h-9 w-9 cursor-pointer list-none items-center justify-center text-fg transition-colors duration-150 hover:text-accent [&::-webkit-details-marker]:hidden"
          aria-label={t("nav.search")}
        >
          {/* Hugeicons Search01 — decorative; the <summary> carries aria-label. */}
          <Icon icon={Search01Icon} />
        </summary>
        <form
          method="get"
          action={searchAction}
          class="absolute right-0 top-full z-30 mt-px flex w-[min(380px,calc(100vw-2.5rem))] items-center gap-3 border-b border-line bg-cream px-5 py-4"
          role="search"
        >
          <label class="sr-only" for="header-search">{t("nav.search")}</label>
          <input
            id="header-search"
            type="search"
            name="q"
            autocomplete="off"
            placeholder={t("nav.search").toLowerCase()}
            class="flex-1 border-b border-line bg-transparent py-1 t-body text-fg placeholder:text-faint outline-none transition-colors duration-150 focus:border-fg"
          />
          <button type="submit" class="t-body text-fg hover:text-accent">
            &rarr;
          </button>
        </form>
      </details>

      <a
        href={cartHref}
        class="relative flex h-9 w-9 items-center justify-center text-fg transition-colors duration-150 hover:text-accent"
        aria-label={t("nav.cart")}
      >
        {/* Hugeicons ShoppingBag01 — calmer than the cart-with-wheels variant
            and visually closer to the Saturdays NYC bag silhouette. The
            anchor's aria-label describes the action; the icon stays decorative. */}
        <Icon icon={ShoppingBag01Icon} />
        {/* Count dot — empty in markup until the cart store lands. The
            element stays mounted so the layout stays stable when a count
            arrives. */}
        <span
          data-cart-count
          class="absolute -right-0.5 -top-0.5 hidden h-1.5 w-1.5 rounded-full bg-accent"
          aria-hidden="true"
        ></span>
      </a>

      <a
        href={accountHref}
        class="hidden h-9 items-center px-3 t-body text-fg transition-colors duration-150 hover:text-accent md:flex"
      >
        {t("nav.account")}
      </a>

      <div class="hidden items-center gap-1 pl-2 t-caption md:flex">
        <a
          href={idHref}
          aria-current={locale === "id" ? "true" : undefined}
          class:list={[
            "px-1 lowercase tracking-[0.05em] transition-colors duration-150",
            locale === "id" ? "text-fg" : "text-faint hover:text-fg",
          ]}
        >
          id
        </a>
        <span class="text-faint" aria-hidden="true">·</span>
        <a
          href={enHref}
          aria-current={locale === "en" ? "true" : undefined}
          class:list={[
            "px-1 lowercase tracking-[0.05em] transition-colors duration-150",
            locale === "en" ? "text-fg" : "text-faint hover:text-fg",
          ]}
        >
          en
        </a>
      </div>
    </div>
  </div>
</header>
