---
import { createTranslator, resolveLocale, localePath, type Locale } from "@/lib/i18n";

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);

// Build the URL the language switcher links to. We swap the locale prefix
// of the current path; if the target locale is the default ("id"), the prefix
// is dropped entirely.
const currentPath = Astro.url.pathname;
const stripped = currentPath.replace(/^\/(en|id)(?=\/|$)/, "") || "/";
const idHref = localePath("id", stripped);
const enHref = localePath("en", stripped);
---

<header class="border-b border-neutral-200 bg-white">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href={localePath(locale, "/")} class="text-lg font-semibold text-neutral-900">
      mt-commerce
    </a>

    <details class="relative md:hidden">
      <summary
        class="cursor-pointer list-none rounded-md border border-neutral-300 px-3 py-1.5 text-sm"
        aria-label="Menu"
      >
        Menu
      </summary>
      <nav
        class="absolute right-0 z-10 mt-2 w-48 rounded-md border border-neutral-200 bg-white p-2 shadow-md"
      >
        <ul class="flex flex-col gap-1 text-sm">
          <li><a class="block rounded px-2 py-1.5 hover:bg-neutral-100" href={localePath(locale, "/")}>{t("nav.home")}</a></li>
          <li><a class="block rounded px-2 py-1.5 hover:bg-neutral-100" href={localePath(locale, "/products")}>{t("nav.products")}</a></li>
          <li><a class="block rounded px-2 py-1.5 hover:bg-neutral-100" href={localePath(locale, "/cart")}>{t("nav.cart")}</a></li>
        </ul>
      </nav>
    </details>

    <nav class="hidden md:block">
      <ul class="flex items-center gap-6 text-sm text-neutral-700">
        <li><a class="hover:text-neutral-900" href={localePath(locale, "/")}>{t("nav.home")}</a></li>
        <li><a class="hover:text-neutral-900" href={localePath(locale, "/products")}>{t("nav.products")}</a></li>
        <li><a class="hover:text-neutral-900" href={localePath(locale, "/cart")}>{t("nav.cart")}</a></li>
      </ul>
    </nav>

    <div class="flex items-center gap-2 text-xs text-neutral-600">
      <a
        href={idHref}
        aria-current={locale === "id" ? "true" : undefined}
        class:list={[
          "rounded px-2 py-1",
          locale === "id" ? "bg-neutral-900 text-white" : "hover:bg-neutral-100",
        ]}
      >
        ID
      </a>
      <a
        href={enHref}
        aria-current={locale === "en" ? "true" : undefined}
        class:list={[
          "rounded px-2 py-1",
          locale === "en" ? "bg-neutral-900 text-white" : "hover:bg-neutral-100",
        ]}
      >
        EN
      </a>
    </div>
  </div>
</header>
