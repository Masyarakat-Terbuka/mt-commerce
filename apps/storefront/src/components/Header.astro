---
/**
 * Header — single thin bar, sticky, calm.
 *
 * Layout (left → right):
 *   - Mobile menu toggle (mobile only)
 *   - Lowercase wordmark "mt-commerce" — `t-body` weight 400, no styling
 *   - Center nav: Beranda · Produk · Tentang (`t-body` weight 400, +0.02em
 *     tracking, generous gap)
 *   - Right cluster: search form (always visible from `md` up; magnifier
 *     toggle on mobile to keep the bar uncluttered), cart icon with
 *     optional count dot, account link, locale toggle (`id · en`
 *     lowercase, tiny)
 *
 * Surface: `bg-cream` (matches body) with a 1px hairline bottom border.
 * No backdrop blur, no transparency tricks, no drop shadow — the header
 * sits on top of the same cream the body uses, so it just dissolves into
 * the page.
 *
 * The cart count is left at zero in markup until the cart store lands;
 * the dot structure is in place so the eventual store can hydrate it
 * without restyling the header.
 */
import {
  createTranslator,
  resolveLocale,
  localePath,
  type Locale,
} from "@/lib/i18n";
import { listCategories, listProducts } from "@/lib/api";
import Price from "@/components/Price.astro";
import CartCountBadge from "@/islands/CartCountBadge.tsx";
import HeaderAccountLink from "@/islands/HeaderAccountLink.tsx";
import Icon from "@/components/Icon.astro";
// Hugeicons mirror the admin's icon vocabulary so glyphs match across apps.
// Inline rendering through <Icon /> keeps the .astro tree React-island-free.
import { Search01Icon, ShoppingBag01Icon } from "@hugeicons/core-free-icons";

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);

const homeHref = localePath(locale, "/");
const productsHref = localePath(locale, "/products");
const aboutHref = localePath(locale, "/about");
const cartHref = localePath(locale, "/cart");
const accountHref = localePath(locale, "/account");

// ---------------------------------------------------------------------------
// Mega-menu data — fetched at SSR time so the panel renders pre-hydrated.
//
// Both calls are wrapped in `try/catch` inside `lib/api.ts` and return empty
// shapes on failure, so a build with the API unreachable still produces a
// usable header (categories collapse to nothing; the "Lihat semua" link
// alone is the resilient fallback).
//
// Featured products: pick the newest 3 across the whole catalog rather than
// "newest in the first category". The first category is alphabetical, so
// scoping to it would surface the same three products on every page until
// that category gets new stock — visually stale.
// ---------------------------------------------------------------------------
const [megaCategories, megaFeatured] = await Promise.all([
  listCategories(locale),
  listProducts(locale, { pageSize: 3, sort: "newest" }),
]);
// The header form posts to the dedicated search results page rather than
// the product listing. /products is for browsing the catalog; /search is
// where a typed query (`?q=...`) renders results, breadcrumb, and a
// no-results state. Keeps the two intents — browse vs. search — apart.
const searchAction = localePath(locale, "/search");

// Build language switcher hrefs by stripping the locale prefix from the
// current path and re-prefixing for the target locale.
const currentPath = Astro.url.pathname;
const stripped = currentPath.replace(/^\/(en|id)(?=\/|$)/, "") || "/";
const idHref = localePath("id", stripped);
const enHref = localePath("en", stripped);

const checkoutHref = localePath(locale, "/checkout");
const intlLocale = locale === "id" ? "id-ID" : "en-US";
---

<header class="border-line bg-cream sticky top-0 z-40 border-b">
  <div
    class="mx-auto flex h-14 max-w-[1280px] items-center justify-between gap-4 px-5 md:h-16 md:px-8"
  >
    {/* Left cluster: mobile menu + lowercase wordmark */}
    <div class="flex items-center gap-3">
      <details class="relative md:hidden">
        <summary
          class="text-fg flex h-9 w-9 cursor-pointer list-none items-center justify-center [&::-webkit-details-marker]:hidden"
          aria-label={t("nav.menu")}
        >
          {/* Two thin lines — calmer than the usual three. */}
          <span
            class="bg-fg before:bg-fg block h-px w-5 before:mb-1.5 before:block before:h-px before:w-5 before:content-['']"
          ></span>
        </summary>
        <nav
          class="border-line bg-cream absolute top-full left-0 z-30 mt-px w-[calc(100vw-2.5rem)] border-b px-5 py-6"
          aria-label="Mobile"
        >
          <ul class="t-body flex flex-col gap-4">
            <li>
              <a class="hover:text-accent block" href={homeHref}
                >{t("nav.home")}</a
              >
            </li>
            <li>
              <a class="hover:text-accent block" href={productsHref}
                >{t("nav.products")}</a
              >
            </li>
            <li>
              <a class="hover:text-accent block" href={aboutHref}
                >{t("nav.about")}</a
              >
            </li>
            <li>
              <a class="hover:text-accent block" href={accountHref}
                >{t("nav.account")}</a
              >
            </li>
          </ul>
        </nav>
      </details>

      {
        /*
        Brand lockup: small logo tile + lowercase wordmark. The mark is a
        white door silhouette on a black tile (~28px square) — used as a
        modest accent rather than the wordmark itself, so the dark block
        doesn't dominate the cream header. `loading="eager"` because it's
        above the fold on every page.
      */
      }
      {
        /*
        Brand link: the visible wordmark IS the accessible name, so no
        `aria-label` (Lighthouse fires `label-content-name-mismatch` when
        an aria-label diverges from a visible text label). The logo is
        decorative (`alt=""`) — the wordmark carries the name on its own.
      */
      }
      <a
        href={homeHref}
        class="text-fg hover:text-accent flex items-center gap-2 transition-colors duration-150"
      >
        <img
          src="/logo.png"
          alt=""
          width="28"
          height="28"
          loading="eager"
          decoding="async"
          class="size-7 rounded-sm"
        />
        <span class="t-body font-normal tracking-tight lowercase">
          mt-commerce
        </span>
      </a>
    </div>

    {
      /* Center: desktop nav. Tracking is wider than body to feel architectural. */
    }
    <nav class="hidden md:block" aria-label="Primary" data-mega-menu-root>
      <ul class="t-body text-fg flex items-center gap-10">
        <li>
          <a
            class="hover:text-accent tracking-[0.01em] transition-colors duration-150"
            href={homeHref}
          >
            {t("nav.home")}
          </a>
        </li>
        {
          /*
            Products entry — mega-menu trigger.

            A real <button> (not an <a>) for keyboard activation: pressing
            Enter or Space toggles the panel rather than navigating away.
            Hover (via JS mouseenter/leave with a small grace timeout) and
            focus-within open it; ESC closes and returns focus here.

            The panel itself lives outside the <ul> to span the full header
            width — it's anchored to the <header> via `position: absolute`
            on the .mega-menu-panel below.
          */
        }
        <li>
          <button
            type="button"
            class="hover:text-accent cursor-pointer tracking-[0.01em] transition-colors duration-150"
            aria-expanded="false"
            aria-haspopup="true"
            aria-controls="mega-menu-panel"
            data-mega-menu-trigger
          >
            {t("nav.products")}
          </button>
        </li>
        <li>
          <a
            class="hover:text-accent tracking-[0.01em] transition-colors duration-150"
            href={aboutHref}
          >
            {t("nav.about")}
          </a>
        </li>
      </ul>
    </nav>

    {/* Right cluster: search, cart, account, locale toggle */}
    <div class="flex items-center gap-1">
      {
        /*
        Search — two presentations from the same source-of-truth form:

        Desktop (md+): always visible inline form. The magnifier icon sits
        as a leading visual on the left of the input (decorative, the
        `<label class="sr-only">` carries the accessible name). Single
        text input — pressing Enter submits to /search (the default
        behavior of a single-input GET form), so no visible button is
        needed. Borderless input with a 1px hairline that becomes
        `border-fg` on focus, matching the Filters search style.

        Mobile (<md): falls back to the existing `<details>` toggle so
        the brand + cart + account aren't pushed off the bar. The toggle
        reveals the same form below the header on tap.
      */
      }
      <form
        method="get"
        action={searchAction}
        class="border-line text-faint focus-within:text-fg focus-within:border-fg hidden items-center gap-2 border-b py-1 transition-colors duration-150 md:flex md:w-[280px] lg:w-[360px]"
        role="search"
      >
        <label class="sr-only" for="header-search-desktop">
          {t("nav.search")}
        </label>
        {/* Decorative — the label above is the accessible name. */}
        <Icon icon={Search01Icon} size={16} class="shrink-0" />
        <input
          id="header-search-desktop"
          type="search"
          name="q"
          autocomplete="off"
          placeholder={t("nav.search_placeholder")}
          class="t-body text-fg placeholder:text-faint w-full bg-transparent outline-none"
        />
      </form>

      <details class="group relative md:hidden">
        <summary
          class="text-fg hover:text-accent flex h-9 w-9 cursor-pointer list-none items-center justify-center transition-colors duration-150 [&::-webkit-details-marker]:hidden"
          aria-label={t("nav.search")}
        >
          {
            /* Hugeicons Search01 — decorative; the <summary> carries aria-label. */
          }
          <Icon icon={Search01Icon} />
        </summary>
        <form
          method="get"
          action={searchAction}
          class="border-line bg-cream absolute top-full right-0 z-30 mt-px flex w-[min(380px,calc(100vw-2.5rem))] items-center gap-3 border-b px-5 py-4"
          role="search"
        >
          <label class="sr-only" for="header-search-mobile">
            {t("nav.search")}
          </label>
          <input
            id="header-search-mobile"
            type="search"
            name="q"
            autocomplete="off"
            placeholder={t("nav.search_placeholder")}
            class="border-line t-body text-fg placeholder:text-faint focus:border-fg flex-1 border-b bg-transparent py-1 transition-colors duration-150 outline-none"
          />
          <button type="submit" class="t-body text-fg hover:text-accent">
            &rarr;
          </button>
        </form>
      </details>

      <a
        href={cartHref}
        class="text-fg hover:text-accent relative flex h-9 w-9 items-center justify-center transition-colors duration-150"
        aria-label={t("nav.cart")}
        style="view-transition-name: header-cart;"
      >
        {
          /* Hugeicons ShoppingBag01 — calmer than the cart-with-wheels variant
            and visually closer to the Saturdays NYC bag silhouette. The
            anchor's aria-label describes the action; the icon stays decorative. */
        }
        <Icon icon={ShoppingBag01Icon} />
        {
          /* Count badge — React island that mirrors useCart().itemCount and
            plays a quiet scale bump on each successful add (data-cart-bump
            in global.css). Pairs a polite aria-live region with the visible
            number so screen readers also hear the update. */
        }
        <CartCountBadge
          client:idle
          announceTemplate={t("cart.count_announce")}
        />
      </a>

      {
        /*
        The account label upgrades to the customer's display name on hydration.
        Server-renders as a static link so JavaScript-disabled visitors and the
        initial paint always see a usable element.
      */
      }
      <HeaderAccountLink
        client:idle
        href={accountHref}
        fallbackLabel={t("nav.account")}
        className="t-body text-fg hover:text-accent hidden h-9 items-center px-3 transition-colors duration-150 md:flex"
      />
      <noscript>
        <a
          href={accountHref}
          class="t-body text-fg hover:text-accent hidden h-9 items-center px-3 transition-colors duration-150 md:flex"
        >
          {t("nav.account")}
        </a>
      </noscript>

      <div class="t-caption hidden items-center gap-1 pl-2 md:flex">
        <a
          href={idHref}
          aria-current={locale === "id" ? "true" : undefined}
          class:list={[
            "px-1 tracking-[0.05em] lowercase transition-colors duration-150",
            locale === "id" ? "text-fg" : "text-faint hover:text-fg",
          ]}
        >
          id
        </a>
        <span class="text-faint" aria-hidden="true">·</span>
        <a
          href={enHref}
          aria-current={locale === "en" ? "true" : undefined}
          class:list={[
            "px-1 tracking-[0.05em] lowercase transition-colors duration-150",
            locale === "en" ? "text-fg" : "text-faint hover:text-fg",
          ]}
        >
          en
        </a>
      </div>
    </div>
  </div>

  {
    /*
      Mega-menu panel.

      Anchored to <header> (which is `position: sticky`, so it forms a
      positioning context for `absolute` children). Sits below the header
      bar via `top-full`, full-width via `left-0 right-0`, with an inner
      max-width matching the rest of the site frame.

      Visual: matches the header surface (`bg-cream`, hairline border) so
      the panel reads as an extension of the header rather than a floating
      card. No shadow / no gradient / no glow — same calm rules.

      Hidden by default via `data-state="closed"` (the JS toggles it). The
      `hidden` attribute on the closed state keeps the panel out of the
      tab order and the accessibility tree until opened. Mobile (<md) hides
      it entirely — the existing left-hand <details> menu already covers
      mobile navigation, and a 4-column grid on a phone would be a wall of
      links.

      Animation: opacity + translateY, 150ms. `prefers-reduced-motion`
      collapses the translate to a snap.
    */
  }
  <div
    id="mega-menu-panel"
    role="region"
    aria-label={t("mega_menu.aria_label")}
    data-mega-menu-panel
    data-state="closed"
    hidden
    class="border-line bg-cream absolute top-full right-0 left-0 z-30 border-b"
  >
    <div class="mx-auto max-w-[1280px] px-5 py-8 md:px-8 md:py-10">
      <div class="grid grid-cols-4 gap-8">
        {/* Cols 1-3: categories */}
        <div class="col-span-3">
          <p class="t-overline text-faint mb-4">{t("nav.products")}</p>
          {
            megaCategories.length > 0 ? (
              <ul class="grid grid-cols-3 gap-x-6 gap-y-3">
                {megaCategories.map((category) => (
                  <li>
                    <a
                      href={localePath(
                        locale,
                        `/products?category=${category.slug}`,
                      )}
                      class="t-body text-fg hover:text-accent block transition-colors duration-150"
                      data-mega-menu-link
                    >
                      {category.name[locale]}
                    </a>
                  </li>
                ))}
              </ul>
            ) : null
          }
          <a
            href={productsHref}
            class="t-body text-fg hover:text-accent mt-6 inline-block tracking-[0.01em] transition-colors duration-150"
            data-mega-menu-link
          >
            {t("mega_menu.see_all_link")}
          </a>
        </div>

        {/* Col 4: featured products */}
        {
          megaFeatured.items.length > 0 && (
            <div>
              <p class="t-overline text-faint mb-4">
                {t("mega_menu.featured")}
              </p>
              <ul class="space-y-4">
                {megaFeatured.items.slice(0, 3).map((product) => (
                  <li>
                    <a
                      href={localePath(locale, `/products/${product.slug}`)}
                      class="group flex items-center gap-3"
                      data-mega-menu-link
                    >
                      <div class="bg-cream relative size-14 shrink-0 overflow-hidden">
                        {product.hasImage ? (
                          <img
                            src={product.imageUrl}
                            alt={product.imageAlt[locale]}
                            loading="lazy"
                            decoding="async"
                            width="56"
                            height="56"
                            class="size-full object-cover transition-opacity duration-150 group-hover:opacity-90"
                          />
                        ) : (
                          <div class="border-line size-full border" />
                        )}
                      </div>
                      <div class="min-w-0 flex-1">
                        <p class="t-body text-fg group-hover:text-accent line-clamp-1 transition-colors duration-150">
                          {product.title[locale]}
                        </p>
                        <Price
                          money={product.basePrice}
                          locale={intlLocale}
                          muted
                          class="t-caption"
                        />
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </div>
    </div>
  </div>
</header>

<style>
  /*
    Mega-menu open/closed transitions. Tailwind v4 generates the layout
    classes; the animation tokens live here because Tailwind doesn't ship
    a clean `data-state="open"` variant out of the box and inlining
    keyframe-style transitions in the markup would clutter the .astro tree.

    Rules:
      - Closed: opacity 0, translateY(-4px), `pointer-events: none` so a
        ghost panel doesn't trap clicks during the fade-out.
      - Open: opacity 1, translateY(0), interactive.
      - `prefers-reduced-motion: reduce` keeps the opacity swap (so it's
        still legible *something happened*) but drops the translate.

    The panel uses `[hidden]` to stay out of the a11y tree and tab order
    when closed; we only remove `hidden` when opening, then animate. On
    close we run the reverse transition then re-apply `hidden` — see the
    JS below.
  */
  [data-mega-menu-panel] {
    opacity: 0;
    transform: translateY(-4px);
    pointer-events: none;
    transition:
      opacity 150ms ease,
      transform 150ms ease;
  }
  [data-mega-menu-panel][data-state="open"] {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-mega-menu-panel] {
      transform: none;
      transition: opacity 100ms ease;
    }
    [data-mega-menu-panel][data-state="open"] {
      transform: none;
    }
  }
</style>

<script>
  /**
   * Mega-menu controller.
   *
   * The panel is server-rendered with `data-state="closed"` and the
   * `hidden` attribute. We toggle:
   *   - hover: open on mouseenter (trigger or panel), close on mouseleave
   *     after a 120ms grace timeout so a user crossing the gap between
   *     trigger and panel doesn't lose the menu.
   *   - focus: open when the trigger receives focus or focus moves into
   *     the panel; close when focus leaves both.
   *   - click on trigger: toggles (keyboard-friendly: Enter/Space land here).
   *   - ESC: closes and returns focus to the trigger.
   *   - astro:after-swap: closes the panel after every page swap so the
   *     fresh DOM starts in a known state.
   *
   * Re-attached on `astro:page-load` (fires once on initial load AND after
   * every ClientRouter swap), so a header re-mount does not leave dead
   * listeners or a stale-open panel.
   */
  function initMegaMenu() {
    // Listeners attach on every viewport — the trigger lives inside
    // `nav.hidden md:block`, so it's `display:none` below md and cannot
    // receive hover/focus/click. The panel therefore never opens on
    // mobile, where the existing left-hand <details> menu handles
    // navigation. Wiring unconditionally keeps the code simple across
    // viewport resize without a media-query listener.
    const trigger = document.querySelector<HTMLButtonElement>(
      "[data-mega-menu-trigger]",
    );
    const panel = document.querySelector<HTMLElement>("[data-mega-menu-panel]");
    if (!trigger || !panel) return;

    let closeTimer: number | undefined;
    const GRACE_MS = 120;

    const open = () => {
      if (closeTimer !== undefined) {
        window.clearTimeout(closeTimer);
        closeTimer = undefined;
      }
      if (panel.dataset.state === "open") return;
      panel.hidden = false;
      // Force a reflow so the transition picks up the state change. Reading
      // offsetHeight is the canonical way to flush pending style updates.
      void panel.offsetHeight;
      panel.dataset.state = "open";
      trigger.setAttribute("aria-expanded", "true");
    };

    const close = (returnFocus = false) => {
      if (panel.dataset.state === "closed") return;
      panel.dataset.state = "closed";
      trigger.setAttribute("aria-expanded", "false");
      // Wait for the 150ms transition to finish before adding `hidden`
      // back — otherwise the panel snaps invisible mid-animation.
      window.setTimeout(() => {
        if (panel.dataset.state === "closed") panel.hidden = true;
      }, 180);
      if (returnFocus) trigger.focus();
    };

    const scheduleClose = () => {
      if (closeTimer !== undefined) window.clearTimeout(closeTimer);
      closeTimer = window.setTimeout(() => close(false), GRACE_MS);
    };

    const cancelClose = () => {
      if (closeTimer !== undefined) {
        window.clearTimeout(closeTimer);
        closeTimer = undefined;
      }
    };

    // Hover.
    trigger.addEventListener("mouseenter", open);
    trigger.addEventListener("mouseleave", scheduleClose);
    panel.addEventListener("mouseenter", cancelClose);
    panel.addEventListener("mouseleave", scheduleClose);

    // Focus — opens on focus into trigger or panel, closes when focus
    // leaves both. Using a single focusout on the document and checking
    // relatedTarget keeps the logic simple.
    trigger.addEventListener("focus", open);
    panel.addEventListener("focusin", open);
    const onFocusOut = (event: FocusEvent) => {
      const next = event.relatedTarget as Node | null;
      if (!next) return;
      if (trigger.contains(next) || panel.contains(next)) return;
      close(false);
    };
    trigger.addEventListener("focusout", onFocusOut);
    panel.addEventListener("focusout", onFocusOut);

    // Click toggle (keyboard Enter/Space lands here too).
    trigger.addEventListener("click", (event) => {
      event.preventDefault();
      if (panel.dataset.state === "open") {
        close(false);
      } else {
        open();
      }
    });

    // ESC anywhere on the document closes the panel and returns focus.
    // The keydown listener attaches to `document`, which survives across
    // ClientRouter swaps — so we stash a reference on the window and tear
    // down any previous instance before re-adding. Without this the
    // listener count would grow with every navigation, leaking memory and
    // running the same handler N times on each ESC.
    const w = window as Window & { __mtMegaMenuKeydown?: EventListener };
    if (w.__mtMegaMenuKeydown) {
      document.removeEventListener("keydown", w.__mtMegaMenuKeydown);
    }
    const onKeyDown = (event: KeyboardEvent) => {
      if (event.key !== "Escape") return;
      if (panel.dataset.state !== "open") return;
      event.preventDefault();
      close(true);
    };
    w.__mtMegaMenuKeydown = onKeyDown as EventListener;
    document.addEventListener("keydown", onKeyDown);

    // Auto-close when a link inside the panel is followed — the
    // ClientRouter swap will rebuild the header anyway, but closing
    // immediately removes the visual lag between click and swap.
    panel
      .querySelectorAll<HTMLAnchorElement>("[data-mega-menu-link]")
      .forEach((link) => {
        link.addEventListener("click", () => close(false));
      });
  }

  // Astro fires `astro:page-load` on first paint AND after every
  // ClientRouter swap. Re-running init on each swap re-binds listeners
  // against the freshly rendered header.
  document.addEventListener("astro:page-load", initMegaMenu);
</script>
