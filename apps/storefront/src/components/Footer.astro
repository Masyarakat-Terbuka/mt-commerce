---
/**
 * Footer — sitemap-style, calm typography.
 *
 * Five columns on desktop (Shop / Help / About / Legal / Newsletter), three
 * on tablet with the newsletter column spanning the full row, and stacked
 * collapsible <details> sections on mobile. The collapsibles are the Muji
 * mobile pattern — five columns of links one-on-top-of-another would be a
 * wall of text on a phone, but a sitemap also doesn't want to disappear
 * behind a single "menu" toggle.
 *
 * The Shop column lists `listCategories(locale)` (capped at six entries),
 * so the footer becomes a real navigational surface that mirrors what the
 * site actually sells. We fetch at build time alongside other Astro data —
 * the API helper returns `[]` on failure, in which case the column quietly
 * collapses to just "All products". No empty heading, no error text.
 *
 * The Newsletter column is a heading + a single "not yet available" line.
 * No list-management service is wired up yet; we surface the absence
 * factually rather than ship a form that drops the address on the floor.
 *
 * Below the columns sits the calm bottom edge: brand wordmark, copyright,
 * locale toggle, and a small "Made in Indonesia" line. No emoji
 * (project rule), no fabricated social handles — just the GitHub repo link
 * which lives up in the About column where it belongs.
 */
import {
  createTranslator,
  resolveLocale,
  localePath,
  type Locale,
} from "@/lib/i18n";
import { listCategories } from "@/lib/api";

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);
const year = new Date().getFullYear();

// Mirror the header's locale-swap logic so the footer switcher stays in
// sync with whichever path the visitor is on.
const currentPath = Astro.url.pathname;
const stripped = currentPath.replace(/^\/(en|id)(?=\/|$)/, "") || "/";
const idHref = localePath("id", stripped);
const enHref = localePath("en", stripped);

// Build-time fetch. The helper returns `[]` on any failure (offline build,
// API unreachable), which we surface as a quiet "All products"-only Shop
// column rather than a broken section.
const allCategories = await listCategories(locale);
const categoryLinks = allCategories.slice(0, 6).map((c) => ({
  label: c.name[locale],
  href: localePath(locale, `/products?category=${encodeURIComponent(c.slug)}`),
}));

// Sitemap data. Defining the columns once keeps the desktop grid and the
// mobile <details> stack rendering from a single source.
//
// "Koleksi" sits at the top of the Shop column above "All products" and
// the category list — it surfaces curated landing pages without needing
// a sixth footer column. PRODUCT.md rules out a CMS for v0.1, so the
// link points at the hardcoded registry's index, not a navigation tree.
const productsHref = localePath(locale, "/products");
const collectionsHref = localePath(locale, "/collections");
const shopColumn = {
  heading: t("footer.shop.heading"),
  links: [
    { label: t("collections.index.title"), href: collectionsHref },
    { label: t("footer.shop.all_products"), href: productsHref },
    ...categoryLinks,
  ],
};
const helpColumn = {
  heading: t("footer.help.heading"),
  links: [
    {
      label: t("footer.help.shipping"),
      href: localePath(locale, "/help/shipping"),
    },
    {
      label: t("footer.help.returns"),
      href: localePath(locale, "/help/returns"),
    },
    {
      label: t("footer.help.payment"),
      href: localePath(locale, "/help/payment"),
    },
    { label: t("footer.help.faq"), href: localePath(locale, "/help/faq") },
  ],
};
const aboutColumn = {
  heading: t("footer.about.heading"),
  links: [
    { label: t("footer.about.about"), href: localePath(locale, "/about") },
    // /contact does not exist yet — point at /about anchor as a calm
    // placeholder. Updates to a real /contact page in a follow-up.
    { label: t("footer.about.contact"), href: localePath(locale, "/about") },
    {
      label: t("footer.col.community.github"),
      href: "https://github.com/masyarakat-terbuka/mt-commerce",
    },
  ],
};
const legalColumn = {
  heading: t("footer.legal.heading"),
  links: [
    {
      label: t("footer.legal.privacy"),
      href: localePath(locale, "/legal/privacy"),
    },
    {
      label: t("footer.legal.terms"),
      href: localePath(locale, "/legal/terms"),
    },
  ],
};

// Used by the desktop grid AND the mobile collapsibles. Keeps the two
// renderings in lockstep — adding a column means one entry here.
const linkColumns = [shopColumn, helpColumn, aboutColumn, legalColumn];

const newsletterHeading = t("footer.newsletter.heading");
const newsletterUnavailable = t("footer.newsletter.unavailable");

// Copyright line — t() returns a string template with `{year}`, replaced
// at render time so the year stays current without re-translating.
const copyrightLine = t("footer.copyright").replace("{year}", String(year));
---

<footer class="border-line bg-cream mt-16 border-t">
  <div class="mx-auto max-w-[1280px] px-5 py-10 md:px-8 md:py-14">
    {
      /*
      Desktop / tablet grid. 5 columns at md+ via the explicit `md:grid-cols-5`,
      with the newsletter taking 2 columns at the medium breakpoint where
      we have 3 link columns + a wider newsletter cell so the email input
      doesn't crush. On large screens the newsletter takes a single column.
    */
    }
    <div class="hidden gap-x-12 gap-y-10 md:grid md:grid-cols-3 lg:grid-cols-5">
      {
        linkColumns.map((column) => (
          <nav aria-label={column.heading}>
            <h2 class="t-overline text-muted">{column.heading}</h2>
            <ul class="t-body mt-5 flex flex-col gap-3">
              {column.links.map((link) => (
                <li>
                  <a
                    class="text-fg hover:text-accent transition-colors duration-150"
                    href={link.href}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
      {
        /*
        Newsletter cell. Spans the full row at the md breakpoint (3 columns
        wide so it sits below the link columns), single column at lg+.
        No list-management service is wired up yet — we surface the absence
        as a single calm line rather than ship a form with no backend.
      */
      }
      <div class="md:col-span-3 lg:col-span-1">
        <h2 class="t-overline text-muted">{newsletterHeading}</h2>
        <p class="t-body text-faint mt-5">{newsletterUnavailable}</p>
      </div>
    </div>

    {
      /*
      Mobile: collapsible <details> per column. <summary> uses the same
      t-overline label as the desktop heading so the visual rhythm matches.
      A thin chevron via ::after avoids shipping an icon for one button.
      Newsletter sits below as an expanded heading + single line; no form,
      mirroring the desktop column.
    */
    }
    <div class="flex flex-col md:hidden">
      {
        linkColumns.map((column) => (
          <details class="border-line group border-b">
            <summary class="t-overline text-muted flex cursor-pointer list-none items-center justify-between py-4 [&::-webkit-details-marker]:hidden">
              {column.heading}
              <span
                aria-hidden="true"
                class="text-faint transition-transform duration-150 group-open:rotate-45"
              >
                +
              </span>
            </summary>
            <ul class="t-body flex flex-col gap-3 pt-1 pb-5">
              {column.links.map((link) => (
                <li>
                  <a
                    class="text-fg hover:text-accent transition-colors duration-150"
                    href={link.href}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        ))
      }
      <div class="pt-8">
        <h2 class="t-overline text-muted">{newsletterHeading}</h2>
        <p class="t-body text-faint mt-3">{newsletterUnavailable}</p>
      </div>
    </div>

    {
      /*
      Bottom edge: wordmark + copyright on the left, region + locale on the
      right. Pulled apart from the grid with a thin border-line so the two
      zones read as separate.
    */
    }
    <div
      class="border-line t-caption mt-10 flex flex-col items-start gap-4 border-t pt-6 md:flex-row md:items-center md:justify-between md:gap-6"
    >
      <div
        class="text-faint flex flex-col items-start gap-1 md:flex-row md:items-center md:gap-3"
      >
        <span class="text-fg tracking-tight lowercase">mt-commerce</span>
        <span class="hidden md:inline" aria-hidden="true">·</span>
        <span>{copyrightLine}</span>
      </div>
      <div class="text-faint flex items-center gap-4">
        <span>{t("footer.region")}</span>
        <span aria-hidden="true">·</span>
        <div class="flex items-center gap-1">
          <a
            href={idHref}
            aria-current={locale === "id" ? "page" : undefined}
            class:list={[
              "px-1 tracking-[0.05em] lowercase transition-colors duration-150",
              locale === "id" ? "text-fg" : "text-faint hover:text-fg",
            ]}
          >
            id
          </a>
          <span class="text-faint" aria-hidden="true">·</span>
          <a
            href={enHref}
            aria-current={locale === "en" ? "page" : undefined}
            class:list={[
              "px-1 tracking-[0.05em] lowercase transition-colors duration-150",
              locale === "en" ? "text-fg" : "text-faint hover:text-fg",
            ]}
          >
            en
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
