---
/**
 * Footer — a single line of inline links and a copyright.
 *
 * The 4-column "site map" layout is intentionally gone. It read as
 * generic ecommerce; the editorial direction calls for a single
 * horizontal row of text-links separated by middots, followed by a
 * copyright row with a quiet locale toggle on the right.
 *
 * No social icons, no newsletter signup, no "back to top" button. When
 * something becomes worth pointing at, it earns a place inline here.
 */
import { createTranslator, resolveLocale, localePath, type Locale } from "@/lib/i18n";

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);
const year = new Date().getFullYear();

// Mirror the header's locale-swap logic so the footer switcher stays in
// sync with whichever path the visitor is on.
const currentPath = Astro.url.pathname;
const stripped = currentPath.replace(/^\/(en|id)(?=\/|$)/, "") || "/";
const idHref = localePath("id", stripped);
const enHref = localePath("en", stripped);

const links = [
  { label: t("footer.col.about.title"), href: localePath(locale, "/about") },
  { label: t("footer.col.help.title"), href: localePath(locale, "/help/faq") },
  { label: t("footer.col.community.title"), href: localePath(locale, "/contributing") },
  { label: t("footer.col.legal.privacy"), href: localePath(locale, "/legal/privacy") },
  { label: t("footer.col.legal.terms"), href: localePath(locale, "/legal/terms") },
];
---

<footer class="mt-32 border-t border-line bg-cream">
  <div class="mx-auto max-w-[1280px] px-5 py-12 md:px-8 md:py-16">
    {/* Single inline row of links — middot separated, wraps gracefully. */}
    <ul class="flex flex-wrap items-center gap-x-3 gap-y-2 t-body">
      {
        links.map((link, idx) => (
          <li class="flex items-center gap-x-3">
            <a
              class="text-fg transition-colors duration-150 hover:text-accent"
              href={link.href}
            >
              {link.label}
            </a>
            {idx < links.length - 1 && (
              <span class="text-faint" aria-hidden="true">·</span>
            )}
          </li>
        ))
      }
    </ul>

    {/* Copyright + locale toggle. The line above does the navigational work;
        this row is the page's quiet bottom edge. */}
    <div
      class="mt-10 flex flex-col items-start gap-3 t-caption md:flex-row md:items-center md:justify-between"
    >
      <p class="text-faint">© {year} {t("footer.copyright")}</p>
      <div class="flex items-center gap-1">
        <a
          href={idHref}
          aria-current={locale === "id" ? "true" : undefined}
          class:list={[
            "px-1 lowercase tracking-[0.05em] transition-colors duration-150",
            locale === "id" ? "text-fg" : "text-faint hover:text-fg",
          ]}
        >
          id
        </a>
        <span class="text-faint" aria-hidden="true">·</span>
        <a
          href={enHref}
          aria-current={locale === "en" ? "true" : undefined}
          class:list={[
            "px-1 lowercase tracking-[0.05em] transition-colors duration-150",
            locale === "en" ? "text-fg" : "text-faint hover:text-fg",
          ]}
        >
          en
        </a>
      </div>
    </div>
  </div>
</footer>
