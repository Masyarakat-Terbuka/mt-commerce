---
import { createTranslator, resolveLocale, localePath, type Locale } from "@/lib/i18n";
import { listCategories } from "@/lib/api";

export interface Props {
  active: {
    category?: string;
    search?: string;
    minPrice?: string;
    maxPrice?: string;
    sort?: string;
  };
}

const { active } = Astro.props;
const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);
const categories = listCategories();
const formAction = localePath(locale, "/products");
---

<form
  method="get"
  action={formAction}
  class="grid grid-cols-1 gap-3 rounded-lg border border-neutral-200 bg-white p-4 md:grid-cols-5"
>
  <label class="flex flex-col gap-1 text-xs font-medium text-neutral-700">
    {t("products.filters.search")}
    <input
      type="search"
      name="q"
      value={active.search ?? ""}
      class="rounded border border-neutral-300 px-2 py-1.5 text-sm"
    />
  </label>

  <label class="flex flex-col gap-1 text-xs font-medium text-neutral-700">
    {t("products.filters.category")}
    <select
      name="category"
      class="rounded border border-neutral-300 px-2 py-1.5 text-sm"
    >
      <option value="">—</option>
      {
        categories.map((c) => (
          <option value={c.slug} selected={active.category === c.slug}>
            {c.name[locale]}
          </option>
        ))
      }
    </select>
  </label>

  <label class="flex flex-col gap-1 text-xs font-medium text-neutral-700">
    {t("products.filters.price")} (min)
    <input
      type="number"
      name="min"
      inputmode="numeric"
      min="0"
      value={active.minPrice ?? ""}
      class="rounded border border-neutral-300 px-2 py-1.5 text-sm"
    />
  </label>

  <label class="flex flex-col gap-1 text-xs font-medium text-neutral-700">
    {t("products.filters.price")} (max)
    <input
      type="number"
      name="max"
      inputmode="numeric"
      min="0"
      value={active.maxPrice ?? ""}
      class="rounded border border-neutral-300 px-2 py-1.5 text-sm"
    />
  </label>

  <label class="flex flex-col gap-1 text-xs font-medium text-neutral-700">
    Sort
    <select
      name="sort"
      class="rounded border border-neutral-300 px-2 py-1.5 text-sm"
    >
      <option value="newest" selected={!active.sort || active.sort === "newest"}>
        {t("products.sort.newest")}
      </option>
      <option value="price_asc" selected={active.sort === "price_asc"}>
        {t("products.sort.price_asc")}
      </option>
      <option value="price_desc" selected={active.sort === "price_desc"}>
        {t("products.sort.price_desc")}
      </option>
    </select>
  </label>

  <div class="md:col-span-5">
    <button
      type="submit"
      class="rounded bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-800"
    >
      {t("products.filters.search")}
    </button>
  </div>
</form>
