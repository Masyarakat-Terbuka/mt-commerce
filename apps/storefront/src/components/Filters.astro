---
/**
 * Filters — horizontal bar above the grid.
 *
 * The previous left-rail with section legends and form layout was generic
 * ecommerce; the editorial direction calls for something flatter. The new
 * shape:
 *
 *   ┌ Search ──────────────────────────────────────────────────────┐
 *   │  cari produk…                                            →   │
 *   └──────────────────────────────────────────────────────────────┘
 *
 *   Semua · Kopi · Batik · Kerajinan · Kuliner · Fashion
 *
 *   Menampilkan 24 produk · Urutkan: [Terbaru ▾] · Filter ▾
 *      ↳ Filter expanded:  Min ___  —  Max ___  Terapkan
 *
 * Each interaction is a navigation (GET submit). With JS, the radios and
 * select auto-submit on change; without JS the explicit "Terapkan" button
 * stays as the fallback path. Search and price inputs debounce 600ms.
 *
 * Counts beside category names rendered when the small-catalog SDK call
 * succeeds; absent otherwise (degrade silently to plain category names).
 */
import { createTranslator, resolveLocale, localePath, type Locale } from "@/lib/i18n";
import { listCategories, listProducts } from "@/lib/api";

export interface Props {
  active: {
    category?: string;
    search?: string;
    minPrice?: string;
    maxPrice?: string;
    sort?: string;
  };
  /**
   * When true, renders a compact form (no count badges, no totals) for
   * use inside the mobile sheet. Default false renders the desktop bar.
   */
  inline?: boolean;
}

const { active, inline = false } = Astro.props;
const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);
const categories = await listCategories(locale);
const formAction = localePath(locale, "/products");

let totalCount = 0;
const countsBySlug = new Map<string, number>();
try {
  const all = await listProducts(locale, { pageSize: 100 });
  totalCount = all.total;
  for (const p of all.items) {
    const slug = p.categorySlug;
    if (!slug) continue;
    countsBySlug.set(slug, (countsBySlug.get(slug) ?? 0) + 1);
  }
} catch {
  // Silent degrade — empty counts, no badges.
}

const sortOptions = [
  { value: "newest", label: t("products.sort.newest") },
  { value: "price_asc", label: t("products.sort.price_asc") },
  { value: "price_desc", label: t("products.sort.price_desc") },
] as const;

const activeSort = active.sort && ["newest", "price_asc", "price_desc"].includes(active.sort)
  ? active.sort
  : "newest";

const hasPriceFilter = Boolean(active.minPrice || active.maxPrice);
---

<form
  method="get"
  action={formAction}
  data-filters-form
  class="t-body"
>
  {/* Search bar — single thin input, full width. */}
  <div class="flex items-center border-b border-line pb-3">
    <label for="filter-search" class="sr-only">{t("products.filters.search")}</label>
    <input
      id="filter-search"
      type="search"
      name="q"
      value={active.search ?? ""}
      placeholder={t("products.filters.search_placeholder")}
      autocomplete="off"
      class="flex-1 bg-transparent t-body text-fg placeholder:text-faint outline-none"
    />
    {/*
      Search submit. `min-h-9 px-3` gives a ≥36 px tap target so Lighthouse's
      mobile target-size audit passes; the arrow stays visually quiet.
    */}
    <button
      type="submit"
      class="inline-flex min-h-9 items-center px-3 t-body text-fg transition-colors duration-150 hover:text-accent"
      aria-label={t("products.filters.apply")}
    >
      &rarr;
    </button>
  </div>

  {/* Category — horizontal middot-separated text links (rendered as radios for no-JS). */}
  <fieldset class="mt-8">
    <legend class="sr-only">{t("products.filters.category")}</legend>
    <ul class="flex flex-wrap items-center gap-x-3 gap-y-2">
      <li class="flex items-center gap-x-3">
        <label
          class:list={[
            "cursor-pointer t-body transition-colors duration-150 hover:text-accent",
            !active.category ? "text-accent" : "text-fg",
          ]}
        >
          <input
            type="radio"
            name="category"
            value=""
            checked={!active.category}
            class="sr-only"
          />
          <span>
            {t("products.filters.category_all")}
            {!inline && totalCount > 0 && (
              <span class="ml-1 t-caption text-faint">({totalCount})</span>
            )}
          </span>
        </label>
      </li>
      {
        categories.map((c) => {
          const count = countsBySlug.get(c.slug);
          const isActive = active.category === c.slug;
          return (
            <li class="flex items-center gap-x-3">
              <span class="text-faint" aria-hidden="true">·</span>
              <label
                class:list={[
                  "cursor-pointer t-body transition-colors duration-150 hover:text-accent",
                  isActive ? "text-accent" : "text-fg",
                ]}
              >
                <input
                  type="radio"
                  name="category"
                  value={c.slug}
                  checked={isActive}
                  class="sr-only"
                />
                <span>
                  {c.name[locale]}
                  {!inline && typeof count === "number" && (
                    <span class="ml-1 t-caption text-faint">({count})</span>
                  )}
                </span>
              </label>
            </li>
          );
        })
      }
    </ul>
  </fieldset>

  {/* Sort + price-range disclosure row. Inline, sits left-aligned. */}
  <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3">
    <label class="flex items-center gap-2 t-caption text-muted">
      <span>{t("products.filters.sort")}:</span>
      <select
        name="sort"
        class="cursor-pointer border-0 bg-transparent t-body text-fg outline-none transition-colors duration-150 hover:text-accent focus:text-fg"
      >
        {
          sortOptions.map((opt) => (
            <option value={opt.value} selected={activeSort === opt.value}>
              {opt.label}
            </option>
          ))
        }
      </select>
    </label>

    <details class="group" data-filters-price-disclosure open={hasPriceFilter}>
      <summary
        class="flex cursor-pointer list-none items-center gap-1.5 t-caption text-muted transition-colors duration-150 hover:text-fg [&::-webkit-details-marker]:hidden"
      >
        <span>{t("products.filters.price")}</span>
        <span aria-hidden="true" class="t-body">+</span>
      </summary>
      <div class="mt-3 flex items-center gap-3">
        <label class="flex flex-1 flex-col">
          <span class="sr-only">{t("products.filters.price_min")}</span>
          <input
            type="number"
            name="min"
            inputmode="numeric"
            min="0"
            placeholder={t("products.filters.price_min")}
            value={active.minPrice ?? ""}
            class="price-figure w-28 border-b border-line bg-transparent py-1 t-body text-fg placeholder:text-faint outline-none transition-colors duration-150 focus:border-fg"
          />
        </label>
        <span class="text-faint" aria-hidden="true">—</span>
        <label class="flex flex-1 flex-col">
          <span class="sr-only">{t("products.filters.price_max")}</span>
          <input
            type="number"
            name="max"
            inputmode="numeric"
            min="0"
            placeholder={t("products.filters.price_max")}
            value={active.maxPrice ?? ""}
            class="price-figure w-28 border-b border-line bg-transparent py-1 t-body text-fg placeholder:text-faint outline-none transition-colors duration-150 focus:border-fg"
          />
        </label>
      </div>
    </details>

    {/*
      No-JS fallback — the inline script below hides this once auto-submit
      listeners attach. With JS, every change in the form auto-submits.
    */}
    {/*
      No-JS fallback button. `min-h-9 px-2` gives the tap target the 36×?
      footprint Lighthouse expects on mobile (it was failing the 24×24 floor
      previously), without growing the visual weight of the link-style label.
    */}
    <button
      type="submit"
      data-filters-apply
      class="inline-flex min-h-9 items-center px-2 t-caption text-fg underline-offset-4 transition-colors duration-150 hover:text-accent hover:underline"
    >
      {t("products.filters.apply")}
    </button>
  </div>
</form>

<script>
  /**
   * Auto-submit wiring for the filter form(s).
   *
   * Multiple instances may exist on the same page (the desktop inline bar
   * and the mobile sheet). Each gets its own debounce timer keyed off the
   * element itself.
   */
  const DEBOUNCE_MS = 600;

  function wire(form: HTMLFormElement) {
    let priceTimer: number | undefined;

    const submit = () => {
      if (typeof form.requestSubmit === "function") {
        form.requestSubmit();
      } else {
        form.submit();
      }
    };

    form.addEventListener("change", (e) => {
      const target = e.target as HTMLInputElement | HTMLSelectElement | null;
      if (!target) return;
      const tag = target.tagName;
      const type = (target as HTMLInputElement).type;
      if (tag === "SELECT" || type === "radio" || type === "checkbox") {
        submit();
      }
    });

    form.addEventListener("input", (e) => {
      const target = e.target as HTMLInputElement | null;
      if (!target) return;
      const type = target.type;
      if (type !== "number" && type !== "search" && type !== "text") return;
      if (priceTimer !== undefined) {
        window.clearTimeout(priceTimer);
      }
      priceTimer = window.setTimeout(submit, DEBOUNCE_MS);
    });

    form.addEventListener("keydown", (e) => {
      if ((e as KeyboardEvent).key !== "Enter") return;
      if (priceTimer !== undefined) {
        window.clearTimeout(priceTimer);
        priceTimer = undefined;
      }
    });

    const applyBtn = form.querySelector<HTMLButtonElement>("[data-filters-apply]");
    if (applyBtn) {
      applyBtn.hidden = true;
    }
  }

  document
    .querySelectorAll<HTMLFormElement>("form[data-filters-form]")
    .forEach(wire);
</script>
