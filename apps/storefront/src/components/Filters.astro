---
/**
 * Filters — horizontal bar above the grid.
 *
 * The previous left-rail with section legends and form layout was generic
 * ecommerce; the editorial direction calls for something flatter. The new
 * shape:
 *
 *   ┌ Search ──────────────────────────────────────────────────────┐
 *   │  cari produk…                                            →   │
 *   └──────────────────────────────────────────────────────────────┘
 *
 *   Semua · Kopi · Batik · Kerajinan · Kuliner · Fashion
 *
 *   Menampilkan 24 produk · Urutkan: [Terbaru ▾] · Filter ▾
 *      ↳ Filter expanded:  Min ___  —  Max ___  Terapkan
 *
 * Each interaction is a navigation (GET submit). With JS, the radios and
 * select auto-submit on change; the explicit "Terapkan" button is always
 * visible so it works during the SSR-to-hydration window and as the no-JS
 * fallback. Search and price inputs debounce 600ms.
 *
 * Counts beside category names rendered when the small-catalog SDK call
 * succeeds; absent otherwise (degrade silently to plain category names).
 */
import {
  createTranslator,
  resolveLocale,
  localePath,
  type Locale,
} from "@/lib/i18n";
import { listCategories, listProducts } from "@/lib/api";

export interface Props {
  active: {
    category?: string;
    search?: string;
    minPrice?: string;
    maxPrice?: string;
    sort?: string;
  };
  /**
   * When true, renders a compact form (no count badges, no totals) for
   * use inside the mobile sheet. Default false renders the desktop bar.
   */
  inline?: boolean;
}

const { active, inline = false } = Astro.props;
const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);
const categories = await listCategories(locale);
const formAction = localePath(locale, "/products");

let totalCount = 0;
const countsBySlug = new Map<string, number>();
try {
  const all = await listProducts(locale, { pageSize: 100 });
  totalCount = all.total;
  for (const p of all.items) {
    const slug = p.categorySlug;
    if (!slug) continue;
    countsBySlug.set(slug, (countsBySlug.get(slug) ?? 0) + 1);
  }
} catch {
  // Silent degrade — empty counts, no badges.
}

const sortOptions = [
  { value: "newest", label: t("products.sort.newest") },
  { value: "price_asc", label: t("products.sort.price_asc") },
  { value: "price_desc", label: t("products.sort.price_desc") },
] as const;

const activeSort =
  active.sort && ["newest", "price_asc", "price_desc"].includes(active.sort)
    ? active.sort
    : "newest";

const hasPriceFilter = Boolean(active.minPrice || active.maxPrice);

// Applied-filter chips read URL params on the client. Categories carry
// their {slug → localized name} map as JSON so the client script can
// render a real category label, not just the slug. Search chip's value
// is whatever the user typed; min/max chips are formatted as a price-
// range hint.
const categoryNamesPayload = JSON.stringify(
  Object.fromEntries(categories.map((c) => [c.slug, c.name[locale]])),
);
const chipPriceMin = t("products.filters.price_min");
const chipPriceMax = t("products.filters.price_max");
const chipSearchPrefix = t("products.filters.search");
---

<form method="get" action={formAction} data-filters-form class="t-body">
  {/* Search bar — single thin input, full width. */}
  <div class="border-line flex items-center border-b pb-3">
    <label for="filter-search" class="sr-only"
      >{t("products.filters.search")}</label
    >
    <input
      id="filter-search"
      type="search"
      name="q"
      value={active.search ?? ""}
      placeholder={t("products.filters.search_placeholder")}
      autocomplete="off"
      class="t-body text-fg placeholder:text-faint flex-1 bg-transparent outline-none"
    />
    {
      /*
      Search submit. `min-h-9 px-3` gives a ≥36 px tap target so Lighthouse's
      mobile target-size audit passes; the arrow stays visually quiet.
    */
    }
    <button
      type="submit"
      class="t-body text-fg hover:text-accent inline-flex min-h-9 items-center px-3 transition-colors duration-150"
      aria-label={t("products.filters.apply")}
    >
      &rarr;
    </button>
  </div>

  {
    /* Category — horizontal middot-separated text links (rendered as radios for no-JS). */
  }
  <fieldset class="mt-8">
    <legend class="sr-only">{t("products.filters.category")}</legend>
    <ul class="flex flex-wrap items-center gap-x-3 gap-y-2">
      <li class="flex items-center gap-x-3">
        <label
          class:list={[
            "t-body hover:text-accent cursor-pointer transition-colors duration-150",
            !active.category ? "text-accent" : "text-fg",
          ]}
        >
          <input
            type="radio"
            name="category"
            value=""
            checked={!active.category}
            class="sr-only"
          />
          <span>
            {t("products.filters.category_all")}
            {
              !inline && totalCount > 0 && (
                <span class="t-caption text-faint ml-1">({totalCount})</span>
              )
            }
          </span>
        </label>
      </li>
      {
        categories.map((c) => {
          const count = countsBySlug.get(c.slug);
          const isActive = active.category === c.slug;
          return (
            <li class="flex items-center gap-x-3">
              <span class="text-faint" aria-hidden="true">
                ·
              </span>
              <label
                class:list={[
                  "t-body hover:text-accent cursor-pointer transition-colors duration-150",
                  isActive ? "text-accent" : "text-fg",
                ]}
              >
                <input
                  type="radio"
                  name="category"
                  value={c.slug}
                  checked={isActive}
                  class="sr-only"
                />
                <span>
                  {c.name[locale]}
                  {!inline && typeof count === "number" && (
                    <span class="t-caption text-faint ml-1">({count})</span>
                  )}
                </span>
              </label>
            </li>
          );
        })
      }
    </ul>
  </fieldset>

  {/* Sort + price-range disclosure row. Inline, sits left-aligned. */}
  <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3">
    <label class="t-caption text-muted flex items-center gap-2">
      <span>{t("products.filters.sort")}:</span>
      <select
        name="sort"
        class="t-body text-fg hover:text-accent focus:text-fg cursor-pointer border-0 bg-transparent transition-colors duration-150 outline-none"
      >
        {
          sortOptions.map((opt) => (
            <option value={opt.value} selected={activeSort === opt.value}>
              {opt.label}
            </option>
          ))
        }
      </select>
    </label>

    <details class="group" data-filters-price-disclosure open={hasPriceFilter}>
      <summary
        class="t-caption text-muted hover:text-fg flex cursor-pointer list-none items-center gap-1.5 transition-colors duration-150 [&::-webkit-details-marker]:hidden"
      >
        <span>{t("products.filters.price")}</span>
        <span aria-hidden="true" class="t-body">+</span>
      </summary>
      <div class="mt-3 flex items-center gap-3">
        <label class="flex flex-1 flex-col">
          <span class="sr-only">{t("products.filters.price_min")}</span>
          <input
            type="number"
            name="min"
            inputmode="numeric"
            min="0"
            placeholder={t("products.filters.price_min")}
            value={active.minPrice ?? ""}
            class="price-figure border-line t-body text-fg placeholder:text-faint focus:border-fg w-28 border-b bg-transparent py-1 transition-colors duration-150 outline-none"
          />
        </label>
        <span class="text-faint" aria-hidden="true">—</span>
        <label class="flex flex-1 flex-col">
          <span class="sr-only">{t("products.filters.price_max")}</span>
          <input
            type="number"
            name="max"
            inputmode="numeric"
            min="0"
            placeholder={t("products.filters.price_max")}
            value={active.maxPrice ?? ""}
            class="price-figure border-line t-body text-fg placeholder:text-faint focus:border-fg w-28 border-b bg-transparent py-1 transition-colors duration-150 outline-none"
          />
        </label>
      </div>
    </details>

    {
      /*
      Always-visible Apply button. With JS, every change in the form
      auto-submits and pressing Apply just fires a redundant submit
      (idempotent under view transitions). Keeping it visible avoids a
      stranded state in the SSR-to-hydration window where a user could
      change a control before the auto-submit listener attaches.
      `min-h-9 px-2` keeps the tap target ≥36px so Lighthouse's mobile
      target-size audit passes, without growing the visual weight of
      the link-style label.
    */
    }
    <button
      type="submit"
      data-filters-apply
      class="t-caption text-fg hover:text-accent inline-flex min-h-9 items-center px-2 underline-offset-4 transition-colors duration-150 hover:underline"
    >
      {t("products.filters.apply")}
    </button>
  </div>
</form>

{
  /*
  Applied-filter chip row. Hidden until a client script reads the URL
  params and discovers at least one active filter. Categories carry
  their localized names as JSON so chips show "Kopi" instead of "kopi".
  Search/price chips are JS-built from raw URL values.

  Click the "Hapus filter" link to return to the canonical unfiltered
  listing — it points at the same path the form action uses, so the
  href works even if JS is off.
  */
}
<div
  data-applied-filters
  data-clear-href={formAction}
  data-category-names={categoryNamesPayload}
  data-chip-search={chipSearchPrefix}
  data-chip-min={chipPriceMin}
  data-chip-max={chipPriceMax}
  class="border-line mt-6 hidden flex-wrap items-center gap-x-3 gap-y-2 border-t pt-4"
  hidden
>
  <span class="t-caption text-muted">{t("products.list.applied_filters")}:</span
  >
  <ul data-applied-filters-list class="contents"></ul>
  <a
    href={formAction}
    class="t-caption text-fg hover:text-accent ml-auto inline-flex min-h-9 items-center underline-offset-[4px] transition-colors duration-150 hover:underline"
  >
    {t("products.list.clear_filters")} &rarr;
  </a>
</div>

<script>
  /**
   * Auto-submit wiring for the filter form(s).
   *
   * Multiple instances may exist on the same page (the desktop inline bar
   * and the mobile sheet). Each gets its own debounce timer keyed off the
   * element itself.
   */
  // 700ms felt right empirically: long enough that a typist entering
  // "250000" on the price field doesn't fire 6 mid-keystroke submits, short
  // enough that the perceived debounce after an Apply-style pause is
  // imperceptible. The earlier 300ms was eager — every paused keystroke
  // produced a network round-trip and a results re-render.
  const DEBOUNCE_MS = 700;

  function wire(form: HTMLFormElement) {
    let priceTimer: number | undefined;

    const submit = () => {
      if (typeof form.requestSubmit === "function") {
        form.requestSubmit();
      } else {
        form.submit();
      }
    };

    form.addEventListener("change", (e) => {
      const target = e.target as HTMLInputElement | HTMLSelectElement | null;
      if (!target) return;
      const tag = target.tagName;
      const type = (target as HTMLInputElement).type;
      if (tag === "SELECT" || type === "radio" || type === "checkbox") {
        submit();
      }
    });

    form.addEventListener("input", (e) => {
      const target = e.target as HTMLInputElement | null;
      if (!target) return;
      const type = target.type;
      if (type !== "number" && type !== "search" && type !== "text") return;
      if (priceTimer !== undefined) {
        window.clearTimeout(priceTimer);
      }
      priceTimer = window.setTimeout(submit, DEBOUNCE_MS);
    });

    form.addEventListener("keydown", (e) => {
      if ((e as KeyboardEvent).key !== "Enter") return;
      if (priceTimer !== undefined) {
        window.clearTimeout(priceTimer);
        priceTimer = undefined;
      }
    });
  }

  document
    .querySelectorAll<HTMLFormElement>("form[data-filters-form]")
    .forEach(wire);
</script>

<script>
  /**
   * Applied-filter chips. The static build can't observe URL params at
   * frontmatter time, so the chip row is server-rendered hidden and
   * filled in client-side from `window.location.search`. Each chip is
   * read-only (no per-chip remove yet) and the "Hapus filter" link in
   * the row clears every filter at once by navigating back to the
   * canonical listing path.
   */
  function renderAppliedFilters(container: HTMLElement) {
    const list = container.querySelector<HTMLElement>(
      "[data-applied-filters-list]",
    );
    if (!list) return;

    const params = new URLSearchParams(window.location.search);
    const category = params.get("category") ?? "";
    const search = params.get("q") ?? "";
    const min = params.get("min") ?? "";
    const max = params.get("max") ?? "";

    const categoryNames = (() => {
      try {
        return JSON.parse(
          container.getAttribute("data-category-names") ?? "{}",
        ) as Record<string, string>;
      } catch {
        return {} as Record<string, string>;
      }
    })();
    const chipSearch = container.getAttribute("data-chip-search") ?? "";
    const chipMin = container.getAttribute("data-chip-min") ?? "";
    const chipMax = container.getAttribute("data-chip-max") ?? "";

    const chips: string[] = [];
    if (category && categoryNames[category]) {
      chips.push(categoryNames[category]!);
    } else if (category) {
      chips.push(category);
    }
    if (search) chips.push(`${chipSearch}: ${search}`);
    if (min) chips.push(`${chipMin}: ${min}`);
    if (max) chips.push(`${chipMax}: ${max}`);

    if (chips.length === 0) {
      container.classList.add("hidden");
      container.setAttribute("hidden", "");
      list.replaceChildren();
      return;
    }

    container.classList.remove("hidden");
    container.classList.add("flex");
    container.removeAttribute("hidden");

    const fragment = document.createDocumentFragment();
    for (const text of chips) {
      const li = document.createElement("li");
      li.className =
        "border-line t-caption text-fg inline-flex items-center border px-3 py-1";
      li.textContent = text;
      fragment.appendChild(li);
    }
    list.replaceChildren(fragment);
  }

  function refreshAll() {
    document
      .querySelectorAll<HTMLElement>("[data-applied-filters]")
      .forEach(renderAppliedFilters);
  }

  refreshAll();
  window.addEventListener("popstate", refreshAll);
  // Astro's ClientRouter may swap the page in place; re-render chips
  // after the new DOM is committed so a back-nav from /products?cat=batik
  // still picks up the active state.
  document.addEventListener("astro:page-load", refreshAll);
</script>
