---
/**
 * Filters — left rail on desktop, native `<dialog>` on mobile.
 *
 * The form posts back to the listing page with a plain GET so the
 * filtered URL is shareable and the back button works. There is no
 * client-side state — every interaction is a navigation.
 *
 * Markup is identical between desktop and mobile; only the wrapper
 * differs. CSS handles the breakpoint switch:
 *
 *   - Desktop (md+): rendered inline in the page's left rail.
 *   - Mobile: a `<dialog>` opened by a "Filter" button. The dialog
 *     uses the `open` attribute via `dialog.showModal()` triggered
 *     by inline JS that the listing page injects; we keep the
 *     button/dialog pair entirely native to avoid a React island
 *     just for a panel toggle.
 *
 * The radio inputs for sort/category use `name="sort"`/`name="category"`
 * with each option's value, so on submit the URL carries the chosen
 * value verbatim. An "All" option for category clears the filter
 * (empty value).
 *
 * Auto-submit behavior (progressive enhancement):
 *
 *   With JS enabled, changing a radio submits the form immediately;
 *   typing in price min/max debounces 600ms then submits. The
 *   "Terapkan" button stays in the DOM as the no-JS fallback and
 *   is hidden by the inline script once listeners are attached.
 *   Pressing Enter in any input triggers the form's native submit
 *   path, not a parallel one.
 */
import { createTranslator, resolveLocale, localePath, type Locale } from "@/lib/i18n";
import { listCategories, listProducts } from "@/lib/api";

export interface Props {
  active: {
    category?: string;
    search?: string;
    minPrice?: string;
    maxPrice?: string;
    sort?: string;
  };
  /**
   * When true, render only the inline form fields (used inside the mobile
   * `<dialog>`). When false (default), render the desktop sidebar wrapper
   * with the form inside.
   */
  inline?: boolean;
}

const { active, inline = false } = Astro.props;
const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);
const categories = await listCategories();
const formAction = localePath(locale, "/products");

/**
 * Pre-compute per-category counts in one SDK call. The catalog at v0.1 is
 * small (<100 products), and the listing page already issues a parallel
 * call to render the grid, so the cost here is negligible compared to N+1
 * per-category queries.
 *
 * If the call fails the rail still renders — `counts` stays empty and the
 * parenthetical numbers are simply omitted.
 */
let totalCount = 0;
const countsBySlug = new Map<string, number>();
try {
  const all = await listProducts({ pageSize: 100 });
  totalCount = all.total;
  for (const p of all.items) {
    const slug = p.categorySlug;
    if (!slug) continue;
    countsBySlug.set(slug, (countsBySlug.get(slug) ?? 0) + 1);
  }
} catch {
  // Stay silent — empty counts map is the graceful degrade path.
}

const sortOptions = [
  { value: "newest", label: t("products.sort.newest") },
  { value: "price_asc", label: t("products.sort.price_asc") },
  { value: "price_desc", label: t("products.sort.price_desc") },
] as const;

const activeSort = active.sort && ["newest", "price_asc", "price_desc"].includes(active.sort)
  ? active.sort
  : "newest";
---

<form
  method="get"
  action={formAction}
  data-filters-form
  class:list={[
    "flex flex-col gap-8 t-body",
    inline ? "" : "md:sticky md:top-20 md:self-start",
  ]}
>
  {/* Search */}
  <div>
    <label class="t-caption block tracking-wide text-muted" for="filter-search">
      {t("products.filters.search")}
    </label>
    <input
      id="filter-search"
      type="search"
      name="q"
      value={active.search ?? ""}
      placeholder={t("products.filters.search_placeholder")}
      aria-label={t("products.filters.search")}
      class="mt-2 w-full border-b border-line bg-transparent py-1.5 text-fg outline-none transition-colors duration-150 focus:border-accent"
    />
  </div>

  {/* Category — radio list */}
  <fieldset>
    <legend class="t-caption tracking-wide text-muted">
      {t("products.filters.category")}
    </legend>
    <ul class="mt-3 space-y-2">
      <li>
        <label class="flex cursor-pointer items-center gap-2.5 text-fg">
          <input
            type="radio"
            name="category"
            value=""
            checked={!active.category}
            class="h-3.5 w-3.5 accent-accent"
          />
          <span>
            {t("products.filters.category_all")}
            {totalCount > 0 && <span class="text-faint"> ({totalCount})</span>}
          </span>
        </label>
      </li>
      {
        categories.map((c) => {
          const count = countsBySlug.get(c.slug);
          return (
            <li>
              <label class="flex cursor-pointer items-center gap-2.5 text-fg">
                <input
                  type="radio"
                  name="category"
                  value={c.slug}
                  checked={active.category === c.slug}
                  class="h-3.5 w-3.5 accent-accent"
                />
                <span>
                  {c.name[locale]}
                  {typeof count === "number" && <span class="text-faint"> ({count})</span>}
                </span>
              </label>
            </li>
          );
        })
      }
    </ul>
  </fieldset>

  {/* Price range */}
  <fieldset>
    <legend class="t-caption tracking-wide text-muted">
      {t("products.filters.price")}
    </legend>
    <div class="mt-3 flex items-center gap-3">
      <label class="flex flex-1 flex-col">
        <span class="sr-only">{t("products.filters.price_min")}</span>
        <input
          type="number"
          name="min"
          inputmode="numeric"
          min="0"
          placeholder={t("products.filters.price_min")}
          value={active.minPrice ?? ""}
          class="price-figure border-b border-line bg-transparent py-1.5 text-fg outline-none transition-colors duration-150 focus:border-accent"
        />
      </label>
      <span class="text-faint" aria-hidden="true">—</span>
      <label class="flex flex-1 flex-col">
        <span class="sr-only">{t("products.filters.price_max")}</span>
        <input
          type="number"
          name="max"
          inputmode="numeric"
          min="0"
          placeholder={t("products.filters.price_max")}
          value={active.maxPrice ?? ""}
          class="price-figure border-b border-line bg-transparent py-1.5 text-fg outline-none transition-colors duration-150 focus:border-accent"
        />
      </label>
    </div>
  </fieldset>

  {/* Sort — radio list */}
  <fieldset>
    <legend class="t-caption tracking-wide text-muted">
      {t("products.filters.sort")}
    </legend>
    <ul class="mt-3 space-y-2">
      {
        sortOptions.map((opt) => (
          <li>
            <label class="flex cursor-pointer items-center gap-2.5 text-fg">
              <input
                type="radio"
                name="sort"
                value={opt.value}
                checked={activeSort === opt.value}
                class="h-3.5 w-3.5 accent-accent"
              />
              <span>{opt.label}</span>
            </label>
          </li>
        ))
      }
    </ul>
  </fieldset>

  {/*
    No-JS fallback. The script below hides this once auto-submit listeners
    are attached, so JS users only see the rail respond to interaction.
  */}
  <button type="submit" data-filters-apply class="btn-primary w-full">
    {t("products.filters.apply")}
  </button>
</form>

<script>
  /**
   * Auto-submit wiring for filter forms.
   *
   * Multiple instances may exist on the same page (the desktop sidebar
   * and the mobile dialog), so we attach to every `[data-filters-form]`.
   * Each form gets its own debounce timer keyed off the element itself.
   */
  const DEBOUNCE_MS = 600;

  function wire(form: HTMLFormElement) {
    let priceTimer: number | undefined;

    const submit = () => {
      // Use requestSubmit when available so the form's submit event fires
      // (matches a real button click); fall back to submit() for older
      // browsers that lack it.
      if (typeof form.requestSubmit === "function") {
        form.requestSubmit();
      } else {
        form.submit();
      }
    };

    form.addEventListener("change", (e) => {
      const target = e.target as HTMLInputElement | HTMLSelectElement | null;
      if (!target) return;
      const tag = target.tagName;
      const type = (target as HTMLInputElement).type;
      // Radio + select changes submit immediately. Text/number/search
      // inputs are handled by the debounced `input` listener below.
      if (tag === "SELECT" || type === "radio" || type === "checkbox") {
        submit();
      }
    });

    form.addEventListener("input", (e) => {
      const target = e.target as HTMLInputElement | null;
      if (!target) return;
      const type = target.type;
      if (type !== "number" && type !== "search" && type !== "text") return;
      if (priceTimer !== undefined) {
        window.clearTimeout(priceTimer);
      }
      priceTimer = window.setTimeout(submit, DEBOUNCE_MS);
    });

    // Enter inside an input fires the form's native submit; cancel any
    // pending debounce so we don't fire a second submit afterward.
    form.addEventListener("keydown", (e) => {
      if ((e as KeyboardEvent).key !== "Enter") return;
      if (priceTimer !== undefined) {
        window.clearTimeout(priceTimer);
        priceTimer = undefined;
      }
      // Let the browser handle the submit naturally.
    });

    // Hide the explicit Apply button — its only role is no-JS fallback.
    const applyBtn = form.querySelector<HTMLButtonElement>("[data-filters-apply]");
    if (applyBtn) {
      applyBtn.hidden = true;
    }
  }

  document
    .querySelectorAll<HTMLFormElement>("form[data-filters-form]")
    .forEach(wire);
</script>
