---
/**
 * Renders a Money value as a localized currency string.
 *
 * Uses `format` from `@mt-commerce/core/money` so the formatting rules live
 * with the type, not in the storefront. The `.price-figure` class enforces
 * tabular numerals so column-aligned prices in product grids do not wobble
 * between rows.
 *
 * Three colour modes:
 *   - default → full-strength fg (used on the detail page hero block)
 *   - muted   → `text-muted` (used on cards — Saturdays NYC mutes prices
 *               below the title so the photo and title do the heavy lifting)
 *   - strike  → faint with line-through (compare-at)
 */
import { format as formatMoney, type Money } from "@mt-commerce/core/money";

export interface Props {
  money: Money;
  /** BCP 47 locale; defaults to id-ID. */
  locale?: string;
  /** When true, renders with line-through styling (used for compare-at). */
  strike?: boolean;
  /** When true, renders in `text-muted` (used on cards). */
  muted?: boolean;
  class?: string;
}

const {
  money,
  locale = "id-ID",
  strike = false,
  muted = false,
  class: className,
} = Astro.props;
const formatted = formatMoney(money, { locale });

let toneClass: string;
if (strike) {
  toneClass = "text-faint line-through";
} else if (muted) {
  toneClass = "text-muted";
} else {
  toneClass = "text-fg";
}

const classes = ["price-figure", toneClass, className ?? ""]
  .filter(Boolean)
  .join(" ");
---

<span class={classes} data-currency={money.currency}>{formatted}</span>
