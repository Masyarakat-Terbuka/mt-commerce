---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { resolveLocale, type Locale } from "@/lib/i18n";

export interface Props {
  title: string;
  description?: string;
  /** Optional OG image URL. */
  ogImage?: string;
  /** Canonical URL override; defaults to the current request URL. */
  canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;
const locale: Locale = resolveLocale(Astro.currentLocale);
const siteUrl = Astro.site?.toString() ?? Astro.url.origin;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    {/*
      Geist Variable served from Google Fonts. Hosted, not bundled — keeps
      the storefront free of a new top-level dep while still delivering a
      distinctive type face. `display=swap` avoids flashing invisible text
      on slow connections, which matches the platform's "fast on modest
      hardware" principle.
    */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&display=swap"
    />
  </head>
  <body class="min-h-screen bg-cream text-fg">
    <Header />
    {/*
      No inner wrapper here — pages decide their own layout (full-bleed
      hero on home, sidebar layout on listing, centered column on detail).
      A blanket `mx-auto max-w-6xl` would force every page to fight it.
    */}
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
