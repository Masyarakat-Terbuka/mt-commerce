---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { resolveLocale, type Locale } from "@/lib/i18n";

export interface Props {
  title: string;
  description?: string;
  /** Optional OG image URL. */
  ogImage?: string;
  /** Canonical URL override; defaults to the current request URL. */
  canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;
const locale: Locale = resolveLocale(Astro.currentLocale);
const siteUrl = Astro.site?.toString() ?? Astro.url.origin;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="min-h-screen bg-white text-neutral-900">
    <Header />
    <main class="mx-auto max-w-6xl px-4 py-6">
      <slot />
    </main>
    <Footer />
  </body>
</html>
