---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import CartDrawer from "@/islands/CartDrawer.tsx";
import PromoBanner from "@/islands/PromoBanner.tsx";
import {
  createTranslator,
  resolveLocale,
  localePath,
  type Locale,
} from "@/lib/i18n";
import { buildHreflangPair, jsonLdString, ogLocale } from "@/lib/seo";

export interface Props {
  title: string;
  description?: string;
  /** Optional OG image URL. */
  ogImage?: string;
  /** Canonical URL override; defaults to the current request URL. */
  canonical?: string;
  /**
   * Emit `<meta name="robots" content="noindex,follow">`. Used by pages
   * that should not pollute the search index — search results in
   * particular, where every `?q=...` would otherwise become a low-quality
   * indexable page. Crawlers still follow outbound links so the rest of
   * the catalog remains discoverable.
   */
  noindex?: boolean;
  /**
   * Open Graph object type. Defaults to "website" — the right value for
   * the home, listing, content, and search pages. Product detail pages
   * pass "product" so social previews and rich-result tooling can pick
   * up that the page is a buyable item rather than a landing page. See
   * https://ogp.me/#types for the list of well-known types.
   */
  ogType?: string;
  /**
   * Optional JSON-LD structured data payload(s). A single object or an
   * array of objects — the layout serialises and emits them inside a
   * `<script type="application/ld+json">` element. Pages keep this
   * concern centralised here so we don't repeat the safe-stringify
   * dance (`</` escaping) on every call site.
   */
  jsonLd?: object | object[];
}

const {
  title,
  description,
  ogImage,
  canonical,
  noindex,
  ogType = "website",
  jsonLd,
} = Astro.props;

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);
const intlLocale = locale === "id" ? "id-ID" : "en-US";
const siteUrl = Astro.site?.toString() ?? Astro.url.origin;
const canonicalUrl =
  canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
// Brand mark — same asset used in the header. Falls back as the social
// preview image when callers don't pass one explicitly.
const resolvedOgImage = ogImage ?? "/logo.png";
// Resolve the OG image to an absolute URL when it's a path. Open Graph
// scrapers reject relative URLs in `og:image`, and `twitter:image`
// inherits the same constraint, so resolving once here keeps both meta
// tags consistent regardless of what the caller passes.
const absoluteOgImage = resolvedOgImage.startsWith("http")
  ? resolvedOgImage
  : new URL(resolvedOgImage, siteUrl).toString();

// Build the id/en URL pair for hreflang and og:locale:alternate. We
// derive both from the canonical pathname so a page that overrides
// `canonical` still emits coherent alternates.
const canonicalPath = new URL(canonicalUrl).pathname;
const hreflang = buildHreflangPair(canonicalPath, siteUrl);
const alternateOgLocale = locale === "id" ? "en_US" : "id_ID";

// Normalise JSON-LD into an array of payloads. A single object is the
// common case; arrays are used on pages that emit more than one shape
// (for example PDP: Product + BreadcrumbList).
const jsonLdPayloads = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/logo.png" />

    {
      /*
      hreflang advertises the id/en pair to search engines. We always emit
      both locale URLs and an `x-default` pointing at the default locale,
      per Google's guidance for sites that don't auto-detect language.
      `@astrojs/sitemap` produces the same alternates inside the sitemap;
      duplicating here makes the relationship visible to crawlers that
      don't fetch the sitemap on every page.
    */
    }
    <link rel="alternate" hreflang="id" href={hreflang.id} />
    <link rel="alternate" hreflang="en" href={hreflang.en} />
    <link rel="alternate" hreflang="x-default" href={hreflang.xDefault} />

    {/* Open Graph — site-level facets first, then page-specific. */}
    <meta property="og:site_name" content="mt-commerce" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:locale" content={ogLocale(locale)} />
    <meta property="og:locale:alternate" content={alternateOgLocale} />

    {
      /*
      Twitter card. `summary_large_image` is the right card for both
      content and product pages — Twitter falls back gracefully on the
      OG fields, but emitting `twitter:title` / `twitter:description` /
      `twitter:image` explicitly avoids the ambiguity some scrapers
      have when only OG is present.
    */
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={absoluteOgImage} />

    {
      /*
      Geist Variable served from Google Fonts. Hosted, not bundled — keeps
      the storefront free of a new top-level dep while still delivering a
      distinctive type face. `display=swap` avoids flashing invisible text
      on slow connections, which matches the platform's "fast on modest
      hardware" principle.
    */
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&display=swap"
    />

    {
      /*
      JSON-LD structured data. Each payload is serialised through
      `jsonLdString`, which escapes `</` so a stray `</script>` substring
      inside any product copy or URL cannot break out of the script
      element. `is:inline` skips Astro's bundler — JSON-LD is data, not
      a JS module, and must land in the HTML head as-is.
    */
    }
    {
      jsonLdPayloads.map((payload) => (
        <script
          type="application/ld+json"
          is:inline
          set:html={jsonLdString(payload)}
        />
      ))
    }

    {
      /*
      Astro's built-in client-side router. Intercepts internal `<a>` clicks
      and swaps content without a full page reload — no white flash, no
      re-download of CSS or fonts, scroll position preserved on back/forward.
      Costs ~10 KB of JS in the initial bundle; cuts the perceived
      navigation latency dramatically.

      Combined with `prefetch` in astro.config.mjs (hover-prefetch every
      internal link), the typical second-page navigation feels instant.
      Islands re-mount on swap; cart state survives because it lives in
      a module-level store + localStorage, not React component state.
    */
    }
    <ClientRouter />
  </head>
  <body class="bg-cream text-fg min-h-screen">
    {
      /*
      Skip link — lets keyboard users bypass the header on every page.
      The link is visually hidden until focused, at which point it sits
      flush in the top-left corner. Per WIG: "include skip link for main
      content". `scroll-margin-top` on `<main>` keeps focus from landing
      under the sticky header when the link is activated.
    */
    }
    <a
      href="#main"
      class="focus-visible:bg-paper focus-visible:t-body focus-visible:text-fg sr-only focus-visible:not-sr-only focus-visible:absolute focus-visible:top-4 focus-visible:left-4 focus-visible:z-50 focus-visible:px-4 focus-visible:py-2"
    >
      {t("nav.skip_to_content")}
    </a>
    {
      /*
      Promo banner — thin band ABOVE the sticky header. Mounted as a React
      island so the localStorage-backed dismiss can run before paint without
      a flash. `client:load` is intentional: `client:idle` would defer past
      LCP and the banner would visibly shift in afterwards. The banner sits
      in normal flow (no sticky), so when dismissed, the header reflows to
      the very top of the viewport and the rest of the page rises with it.
      Strings are passed in as props so the island stays locale-agnostic.
    */
    }
    <PromoBanner
      client:load
      text={t("promo_banner.text")}
      dismissLabel={t("promo_banner.dismiss")}
      regionLabel={t("promo_banner.region_label")}
    />
    <Header />
    {
      /*
      No inner wrapper here — pages decide their own layout (full-bleed
      hero on home, sidebar layout on listing, centered column on detail).
      A blanket `mx-auto max-w-6xl` would force every page to fight it.
    */
    }
    <main id="main" style="scroll-margin-top: 4.5rem;">
      <slot />
    </main>
    <Footer />
    {
      /*
      Global cart drawer — mounted once at the layout level so the
      `mt:cart-open` event from any AddToCartButton on the page can
      slide it in. Carries every i18n string the panel needs so the
      island stays locale-agnostic.
    */
    }
    <CartDrawer
      client:load
      locale={intlLocale}
      cartHref={localePath(locale, "/cart")}
      checkoutHref={localePath(locale, "/checkout")}
      productsHref={localePath(locale, "/products")}
      titleLabel={t("cart.title")}
      closeLabel={t("cart.close")}
      emptyLabel={t("cart.empty")}
      emptyCtaLabel={t("cart.empty_cta")}
      subtotalIncludingTaxLabel={t("cart.subtotal_including_tax")}
      taxIncludedNote={t("cart.tax_included_note")}
      shippingLabel={t("cart.shipping")}
      totalLabel={t("cart.total")}
      checkoutCtaLabel={t("cart.checkout_cta")}
      removeLabel={t("cart.remove_item")}
      quantityLabel={t("cart.quantity")}
      productFallbackLabel={t("cart.product_fallback")}
    />
  </body>
</html>
