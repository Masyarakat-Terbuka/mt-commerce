---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductGrid from "@/islands/ProductGrid.tsx";
import { resolveApiUrl } from "@/lib/api";
import { createTranslator, resolveLocale, localePath, type Locale } from "@/lib/i18n";

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);

const title = `${t("home.hero.title")} — mt-commerce`;
const description = t("home.hero.subtitle");

const apiUrl = resolveApiUrl();
const detailHrefBase = localePath(locale, "/products");
const intlLocale = locale === "id" ? "id-ID" : "en-US";
---

<BaseLayout title={title} description={description}>
  <section class="py-8 md:py-12">
    <h1 class="max-w-2xl text-2xl font-semibold text-neutral-900 md:text-4xl">
      {t("home.hero.title")}
    </h1>
    <p class="mt-3 max-w-2xl text-base text-neutral-600 md:text-lg">
      {t("home.hero.subtitle")}
    </p>
  </section>

  <section class="py-4">
    <h2 class="mb-4 text-lg font-semibold text-neutral-900">{t("home.featured")}</h2>
    <ProductGrid
      client:load
      apiUrl={apiUrl}
      locale={intlLocale}
      detailHrefBase={detailHrefBase}
      emptyLabel={t("products.list.empty")}
      loadingLabel={t("products.list.loading")}
      errorLabel={t("products.list.error")}
      query={{ pageSize: 4, sort: "newest" }}
      limit={4}
    />
  </section>
</BaseLayout>
