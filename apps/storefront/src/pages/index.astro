---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductGrid from "@/islands/ProductGrid.tsx";
import {
  listCategories,
  listProducts,
  resolveApiUrl,
  toProductCardListing,
  type StoreProductCardListing,
} from "@/lib/api";
import {
  createTranslator,
  resolveLocale,
  localePath,
  type Locale,
} from "@/lib/i18n";

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);

const title = `${t("home.hero.headline")} — mt-commerce`;
const description = t("home.hero.subhead");

const apiUrl = resolveApiUrl();
const detailHrefBase = localePath(locale, "/products");
const productsHref = localePath(locale, "/products");
const intlLocale = locale === "id" ? "id-ID" : "en-US";

// Site-wide structured data emitted on the home page only.
//   - `Organization` advertises the brand name, URL, and logo so search
//     engines can populate the knowledge panel and rich previews.
//   - `WebSite` with a `SearchAction` exposes the on-site search box;
//     Google's "sitelinks search box" feature reads this. The query
//     placeholder uses the standard `{search_term_string}` template.
//     The search route lives at `/search` (id) and `/en/search` (en);
//     pointing at the locale-prefixed path keeps query traffic in the
//     visitor's locale.
const siteUrl = Astro.site?.toString() ?? Astro.url.origin;
const homeUrl = new URL(localePath(locale, "/"), siteUrl).toString();
const searchUrl = new URL(
  localePath(locale, "/search?q={search_term_string}"),
  siteUrl,
).toString();
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "mt-commerce",
    url: siteUrl,
    logo: new URL("/logo.png", siteUrl).toString(),
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "mt-commerce",
    url: homeUrl,
    inLanguage: locale === "id" ? "id-ID" : "en-US",
    potentialAction: {
      "@type": "SearchAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: searchUrl,
      },
      "query-input": "required name=search_term_string",
    },
  },
];

// Hero image — chosen for the editorial moment. The gerabah (earthenware)
// photograph reads as warm, low-saturation, and culturally specific without
// being decorative. The cream wash (`bg-cream/35`) keeps any text on top
// legible while letting the photo carry the visual weight.
//
// Three Unsplash widths so a 360 px mobile doesn't pay for a 2400 px image
// (Lighthouse mobile flagged ~1.1 MB of unused pixels). The browser picks
// from `srcset` based on device width; `sizes="100vw"` because the photo
// fills the viewport. The `src` (full width) stays as the fallback for
// crawlers and clients that ignore srcset.
const heroBase = "https://images.unsplash.com/photo-1493106641515-6b5631de4bb9";
const heroSrcset = [
  `${heroBase}?w=800&q=70&auto=format&fit=crop 800w`,
  `${heroBase}?w=1200&q=72&auto=format&fit=crop 1200w`,
  `${heroBase}?w=1600&q=75&auto=format&fit=crop 1600w`,
  `${heroBase}?w=2400&q=80&auto=format&fit=crop 2400w`,
].join(", ");
const heroSrc1200 = `${heroBase}?w=1200&q=72&auto=format&fit=crop`;
const heroImageAlt =
  locale === "id"
    ? "Foto gerabah tanah liat — pengrajin Kasongan, Yogyakarta"
    : "Photograph of earthenware pottery — Kasongan artisans, Yogyakarta";

// Multi-strip home.
//
// Five build-time fetches plus the category list run in parallel via a
// single `Promise.all`. The two "sort" strips are 6 cards wide so the 3-up
// desktop grid renders two clean rows; the three category strips are 4
// cards (a single 4-up row at desktop, 2x2 on mobile via the island's grid).
//
// Resilience: every `listProducts` call returns an empty result on failure
// (see `lib/api.ts`). A strip with zero items renders nothing — we skip
// the heading entirely rather than show "no products yet" boilerplate.
//
// Hardcoded category slugs (`kopi`, `batik`, `kerajinan`) match the seeded
// demo catalog and the bilingual i18n keys. Empty-strip skipping is the
// fallback if any of those slugs is absent at build/request time.
const HOME_CATEGORY_SLUGS = ["kopi", "batik", "kerajinan"] as const;

const [categories, newest, bestPrice, kopi, batik, kerajinan] =
  await Promise.all([
    listCategories(locale),
    listProducts(locale, { pageSize: 6, sort: "newest" }),
    listProducts(locale, { pageSize: 6, sort: "price_asc" }),
    listProducts(locale, {
      pageSize: 4,
      sort: "newest",
      category: HOME_CATEGORY_SLUGS[0],
    }),
    listProducts(locale, {
      pageSize: 4,
      sort: "newest",
      category: HOME_CATEGORY_SLUGS[1],
    }),
    listProducts(locale, {
      pageSize: 4,
      sort: "newest",
      category: HOME_CATEGORY_SLUGS[2],
    }),
  ]);

// Project each result into the slim shape the island consumes. `undefined`
// when the result is empty so the island falls through to its client fetch
// (offline-build path) instead of locking onto an empty seed.
function seedFor(result: typeof newest): StoreProductCardListing | undefined {
  if (result.items.length === 0) return undefined;
  return toProductCardListing(result, locale);
}

const newestSeed = seedFor(newest);
const bestPriceSeed = seedFor(bestPrice);
const kopiSeed = seedFor(kopi);
const batikSeed = seedFor(batik);
const kerajinanSeed = seedFor(kerajinan);

// Strip skip rule: render only when the build-time fetch returned at least
// one product. The two sort strips can never be "empty" in a healthy build
// (they hit the global catalog) but we still gate them so a fully-empty
// catalog or an offline build degrades to "hero + categories" gracefully.
const showNewest = newest.items.length > 0;
const showBestPrice = bestPrice.items.length > 0;
const showKopi = kopi.items.length > 0;
const showBatik = batik.items.length > 0;
const showKerajinan = kerajinan.items.length > 0;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  {
    /*
    Hero — editorial image moment.

    A full-bleed photograph (70vh desktop / 50vh mobile) with a thin warm
    overlay so the headline reads cleanly. Title sits in the bottom-left
    third — Saturdays NYC's wide-image landing rhythm — with a single
    quiet "Lihat koleksi →" text link below. No buttons, no CTAs, no
    layered cards. The photo IS the hero.
  */
  }
  <section class="relative" aria-labelledby="home-hero">
    <div
      class="relative h-[50vh] min-h-[420px] w-full overflow-hidden md:h-[70vh] md:min-h-[560px]"
    >
      <img
        src={heroSrc1200}
        srcset={heroSrcset}
        sizes="100vw"
        alt={heroImageAlt}
        loading="eager"
        decoding="async"
        fetchpriority="high"
        class="absolute inset-0 h-full w-full object-cover"
      />
      {
        /*
        Warm cream wash. Subtle (35%) — enough to lift fg legibility without
        muddying the photo. Sits as a separate layer so the image stays a
        clean asset for OG/social if we ever lift it.
      */
      }
      <div class="bg-cream/35 absolute inset-0" aria-hidden="true"></div>

      {/* Title overlay — bottom-third, left-aligned, generous gutter. */}
      <div class="absolute inset-0 flex items-end">
        <div class="mx-auto w-full max-w-[1280px] px-5 pb-12 md:px-8 md:pb-20">
          <h1 id="home-hero" class="t-display text-fg max-w-[20ch]">
            {t("home.hero.headline")}
          </h1>
          <p class="t-body text-fg/85 mt-4 max-w-[44ch]">
            {t("home.hero.subhead")}
          </p>
          <a
            href={localePath(locale, "/products")}
            class="t-body text-fg hover:text-accent mt-8 inline-flex items-center gap-2 underline-offset-[6px] transition-colors duration-200 hover:underline"
          >
            {t("home.hero.cta")}
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  {
    /*
    Multi-strip browse area.

    Each strip is a section with:
      - a left-aligned overline title (h2),
      - a quiet "see all →" text link on the right pointing at the
        listing page with the matching `?sort=` or `?category=` filter,
      - the existing `ProductGrid` island, seeded with `initialData` so
        first paint shows photographs, not skeletons.

    Spacing rhythm matches the rest of the storefront: pt-24/pb-24 mobile,
    pt-32/pb-32 desktop. A hairline `border-line border-t` divider opens
    each strip — it gives the eye an orientation cue between sections,
    Muji-style, without adding any visual weight.

    Strips skip themselves entirely when their fetch returned zero items.
  */
  }
  {
    showNewest && (
      <section class="border-line mx-auto max-w-[1280px] border-t px-5 pt-24 pb-24 md:px-8 md:pt-32 md:pb-32">
        <div class="flex items-baseline justify-between gap-4">
          <h2 class="t-overline text-muted">{t("home.strips.newest")}</h2>
          <a
            href={`${productsHref}?sort=newest`}
            class="t-body text-muted hover:text-accent transition-colors duration-150"
          >
            {t("home.strips.newest_link")}
          </a>
        </div>
        <div class="mt-10 md:mt-14">
          <ProductGrid
            client:load
            apiUrl={apiUrl}
            locale={intlLocale}
            apiLocale={locale}
            detailHrefBase={detailHrefBase}
            emptyLabel={t("products.list.empty")}
            errorLabel={t("products.list.error")}
            skeletonLabel={t("products.list.skeleton_aria")}
            photoComingSoonLabel={t("products.card.photo_coming_soon")}
            query={{ pageSize: 6, sort: "newest" }}
            limit={6}
            skeletonCount={6}
            initialData={newestSeed}
          />
        </div>
      </section>
    )
  }

  {
    showBestPrice && (
      <section class="border-line mx-auto max-w-[1280px] border-t px-5 pt-24 pb-24 md:px-8 md:pt-32 md:pb-32">
        <div class="flex items-baseline justify-between gap-4">
          <h2 class="t-overline text-muted">{t("home.strips.best_price")}</h2>
          <a
            href={`${productsHref}?sort=price_asc`}
            class="t-body text-muted hover:text-accent transition-colors duration-150"
          >
            {t("home.strips.best_price_link")}
          </a>
        </div>
        <div class="mt-10 md:mt-14">
          <ProductGrid
            client:load
            apiUrl={apiUrl}
            locale={intlLocale}
            apiLocale={locale}
            detailHrefBase={detailHrefBase}
            emptyLabel={t("products.list.empty")}
            errorLabel={t("products.list.error")}
            skeletonLabel={t("products.list.skeleton_aria")}
            photoComingSoonLabel={t("products.card.photo_coming_soon")}
            query={{ pageSize: 6, sort: "price_asc" }}
            limit={6}
            skeletonCount={6}
            initialData={bestPriceSeed}
          />
        </div>
      </section>
    )
  }

  {
    showKopi && (
      <section class="border-line mx-auto max-w-[1280px] border-t px-5 pt-24 pb-24 md:px-8 md:pt-32 md:pb-32">
        <div class="flex items-baseline justify-between gap-4">
          <h2 class="t-overline text-muted">
            {t("home.strips.by_category.kopi")}
          </h2>
          <a
            href={`${productsHref}?category=kopi`}
            class="t-body text-muted hover:text-accent transition-colors duration-150"
          >
            {t("home.strips.by_category.see_all")}
          </a>
        </div>
        <div class="mt-10 md:mt-14">
          <ProductGrid
            client:load
            apiUrl={apiUrl}
            locale={intlLocale}
            apiLocale={locale}
            detailHrefBase={detailHrefBase}
            emptyLabel={t("products.list.empty")}
            errorLabel={t("products.list.error")}
            skeletonLabel={t("products.list.skeleton_aria")}
            photoComingSoonLabel={t("products.card.photo_coming_soon")}
            query={{ pageSize: 4, sort: "newest", categorySlug: "kopi" }}
            limit={4}
            skeletonCount={4}
            initialData={kopiSeed}
          />
        </div>
      </section>
    )
  }

  {
    showBatik && (
      <section class="border-line mx-auto max-w-[1280px] border-t px-5 pt-24 pb-24 md:px-8 md:pt-32 md:pb-32">
        <div class="flex items-baseline justify-between gap-4">
          <h2 class="t-overline text-muted">
            {t("home.strips.by_category.batik")}
          </h2>
          <a
            href={`${productsHref}?category=batik`}
            class="t-body text-muted hover:text-accent transition-colors duration-150"
          >
            {t("home.strips.by_category.see_all")}
          </a>
        </div>
        <div class="mt-10 md:mt-14">
          <ProductGrid
            client:load
            apiUrl={apiUrl}
            locale={intlLocale}
            apiLocale={locale}
            detailHrefBase={detailHrefBase}
            emptyLabel={t("products.list.empty")}
            errorLabel={t("products.list.error")}
            skeletonLabel={t("products.list.skeleton_aria")}
            photoComingSoonLabel={t("products.card.photo_coming_soon")}
            query={{ pageSize: 4, sort: "newest", categorySlug: "batik" }}
            limit={4}
            skeletonCount={4}
            initialData={batikSeed}
          />
        </div>
      </section>
    )
  }

  {
    showKerajinan && (
      <section class="border-line mx-auto max-w-[1280px] border-t px-5 pt-24 pb-24 md:px-8 md:pt-32 md:pb-32">
        <div class="flex items-baseline justify-between gap-4">
          <h2 class="t-overline text-muted">
            {t("home.strips.by_category.kerajinan")}
          </h2>
          <a
            href={`${productsHref}?category=kerajinan`}
            class="t-body text-muted hover:text-accent transition-colors duration-150"
          >
            {t("home.strips.by_category.see_all")}
          </a>
        </div>
        <div class="mt-10 md:mt-14">
          <ProductGrid
            client:load
            apiUrl={apiUrl}
            locale={intlLocale}
            apiLocale={locale}
            detailHrefBase={detailHrefBase}
            emptyLabel={t("products.list.empty")}
            errorLabel={t("products.list.error")}
            skeletonLabel={t("products.list.skeleton_aria")}
            photoComingSoonLabel={t("products.card.photo_coming_soon")}
            query={{ pageSize: 4, sort: "newest", categorySlug: "kerajinan" }}
            limit={4}
            skeletonCount={4}
            initialData={kerajinanSeed}
          />
        </div>
      </section>
    )
  }

  {/* Category strip — calm, middot-separated. Single horizontal line. */}
  {
    categories.length > 0 && (
      <section class="border-line border-t">
        <div class="mx-auto max-w-[1280px] px-5 py-12 md:px-8 md:py-16">
          <p class="t-overline text-muted">{t("home.categories.title")}</p>
          <ul class="t-body mt-5 flex flex-wrap items-center gap-x-3 gap-y-2">
            {categories.map((c, idx) => (
              <li class="flex items-center gap-x-3">
                <a
                  href={`${localePath(locale, "/products")}?category=${c.slug}`}
                  class="text-fg hover:text-accent transition-colors duration-150"
                >
                  {c.name[locale]}
                </a>
                {idx < categories.length - 1 && (
                  <span class="text-faint" aria-hidden="true">
                    ·
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }
</BaseLayout>
