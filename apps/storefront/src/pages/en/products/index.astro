---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Filters from "@/components/Filters.astro";
import ProductGrid from "@/islands/ProductGrid.tsx";
import { listProducts, resolveApiUrl, toProductCardListing } from "@/lib/api";
import { createTranslator, localePath } from "@/lib/i18n";

const locale = "en" as const;
const t = createTranslator(locale);

// See `pages/products/index.astro` for the rationale: under
// `output: "static"` the URL params are unobservable at build time, so the
// island owns URL parsing (`urlDriven`) and this page fetches the
// unfiltered canonical first page for SEO + initialData.
const title = `${t("products.list.title")} — mt-commerce`;
const apiUrl = resolveApiUrl();
const detailHrefBase = localePath(locale, "/products");

const activeFilters = {
  category: undefined,
  search: undefined,
  minPrice: undefined,
  maxPrice: undefined,
  sort: undefined,
};

// Mirrors `pages/products/index.astro` — see comments there.
const seoListing = await listProducts(locale, {
  page: 1,
  sort: "newest",
});
const seoCards = toProductCardListing(seoListing, locale);
const initialGridData = seoCards.items.length > 0 ? seoCards : undefined;

const siteUrl = Astro.site?.toString() ?? Astro.url.origin;
const productsUrl = new URL(
  localePath(locale, "/products"),
  siteUrl,
).toString();
const homeUrl = new URL(localePath(locale, "/"), siteUrl).toString();

const jsonLd: object[] = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: t("products.detail.breadcrumbs.home"),
        item: homeUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: t("products.list.title"),
        item: productsUrl,
      },
    ],
  },
];

if (seoListing.items.length > 0) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: seoListing.items.map((p, idx) => ({
      "@type": "ListItem",
      position: idx + 1,
      url: new URL(`${detailHrefBase}/${p.slug}`, siteUrl).toString(),
      name: p.title[locale],
    })),
  });
}
---

<BaseLayout
  title={title}
  description={t("products.list.title")}
  jsonLd={jsonLd}
>
  <div
    class="mx-auto max-w-[1280px] px-5 pt-16 pb-24 md:px-8 md:pt-20 md:pb-32"
  >
    <header class="mb-12 md:mb-16">
      <h1 class="t-display text-fg">{t("products.list.title")}</h1>
    </header>

    <div class="mb-10 md:mb-14">
      <Filters active={activeFilters} />
    </div>

    {
      /*
      Visually-hidden section heading; cards inside the grid use `h3`.
      This `h2` keeps heading order valid (h1 → h2 → h3) without adding
      a second visible title above the grid.
    */
    }
    <h2 class="sr-only">{t("products.list.title")}</h2>
    <ProductGrid
      client:load
      apiUrl={apiUrl}
      locale="en-US"
      apiLocale={locale}
      detailHrefBase={detailHrefBase}
      emptyLabel={t("products.list.empty")}
      errorLabel={t("products.list.error")}
      skeletonLabel={t("products.list.skeleton_aria")}
      photoComingSoonLabel={t("products.card.photo_coming_soon")}
      query={{ page: 1, sort: "newest" }}
      urlDriven
      skeletonCount={9}
      showCount
      showingCountTemplate={t("products.list.showing_count")}
      initialData={initialGridData}
    />
  </div>
</BaseLayout>
