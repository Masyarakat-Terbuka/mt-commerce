---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Filters from "@/components/Filters.astro";
import ProductGrid from "@/islands/ProductGrid.tsx";
import { resolveApiUrl } from "@/lib/api";
import { createTranslator, localePath } from "@/lib/i18n";

const t = createTranslator("en");
const url = Astro.url;
const search = url.searchParams.get("q") ?? undefined;
const category = url.searchParams.get("category") || undefined;
const minRaw = url.searchParams.get("min");
const maxRaw = url.searchParams.get("max");
const sortRaw = url.searchParams.get("sort");
const pageRaw = url.searchParams.get("page");

type SortKey = "newest" | "price_asc" | "price_desc";
const sort: SortKey =
  sortRaw === "price_asc" || sortRaw === "price_desc" || sortRaw === "newest"
    ? sortRaw
    : "newest";
const page = pageRaw ? Math.max(1, Number.parseInt(pageRaw, 10) || 1) : 1;
const minPrice = minRaw && /^\d+$/.test(minRaw) ? minRaw : undefined;
const maxPrice = maxRaw && /^\d+$/.test(maxRaw) ? maxRaw : undefined;

const title = `${t("products.list.title")} — mt-commerce`;
const apiUrl = resolveApiUrl();
const detailHrefBase = localePath("en", "/products");
---

<BaseLayout title={title} description={t("products.list.title")}>
  <h1 class="mb-4 text-xl font-semibold md:text-2xl">{t("products.list.title")}</h1>

  <Filters
    active={{
      category,
      search,
      minPrice: minRaw ?? undefined,
      maxPrice: maxRaw ?? undefined,
      sort: sortRaw ?? undefined,
    }}
  />

  <div class="mt-6">
    <ProductGrid
      client:load
      apiUrl={apiUrl}
      locale="en-US"
      detailHrefBase={detailHrefBase}
      emptyLabel={t("products.list.empty")}
      loadingLabel={t("products.list.loading")}
      errorLabel={t("products.list.error")}
      query={{
        ...(category ? { categorySlug: category } : {}),
        ...(search ? { search } : {}),
        ...(minPrice ? { minPriceAmount: minPrice } : {}),
        ...(maxPrice ? { maxPriceAmount: maxPrice } : {}),
        page,
        sort,
      }}
    />
  </div>
</BaseLayout>
