---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductDetail from "@/islands/ProductDetail.tsx";
import { getProductBySlug, listProducts, resolveApiUrl } from "@/lib/api";
import { createTranslator, localePath } from "@/lib/i18n";

export async function getStaticPaths() {
  // Slugs aren't localized in v0.1, so the default locale is fine here.
  // Mirrors `/products/[slug]`'s rationale.
  const result = await listProducts("id", { pageSize: 100, sort: "newest" });
  return result.items.map((p) => ({ params: { slug: p.slug } }));
}

const locale = "en" as const;
const t = createTranslator(locale);
const intlLocale = "en-US";

const { slug } = Astro.params as { slug: string };
const product = await getProductBySlug(locale, slug);

const pageTitle = product ? product.title[locale] : slug;
const description = product ? product.description[locale] : "";
const ogImage = product?.hasImage ? product.imageUrl : undefined;

const jsonLd = product
  ? {
      "@context": "https://schema.org",
      "@type": "Product",
      name: pageTitle,
      description,
      ...(product.hasImage ? { image: product.imageUrl } : {}),
      sku: product.id,
      offers: {
        "@type": "Offer",
        price: product.basePrice.amount.toString(),
        priceCurrency: product.basePrice.currency,
        availability: product.variants.some((v) => v.available)
          ? "https://schema.org/InStock"
          : "https://schema.org/OutOfStock",
      },
    }
  : null;

const apiUrl = resolveApiUrl();
const detailHrefBase = localePath(locale, "/products");
---

<BaseLayout
  title={`${pageTitle} — mt-commerce`}
  description={description}
  ogImage={ogImage}
>
  <ProductDetail
    client:load
    apiUrl={apiUrl}
    slug={slug}
    locale={intlLocale}
    apiLocale={locale}
    loadingLabel={t("products.detail.loading")}
    errorLabel={t("products.list.error")}
    notFoundLabel={t("products.detail.not_found")}
    variantsHeading={t("products.detail.variants")}
    compareAtLabel={t("products.detail.compare_at")}
    addToCartLabel={t("products.detail.add_to_cart")}
    outOfStockLabel={t("products.detail.out_of_stock")}
    breadcrumbHomeLabel={t("products.detail.breadcrumbs.home")}
    relatedTitle={t("products.detail.related_title")}
    detailHrefBase={detailHrefBase}
  />

  {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
</BaseLayout>
