---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductGrid from "@/islands/ProductGrid.tsx";
import {
  listCategories,
  listProducts,
  resolveApiUrl,
  toProductCardListing,
  type StoreProductCardListing,
} from "@/lib/api";
import { createTranslator, localePath } from "@/lib/i18n";

// Mirrors `src/pages/index.astro` with the locale pinned to `en`. See that
// file for layout rationale and structural comments — this one only deviates
// in the locale handling.
const locale = "en" as const;
const t = createTranslator(locale);

const title = `${t("home.hero.headline")} — mt-commerce`;
const description = t("home.hero.subhead");
const apiUrl = resolveApiUrl();
const detailHrefBase = localePath("en", "/products");
const productsHref = localePath("en", "/products");
const intlLocale = "en-US";

const siteUrl = Astro.site?.toString() ?? Astro.url.origin;
const homeUrl = new URL(localePath("en", "/"), siteUrl).toString();
const searchUrl = new URL(
  localePath("en", "/search?q={search_term_string}"),
  siteUrl,
).toString();
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "mt-commerce",
    url: siteUrl,
    logo: new URL("/logo.png", siteUrl).toString(),
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "mt-commerce",
    url: homeUrl,
    inLanguage: "en-US",
    potentialAction: {
      "@type": "SearchAction",
      target: { "@type": "EntryPoint", urlTemplate: searchUrl },
      "query-input": "required name=search_term_string",
    },
  },
];

function unsplash(
  id: string,
  fallbackWidth = 1200,
): { src: string; srcset: string } {
  const at = (w: number, q: number) =>
    `https://images.unsplash.com/${id}?w=${w}&q=${q}&auto=format&fit=crop`;
  return {
    src: at(fallbackWidth, 75),
    srcset: [
      `${at(560, 70)} 560w`,
      `${at(900, 75)} 900w`,
      `${at(1400, 78)} 1400w`,
      `${at(1920, 80)} 1920w`,
    ].join(", "),
  };
}

const banners = [
  {
    img: unsplash("photo-1493106641515-6b5631de4bb9"),
    title: t("home.banner.1.title"),
    cta: t("home.banner.1.cta"),
    alt: t("home.banner.1.alt"),
    href: `${productsHref}?sort=newest`,
  },
  {
    img: unsplash("photo-1606760227091-3dd870d97f1d"),
    title: t("home.banner.3.title"),
    cta: t("home.banner.3.cta"),
    alt: t("home.banner.3.alt"),
    href: `${productsHref}?category=batik`,
  },
] as const;

const categoryTiles = [
  {
    slug: "kopi",
    label: t("home.tiles.kopi"),
    alt: t("home.tiles.alt.kopi"),
    img: unsplash("photo-1495474472287-4d71bcdd2085", 600),
  },
  {
    slug: "batik",
    label: t("home.tiles.batik"),
    alt: t("home.tiles.alt.batik"),
    img: unsplash("photo-1530092285049-1c42085fd395", 600),
  },
  {
    slug: "kerajinan",
    label: t("home.tiles.kerajinan"),
    alt: t("home.tiles.alt.kerajinan"),
    img: unsplash("photo-1565193566173-7a0ee3dbe261", 600),
  },
  {
    slug: "kuliner",
    label: t("home.tiles.kuliner"),
    alt: t("home.tiles.alt.kuliner"),
    img: unsplash("photo-1565299624946-b28f40a0ae38", 600),
  },
  {
    slug: "fashion",
    label: t("home.tiles.fashion"),
    alt: t("home.tiles.alt.fashion"),
    img: unsplash("photo-1490481651871-ab68de25d43d", 600),
  },
] as const;

const pickupTiles = [
  {
    label: t("home.pickup.1.label"),
    alt: t("home.pickup.1.alt"),
    img: unsplash("photo-1559056199-641a0ac8b55e", 600),
    href: `${productsHref}?category=kopi`,
  },
  {
    label: t("home.pickup.2.label"),
    alt: t("home.pickup.2.alt"),
    img: unsplash("photo-1583846783214-7229a91b20ed", 600),
    href: `${productsHref}?category=batik`,
  },
  {
    label: t("home.pickup.3.label"),
    alt: t("home.pickup.3.alt"),
    img: unsplash("photo-1493225457124-a3eb161ffa5f", 600),
    href: `${productsHref}?category=kerajinan`,
  },
  {
    label: t("home.pickup.4.label"),
    alt: t("home.pickup.4.alt"),
    img: unsplash("photo-1583394838336-acd977736f90", 600),
    href: `${productsHref}?sort=newest`,
  },
  {
    label: t("home.pickup.5.label"),
    alt: t("home.pickup.5.alt"),
    img: unsplash("photo-1556228720-195a672e8a03", 600),
    href: `${productsHref}?category=fashion`,
  },
  {
    label: t("home.pickup.6.label"),
    alt: t("home.pickup.6.alt"),
    img: unsplash("photo-1556909114-f6e7ad7d3136", 600),
    href: productsHref,
  },
  {
    label: t("home.pickup.7.label"),
    alt: t("home.pickup.7.alt"),
    img: unsplash("photo-1545239351-1141bd82e8a6", 600),
    href: `${productsHref}?category=kuliner`,
  },
  {
    label: t("home.pickup.8.label"),
    alt: t("home.pickup.8.alt"),
    img: unsplash("photo-1551782450-a2132b4ba21d", 600),
    href: `${productsHref}?category=kuliner`,
  },
] as const;

const featureGroups = [
  {
    title: t("home.features.tab1.title"),
    href: `${productsHref}?category=kerajinan`,
    items: [
      {
        title: t("home.features.tab1.1.title"),
        alt: t("home.features.tab1.1.alt"),
        img: unsplash("photo-1556760544-74068565f05c"),
      },
      {
        title: t("home.features.tab1.2.title"),
        alt: t("home.features.tab1.2.alt"),
        img: unsplash("photo-1517248135467-4c7edcad34c4"),
      },
    ],
  },
  {
    title: t("home.features.tab2.title"),
    href: `${productsHref}?sort=newest`,
    items: [
      {
        title: t("home.features.tab2.1.title"),
        alt: t("home.features.tab2.1.alt"),
        img: unsplash("photo-1601412436009-d964bd02edbc"),
      },
      {
        title: t("home.features.tab2.2.title"),
        alt: t("home.features.tab2.2.alt"),
        img: unsplash("photo-1607082348824-0a96f2a4b9da"),
      },
    ],
  },
  {
    title: t("home.features.tab3.title"),
    href: `${productsHref}?category=kuliner`,
    items: [
      {
        title: t("home.features.tab3.1.title"),
        alt: t("home.features.tab3.1.alt"),
        img: unsplash("photo-1542838132-92c53300491e"),
      },
      {
        title: t("home.features.tab3.2.title"),
        alt: t("home.features.tab3.2.alt"),
        img: unsplash("photo-1568901346375-23c9450c58cd"),
      },
    ],
  },
] as const;

const activities = [
  {
    title: t("home.activities.1.title"),
    alt: t("home.activities.1.alt"),
    img: unsplash("photo-1517760444937-f6397edcbbcd", 800),
    href: localePath("en", "/help"),
  },
  {
    title: t("home.activities.2.title"),
    alt: t("home.activities.2.alt"),
    img: unsplash("photo-1503602642458-232111445657", 800),
    href: localePath("en", "/about"),
  },
  {
    title: t("home.activities.3.title"),
    alt: t("home.activities.3.alt"),
    img: unsplash("photo-1473093295043-cdd812d0e601", 800),
    href: "https://github.com/masyarakat-terbuka/mt-commerce/discussions",
  },
  {
    title: t("home.activities.4.title"),
    alt: t("home.activities.4.alt"),
    img: unsplash("photo-1542838686-37da4a9fd1b3", 800),
    href: "https://github.com/masyarakat-terbuka/mt-commerce",
  },
] as const;

const journalCards = [
  {
    tag: t("home.journal.brewing.tag"),
    title: t("home.journal.brewing.title"),
    alt: t("home.journal.brewing.alt"),
    img: unsplash("photo-1506372023823-741c83b836fe", 600),
    href: `${productsHref}?category=kopi`,
  },
  {
    tag: t("home.journal.batik.tag"),
    title: t("home.journal.batik.title"),
    alt: t("home.journal.batik.alt"),
    img: unsplash("photo-1567620905732-2d1ec7ab7445", 600),
    href: `${productsHref}?category=batik`,
  },
  {
    tag: t("home.journal.craft.tag"),
    title: t("home.journal.craft.title"),
    alt: t("home.journal.craft.alt"),
    img: unsplash("photo-1550583724-b2692b85b150", 600),
    href: `${productsHref}?category=kerajinan`,
  },
  {
    tag: t("home.journal.kuliner.tag"),
    title: t("home.journal.kuliner.title"),
    alt: t("home.journal.kuliner.alt"),
    img: unsplash("photo-1551717743-49959800b1f6", 600),
    href: `${productsHref}?category=kuliner`,
  },
] as const;

const [categories, newest] = await Promise.all([
  listCategories(locale),
  listProducts(locale, { pageSize: 6, sort: "newest" }),
]);

const newestSeed: StoreProductCardListing | undefined =
  newest.items.length === 0 ? undefined : toProductCardListing(newest, locale);
const showNewest = newest.items.length > 0;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <section
    class="relative pt-0 md:pt-2"
    aria-label={t("home.banner.region_label")}
  >
    <ul
      class="hide-scrollbar flex snap-x snap-mandatory gap-3 overflow-x-auto px-5 pb-4 md:gap-5 md:px-8 md:pb-6"
    >
      {
        banners.map((b, i) => (
          <li class="shrink-0 basis-[88%] snap-start md:basis-[58%] lg:basis-[48%]">
            <a href={b.href} class="group block">
              <div class="img-frame bg-cream relative aspect-[3/2] w-full overflow-hidden md:aspect-[16/9]">
                <img
                  src={b.img.src}
                  srcset={b.img.srcset}
                  sizes="(min-width: 1024px) 48vw, (min-width: 768px) 58vw, 88vw"
                  alt={b.alt}
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding="async"
                  fetchpriority={i === 0 ? "high" : "auto"}
                  width="1400"
                  height="788"
                  onerror="this.parentElement.dataset.broken='true'"
                  class="absolute inset-0 h-full w-full object-cover transition-opacity duration-200 group-hover:opacity-90"
                />
                <span
                  class="img-fallback absolute inset-0 items-center justify-center px-6 text-center"
                  aria-hidden="true"
                >
                  <span class="t-body text-fg line-clamp-2">{b.title}</span>
                </span>
              </div>
              <div class="mt-4">
                <p class="t-h1 text-fg group-hover:text-accent max-w-[28ch] transition-colors duration-200">
                  {b.title}
                </p>
                <span class="t-body text-fg mt-2 inline-flex items-center gap-2 underline-offset-[6px] group-hover:underline">
                  {b.cta}
                  <span aria-hidden="true">&rarr;</span>
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section
    class="border-line mx-auto max-w-[1280px] border-y px-5 py-5 md:px-8 md:py-6"
    aria-labelledby="home-trust"
  >
    <h2 id="home-trust" class="sr-only">{t("home.trust.title")}</h2>
    <ul class="grid grid-cols-1 gap-y-3 md:grid-cols-3 md:gap-x-6 md:gap-y-0">
      <li class="t-caption text-fg md:text-center">
        {t("home.trust.shipping")}
      </li>
      <li class="t-caption text-fg md:text-center">
        {t("home.trust.payment")}
      </li>
      <li class="t-caption text-fg md:text-center">
        {t("home.trust.artisans")}
      </li>
    </ul>
  </section>

  <section
    class="mx-auto max-w-[1280px] px-5 py-8 md:px-8 md:py-12"
    aria-labelledby="home-tiles"
  >
    <h2 id="home-tiles" class="t-overline text-muted">
      {t("home.tiles.title")}
    </h2>
    <ul class="mt-5 grid grid-cols-5 gap-x-2 gap-y-5 md:mt-8 md:gap-x-6">
      {
        categoryTiles.map((tile) => (
          <li>
            <a
              href={`${productsHref}?category=${tile.slug}`}
              class="group flex flex-col items-center"
            >
              <div class="img-frame bg-cream relative aspect-square w-full overflow-hidden rounded-full">
                <img
                  src={tile.img.src}
                  srcset={tile.img.srcset}
                  sizes="(min-width: 768px) 18vw, 18vw"
                  alt={tile.alt}
                  loading="lazy"
                  decoding="async"
                  width="600"
                  height="600"
                  onerror="this.parentElement.dataset.broken='true'"
                  class="absolute inset-0 h-full w-full object-cover transition-opacity duration-200 group-hover:opacity-90"
                />
                <span
                  class="img-fallback absolute inset-0 items-center justify-center px-3 text-center"
                  aria-hidden="true"
                >
                  <span class="t-caption text-fg line-clamp-2">
                    {tile.label}
                  </span>
                </span>
              </div>
              <span class="t-caption text-fg group-hover:text-accent mt-3 text-center transition-colors duration-200 md:mt-4">
                {tile.label}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  {
    showNewest && (
      <section class="mx-auto max-w-[1280px] px-5 py-8 md:px-8 md:py-12">
        <div class="flex items-baseline justify-between gap-4">
          <h2 class="t-overline text-muted">{t("home.strips.newest")}</h2>
          <a
            href={`${productsHref}?sort=newest`}
            class="t-body text-muted hover:text-accent transition-colors duration-150"
          >
            {t("home.strips.newest_link")}
          </a>
        </div>
        <div class="mt-5 md:mt-8">
          <ProductGrid
            client:load
            apiUrl={apiUrl}
            locale={intlLocale}
            apiLocale={locale}
            detailHrefBase={detailHrefBase}
            emptyLabel={t("products.list.empty")}
            errorLabel={t("products.list.error")}
            skeletonLabel={t("products.list.skeleton_aria")}
            photoComingSoonLabel={t("products.card.photo_coming_soon")}
            query={{ pageSize: 6, sort: "newest" }}
            limit={6}
            skeletonCount={6}
            initialData={newestSeed}
          />
        </div>
      </section>
    )
  }

  <section
    class="mx-auto max-w-[1280px] px-5 py-8 md:px-8 md:py-12"
    aria-labelledby="home-pickup"
  >
    <h2 id="home-pickup" class="t-overline text-muted">
      {t("home.pickup.title")}
    </h2>
    <ul
      class="mt-5 grid grid-cols-2 gap-x-3 gap-y-7 md:mt-8 md:grid-cols-4 md:gap-x-4 md:gap-y-8"
    >
      {
        pickupTiles.map((tile) => (
          <li>
            <a href={tile.href} class="group block">
              <div class="bg-cream relative aspect-[4/5] w-full overflow-hidden">
                <img
                  src={tile.img.src}
                  srcset={tile.img.srcset}
                  sizes="(min-width: 768px) 22vw, 50vw"
                  alt={tile.alt}
                  loading="lazy"
                  decoding="async"
                  width="600"
                  height="750"
                  class="absolute inset-0 h-full w-full object-cover transition-opacity duration-200 group-hover:opacity-90"
                />
              </div>
              <p class="t-body text-fg group-hover:text-accent mt-3 transition-colors duration-200">
                {tile.label}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section
    class="mx-auto max-w-[1280px] px-5 py-8 md:px-8 md:py-12"
    aria-labelledby="home-features"
  >
    <h2 id="home-features" class="t-overline text-muted">
      {t("home.features.title")}
    </h2>

    <div class="mt-6 space-y-10 md:mt-8 md:space-y-14">
      {
        featureGroups.map((group) => (
          <div>
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="t-h1 text-fg">{group.title}</h3>
              <a
                href={group.href}
                class="t-body text-muted hover:text-accent transition-colors duration-150"
              >
                {t("home.features.see_all")}
              </a>
            </div>
            <ul class="mt-5 grid grid-cols-1 gap-x-6 gap-y-7 md:mt-6 md:grid-cols-2">
              {group.items.map((item) => (
                <li>
                  <a href={group.href} class="group block">
                    <div class="bg-cream relative aspect-[3/2] w-full overflow-hidden">
                      <img
                        src={item.img.src}
                        srcset={item.img.srcset}
                        sizes="(min-width: 768px) 50vw, 100vw"
                        alt={item.alt}
                        loading="lazy"
                        decoding="async"
                        width="1200"
                        height="800"
                        class="absolute inset-0 h-full w-full object-cover transition-opacity duration-200 group-hover:opacity-90"
                      />
                    </div>
                    <p class="t-body text-fg group-hover:text-accent mt-4 max-w-[44ch] transition-colors duration-200">
                      {item.title}
                    </p>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <section
    class="mx-auto max-w-[1280px] px-5 py-8 md:px-8 md:py-12"
    aria-labelledby="home-activities"
  >
    <h2 id="home-activities" class="t-overline text-muted">
      {t("home.activities.title")}
    </h2>
    <ul
      class="mt-5 grid grid-cols-2 gap-x-4 gap-y-7 md:mt-8 md:grid-cols-4 md:gap-x-6"
    >
      {
        activities.map((item) => (
          <li>
            <a href={item.href} class="group block">
              <div class="bg-cream relative aspect-[3/2] w-full overflow-hidden">
                <img
                  src={item.img.src}
                  srcset={item.img.srcset}
                  sizes="(min-width: 768px) 22vw, 50vw"
                  alt={item.alt}
                  loading="lazy"
                  decoding="async"
                  width="800"
                  height="533"
                  class="absolute inset-0 h-full w-full object-cover transition-opacity duration-200 group-hover:opacity-90"
                />
              </div>
              <p class="t-body text-fg group-hover:text-accent mt-3 transition-colors duration-200">
                {item.title}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section
    class="mx-auto max-w-[1280px] px-5 py-8 md:px-8 md:py-12"
    aria-labelledby="home-journal"
  >
    <div class="flex items-baseline justify-between gap-4">
      <h2 id="home-journal" class="t-overline text-muted">
        {t("home.journal.title")}
      </h2>
      <a
        href={localePath("en", "/products")}
        class="t-body text-muted hover:text-accent transition-colors duration-150"
      >
        {t("home.journal.see_all")}
      </a>
    </div>
    <ul
      class="mt-5 grid grid-cols-2 gap-x-4 gap-y-7 md:mt-8 md:grid-cols-4 md:gap-x-6"
    >
      {
        journalCards.map((card) => (
          <li>
            <a href={card.href} class="group block">
              <div class="bg-cream relative aspect-square w-full overflow-hidden">
                <img
                  src={card.img.src}
                  srcset={card.img.srcset}
                  sizes="(min-width: 768px) 22vw, 50vw"
                  alt={card.alt}
                  loading="lazy"
                  decoding="async"
                  width="600"
                  height="600"
                  class="absolute inset-0 h-full w-full object-cover transition-opacity duration-200 group-hover:opacity-90"
                />
              </div>
              <p class="t-overline text-muted mt-4">{card.tag}</p>
              <p class="t-body text-fg group-hover:text-accent mt-2 transition-colors duration-200">
                {card.title}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section aria-labelledby="home-browse">
    <div class="mx-auto max-w-[1280px] px-5 py-8 md:px-8 md:py-10">
      <div class="flex items-baseline justify-between gap-4">
        <h2 id="home-browse" class="t-overline text-muted">
          {t("home.browse.title")}
        </h2>
        <a
          href={productsHref}
          class="t-body text-fg hover:text-accent transition-colors duration-150"
        >
          {t("home.browse.cta")}
        </a>
      </div>
      {
        categories.length > 0 && (
          <ul class="t-body mt-5 flex flex-wrap items-center gap-x-3 gap-y-2">
            {categories.map((c, idx) => (
              <li class="flex items-center gap-x-3">
                <a
                  href={`${productsHref}?category=${c.slug}`}
                  class="text-fg hover:text-accent transition-colors duration-150"
                >
                  {c.name[locale]}
                </a>
                {idx < categories.length - 1 && (
                  <span class="text-faint" aria-hidden="true">
                    ·
                  </span>
                )}
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .hide-scrollbar {
    scrollbar-width: none;
  }
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }

  .img-fallback {
    display: none;
  }
  .img-frame[data-broken="true"] > img {
    display: none;
  }
  .img-frame[data-broken="true"] > .img-fallback {
    display: flex;
  }
</style>
