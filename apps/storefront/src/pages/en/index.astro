---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductGrid from "@/islands/ProductGrid.tsx";
import { listCategories, resolveApiUrl } from "@/lib/api";
import { createTranslator, localePath } from "@/lib/i18n";

const locale = "en" as const;
const t = createTranslator(locale);

const title = `${t("home.hero.headline")} — mt-commerce`;
const description = t("home.hero.subhead");

const apiUrl = resolveApiUrl();
const detailHrefBase = localePath("en", "/products");

const categories = await listCategories();
---

<BaseLayout title={title} description={description}>
  {/* Hero mirrors the id/ home page — typography only, no image wash. */}
  <section class="bg-cream" aria-labelledby="home-hero">
    <div class="mx-auto max-w-[1280px] px-4 py-24 md:px-8 md:py-32">
      <h1 id="home-hero" class="t-display max-w-[18ch] text-fg">
        {t("home.hero.headline")}
      </h1>
      <p class="mt-5 max-w-[52ch] t-body text-muted">
        {t("home.hero.subhead")}
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-[1280px] border-t border-line px-4 py-16 md:px-8 md:py-24">
    <div class="flex items-baseline justify-between">
      <h2 class="t-h1 text-fg">{t("home.featured.title")}</h2>
      <a
        href={localePath(locale, "/products")}
        class="t-body text-muted transition-colors duration-150 hover:text-accent"
      >
        {t("products.list.title")} &rarr;
      </a>
    </div>
    <div class="mt-8">
      <ProductGrid
        client:load
        apiUrl={apiUrl}
        locale="en-US"
        detailHrefBase={detailHrefBase}
        emptyLabel={t("products.list.empty")}
        errorLabel={t("products.list.error")}
        skeletonLabel={t("products.list.skeleton_aria")}
          photoComingSoonLabel={t("products.card.photo_coming_soon")}
        query={{ pageSize: 4, sort: "newest" }}
        limit={4}
        skeletonCount={4}
      />
    </div>
  </section>

  {
    categories.length > 0 && (
      <section class="border-t border-line">
        <div class="mx-auto max-w-[1280px] px-4 py-10 md:px-8 md:py-12">
          <h2 class="t-caption text-muted">
            {t("home.categories.title")}
          </h2>
          <ul class="mt-4 flex flex-wrap items-center gap-x-2 gap-y-2 t-body">
            {
              categories.map((c, idx) => (
                <li class="flex items-center gap-x-2">
                  <a
                    href={`${localePath(locale, "/products")}?category=${c.slug}`}
                    class="text-fg transition-colors duration-150 hover:text-accent"
                  >
                    {c.name[locale]}
                  </a>
                  {idx < categories.length - 1 && (
                    <span class="text-faint" aria-hidden="true">
                      ·
                    </span>
                  )}
                </li>
              ))
            }
          </ul>
        </div>
      </section>
    )
  }
</BaseLayout>
