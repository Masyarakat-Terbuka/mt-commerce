---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CheckoutConfirmed from "@/islands/CheckoutConfirmed.tsx";
import { createTranslator, localePath } from "@/lib/i18n";

const locale = "en" as const;
const t = createTranslator(locale);
const intlLocale = "en-US";

const homeHref = localePath(locale, "/");
const orderIntentId = Astro.url.searchParams.get("id") ?? "";

const title = `${t("checkout.confirmed.title")} — mt-commerce`;
---

<BaseLayout title={title} description={t("checkout.confirmed.subtitle")}>
  <CheckoutConfirmed
    client:load
    orderIntentId={orderIntentId}
    locale={intlLocale}
    homeHref={homeHref}
    titleLabel={t("checkout.confirmed.title")}
    subtitleLabel={t("checkout.confirmed.subtitle")}
    orderNumberLabel={t("checkout.confirmed.order_number_label")}
    nextStepsLabel={t("checkout.confirmed.next_steps")}
    backHomeLabel={t("checkout.confirmed.back_home")}
    missingLabel={t("checkout.confirmed.missing")}
    itemsLabel={t("checkout.review.items_label")}
    addressLabel={t("checkout.review.address_label")}
    totalsLabels={{
      subtotal: t("cart.subtotal"),
      tax: t("cart.tax"),
      shipping: t("cart.shipping"),
      total: t("cart.total"),
    }}
  />
</BaseLayout>
