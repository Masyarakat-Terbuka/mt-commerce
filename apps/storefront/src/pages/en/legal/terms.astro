---
/**
 * Terms of service — English mirror of `pages/legal/terms.astro`.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";
import { createTranslator, localePath } from "@/lib/i18n";

const locale = "en" as const;
const t = createTranslator(locale);

const entry = await getEntry("legal", "en/terms");
if (!entry) {
  throw new Error("Missing legal entry: legal/en/terms.mdx");
}
const { Content } = await render(entry);

const title = `${entry.data.title} — mt-commerce`;
---

<BaseLayout title={title} description={t("legal.draft_notice")}>
  <article class="mx-auto max-w-[64ch] px-5 pb-24 pt-12 md:px-8 md:pb-32 md:pt-20">
    <a
      href={localePath(locale, "/")}
      class="t-caption text-muted underline-offset-[6px] transition-colors duration-150 hover:text-accent hover:underline"
    >
      &larr; {t("nav.home")}
    </a>

    <header class="mt-8">
      <h1 class="t-display text-fg">{entry.data.title}</h1>
      <p class="mt-3 t-caption text-muted">
        {t("legal.last_updated")} <time datetime={entry.data.lastUpdated}>{entry.data.lastUpdated}</time>
      </p>
    </header>

    <aside
      class="mt-8 border border-line bg-paper px-5 py-4 t-body text-muted"
      role="note"
    >
      {t("legal.draft_notice")}
    </aside>

    <div class="prose-mt mt-12">
      <Content />
    </div>
  </article>
</BaseLayout>
