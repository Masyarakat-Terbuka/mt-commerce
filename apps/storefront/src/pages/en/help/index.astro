---
/**
 * Help index — English mirror of `pages/help/index.astro`.
 *
 * See the id version for the rationale behind layout choices and the
 * folder-based locale filtering. The two pages are intentionally kept
 * as siblings rather than abstracted into a shared component: the
 * duplication is small, and being able to read a single page top-to-
 * bottom is worth more than a tiny shared wrapper.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { createTranslator, localePath } from "@/lib/i18n";

const locale = "en" as const;
const t = createTranslator(locale);

const entries = await getCollection("help", (entry: CollectionEntry<"help">) =>
  entry.id.startsWith("en/"),
);

entries.sort((a, b) => {
  const ao = a.data.order ?? Number.MAX_SAFE_INTEGER;
  const bo = b.data.order ?? Number.MAX_SAFE_INTEGER;
  if (ao !== bo) return ao - bo;
  return a.data.title.localeCompare(b.data.title, locale);
});

const title = `${t("help.index.title")} — mt-commerce`;
const description = t("help.index.subhead");
---

<BaseLayout title={title} description={description}>
  <section class="mx-auto max-w-[960px] px-5 pb-24 pt-16 md:px-8 md:pb-32 md:pt-24">
    <p class="t-overline text-muted">{t("help.index.title")}</p>
    <h1 class="mt-4 t-display text-fg">{t("help.index.title")}</h1>
    <p class="mt-5 max-w-[60ch] t-body text-muted">{t("help.index.subhead")}</p>

    <ul class="mt-12 grid grid-cols-1 gap-4 md:mt-16 md:grid-cols-2">
      {
        entries.map((entry) => {
          const slug = entry.id.replace(/^en\//, "");
          return (
            <li>
              <a
                href={localePath(locale, `/help/${slug}`)}
                class="block h-full border border-line bg-paper px-6 py-6 transition-colors duration-150 hover:border-line-strong"
              >
                <h2 class="t-h1 text-fg">{entry.data.title}</h2>
                <p class="mt-2 t-body text-muted">{entry.data.summary}</p>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>
</BaseLayout>
