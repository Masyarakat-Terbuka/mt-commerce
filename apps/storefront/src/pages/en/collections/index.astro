---
/**
 * English mirror of `pages/collections/index.astro` — see comments there.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { COLLECTIONS } from "@/lib/collections";
import { createTranslator, localePath } from "@/lib/i18n";

const locale = "en" as const;
const t = createTranslator(locale);

const indexTitle = t("collections.index.title");
const indexTagline = t("collections.index.tagline");
const seeAllLabel = t("collections.index.see_all");
const pageTitle = `${indexTitle} — mt-commerce`;

const entries = COLLECTIONS.map((c) => ({
  slug: c.slug,
  title: t(c.titleKey),
  tagline: t(c.taglineKey),
  href: localePath(locale, `/collections/${c.slug}`),
}));

const siteUrl = Astro.site?.toString() ?? Astro.url.origin;
const homeUrl = new URL(localePath(locale, "/"), siteUrl).toString();
const collectionsUrl = new URL(
  localePath(locale, "/collections"),
  siteUrl,
).toString();

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: t("breadcrumb.home"),
        item: homeUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: indexTitle,
        item: collectionsUrl,
      },
    ],
  },
];
---

<BaseLayout title={pageTitle} description={indexTagline} jsonLd={jsonLd}>
  <div
    class="mx-auto max-w-[1280px] px-5 pt-16 pb-24 md:px-8 md:pt-20 md:pb-32"
  >
    <header class="mb-12 md:mb-16">
      <h1 class="t-display text-fg">{indexTitle}</h1>
      <p class="t-body text-muted mt-4 max-w-[44ch]">{indexTagline}</p>
    </header>

    <ul class="border-line border-t">
      {
        entries.map((entry) => (
          <li class="border-line border-b">
            <a
              href={entry.href}
              class="group flex flex-col gap-3 py-8 md:flex-row md:items-baseline md:justify-between md:gap-12 md:py-12"
            >
              <div class="md:flex-1">
                <h2 class="t-h1 text-fg group-hover:text-accent transition-colors duration-150">
                  {entry.title}
                </h2>
                <p class="t-body text-muted mt-2 max-w-[56ch]">
                  {entry.tagline}
                </p>
              </div>
              <span class="t-body text-muted group-hover:text-accent transition-colors duration-150 md:shrink-0">
                {seeAllLabel}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
