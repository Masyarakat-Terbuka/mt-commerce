---
/**
 * /en/search — English search results.
 *
 * Mirrors `pages/search.astro` (the Indonesian default) almost line-for-line.
 * Two locales, two files is the storefront's convention — see
 * `pages/products/index.astro` and `pages/en/products/index.astro` for the
 * same shape. Comments are not duplicated to avoid drift.
 *
 * The query-dependent body lives in the `SearchResults` island because the
 * storefront builds with `output: "static"`; see the Indonesian file for
 * the full rationale.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import SearchResults from "@/islands/SearchResults.tsx";
import { resolveApiUrl, toIntlLocale } from "@/lib/api";
import { createTranslator, localePath } from "@/lib/i18n";

const locale = "en" as const;
const t = createTranslator(locale);

const productsHref = localePath(locale, "/products");
const homeHref = localePath(locale, "/");
const searchHref = localePath(locale, "/search");
const detailHrefBase = localePath(locale, "/products");
const apiUrl = resolveApiUrl();

const title = `${t("search.title")} — mt-commerce`;
const description = t("search.empty.headline");

const labels = {
  emptyHeading: t("search.empty.headline"),
  emptyBody: t("search.empty.body"),
  resultsHeadingTemplate: t("search.title_with_query"),
  countTemplate: t("search.count"),
  noResultsHeadingTemplate: t("search.no_results.headline"),
  noResultsBody: t("search.no_results.body"),
  loading: t("search.loading"),
  error: t("search.error"),
  browseAll: t("search.browse_all"),
  prevLabel: t("products.list.pagination.prev"),
  nextLabel: t("products.list.pagination.next"),
};
---

<BaseLayout title={title} description={description} noindex={true}>
  <div
    class="mx-auto max-w-[1280px] px-5 pt-12 pb-24 md:px-8 md:pt-16 md:pb-32"
  >
    <nav class="t-caption text-muted mb-8 md:mb-10" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-2">
        <li>
          <a
            class="hover:text-accent transition-colors duration-150"
            href={homeHref}
          >
            {t("breadcrumb.home")}
          </a>
        </li>
        <li aria-hidden="true" class="text-faint">/</li>
        <li class="text-fg" aria-current="page">{t("breadcrumb.search")}</li>
      </ol>
    </nav>

    <SearchResults
      client:load
      apiUrl={apiUrl}
      locale={toIntlLocale(locale)}
      apiLocale={locale}
      detailHrefBase={detailHrefBase}
      productsHref={productsHref}
      searchHref={searchHref}
      labels={labels}
    />
  </div>
</BaseLayout>
