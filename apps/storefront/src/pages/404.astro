---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { resolveLocale, localePath, type Locale } from "@/lib/i18n";

const locale: Locale = resolveLocale(Astro.currentLocale);
const heading = locale === "en" ? "Page not found" : "Halaman tidak ditemukan";
const body =
  locale === "en"
    ? "The page you were looking for is not here."
    : "Halaman yang Anda cari tidak tersedia.";
const home = locale === "en" ? "Back to home" : "Kembali ke beranda";
---

<BaseLayout title={`${heading} — mt-commerce`} description={body}>
  <section class="mx-auto max-w-[640px] px-5 py-32 md:px-8 md:py-40">
    <p class="t-overline text-muted">404</p>
    <h1 class="t-display text-fg mt-4">{heading}</h1>
    <p class="t-body text-muted mt-5">{body}</p>
    <a
      href={localePath(locale, "/")}
      class="t-body text-fg hover:text-accent mt-10 inline-flex items-center gap-2 underline-offset-[6px] transition-colors duration-200 hover:underline"
    >
      &larr; {home}
    </a>
  </section>
</BaseLayout>
