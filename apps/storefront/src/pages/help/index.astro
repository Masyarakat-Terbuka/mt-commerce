---
/**
 * Help index — Indonesian (default locale).
 *
 * Lists every help topic in the current locale as a calm two-column grid
 * of bordered link cards. Topics are pulled from the `help` content
 * collection and filtered to entries under the `id/` folder, so adding
 * a new `.mdx` file in `src/content/help/id/` automatically shows up here
 * without touching this page.
 *
 * Why folder-based locale filtering: see `src/content.config.ts`.
 *
 * The English mirror lives at `src/pages/en/help/index.astro` and reuses
 * the same list shape — only the locale prefix and the collection filter
 * differ. Sharing a layout component for the list was considered and
 * rejected at n=2: the duplication is small, and a local read is easier
 * than tracing through a wrapper.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { createTranslator, localePath } from "@/lib/i18n";

const locale = "id" as const;
const t = createTranslator(locale);

// `entry.id` is the file path relative to the collection's `base` —
// for help/id/shipping.mdx that's "id/shipping". The leading "id/"
// is the locale filter; we slice it off later to build the route.
const entries = await getCollection("help", (entry: CollectionEntry<"help">) =>
  entry.id.startsWith("id/"),
);

// Sort by `order` ascending; topics without `order` fall to the end and
// sort by title alphabetically. Using `Number.MAX_SAFE_INTEGER` as a
// sentinel keeps the comparator branch-free.
entries.sort((a, b) => {
  const ao = a.data.order ?? Number.MAX_SAFE_INTEGER;
  const bo = b.data.order ?? Number.MAX_SAFE_INTEGER;
  if (ao !== bo) return ao - bo;
  return a.data.title.localeCompare(b.data.title, locale);
});

const title = `${t("help.index.title")} — mt-commerce`;
const description = t("help.index.subhead");
---

<BaseLayout title={title} description={description}>
  <section class="mx-auto max-w-[960px] px-5 pb-24 pt-16 md:px-8 md:pb-32 md:pt-24">
    <p class="t-overline text-muted">{t("help.index.title")}</p>
    <h1 class="mt-4 t-display text-fg">{t("help.index.title")}</h1>
    <p class="mt-5 max-w-[60ch] t-body text-muted">{t("help.index.subhead")}</p>

    {/*
      Two-column grid on desktop, single column on mobile. Cards are simple
      bordered blocks — no shadow, no gradient — matching the rest of the
      storefront. The whole card is a link so the hit target is generous.
    */}
    <ul class="mt-12 grid grid-cols-1 gap-4 md:mt-16 md:grid-cols-2">
      {
        entries.map((entry) => {
          // Strip the "id/" prefix to derive the slug used in routing.
          const slug = entry.id.replace(/^id\//, "");
          return (
            <li>
              <a
                href={localePath(locale, `/help/${slug}`)}
                class="block h-full border border-line bg-paper px-6 py-6 transition-colors duration-150 hover:border-line-strong"
              >
                <h2 class="t-h1 text-fg">{entry.data.title}</h2>
                <p class="mt-2 t-body text-muted">{entry.data.summary}</p>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>
</BaseLayout>
