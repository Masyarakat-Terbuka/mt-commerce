---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import Filters from "@/components/Filters.astro";
import Pagination from "@/components/Pagination.astro";
import { listProducts, type SortKey } from "@/lib/api";
import { createTranslator, resolveLocale, localePath, type Locale } from "@/lib/i18n";

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);

const url = Astro.url;
const search = url.searchParams.get("q") ?? undefined;
const category = url.searchParams.get("category") || undefined;
const minRaw = url.searchParams.get("min");
const maxRaw = url.searchParams.get("max");
const sortRaw = url.searchParams.get("sort");
const pageRaw = url.searchParams.get("page");

const sort: SortKey | undefined =
  sortRaw === "price_asc" || sortRaw === "price_desc" || sortRaw === "newest" ? sortRaw : undefined;
const page = pageRaw ? Math.max(1, Number.parseInt(pageRaw, 10) || 1) : 1;
const minPrice = minRaw && /^\d+$/.test(minRaw) ? BigInt(minRaw) : undefined;
const maxPrice = maxRaw && /^\d+$/.test(maxRaw) ? BigInt(maxRaw) : undefined;

const result = listProducts({ search, category, minPrice, maxPrice, sort, page });

// Build a base URL preserving filters but stripping `page`.
const preserved = new URLSearchParams(url.searchParams);
preserved.delete("page");
const qs = preserved.toString();
const baseUrl = qs ? `${localePath(locale, "/products")}?${qs}` : localePath(locale, "/products");

const title = `${t("products.list.title")} — mt-commerce`;
---

<BaseLayout title={title} description={t("products.list.title")}>
  <h1 class="mb-4 text-xl font-semibold md:text-2xl">{t("products.list.title")}</h1>

  <Filters
    active={{
      category,
      search,
      minPrice: minRaw ?? undefined,
      maxPrice: maxRaw ?? undefined,
      sort: sortRaw ?? undefined,
    }}
  />

  <div class="mt-6">
    {
      result.items.length === 0 ? (
        <p class="rounded border border-neutral-200 bg-neutral-50 p-6 text-center text-sm text-neutral-600">
          {t("products.list.empty")}
        </p>
      ) : (
        <div class="grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4">
          {result.items.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      )
    }
  </div>

  <Pagination page={result.page} totalPages={result.totalPages} baseUrl={baseUrl} />
</BaseLayout>
