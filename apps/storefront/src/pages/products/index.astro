---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Filters from "@/components/Filters.astro";
import ProductGrid from "@/islands/ProductGrid.tsx";
import { listProducts, resolveApiUrl, toProductCardListing } from "@/lib/api";
import {
  createTranslator,
  resolveLocale,
  localePath,
  type Locale,
} from "@/lib/i18n";

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);

const url = Astro.url;
const search = url.searchParams.get("q") ?? undefined;
const category = url.searchParams.get("category") || undefined;
const minRaw = url.searchParams.get("min");
const maxRaw = url.searchParams.get("max");
const sortRaw = url.searchParams.get("sort");
const pageRaw = url.searchParams.get("page");

type SortKey = "newest" | "price_asc" | "price_desc";
const sort: SortKey =
  sortRaw === "price_asc" || sortRaw === "price_desc" || sortRaw === "newest"
    ? sortRaw
    : "newest";
const page = pageRaw ? Math.max(1, Number.parseInt(pageRaw, 10) || 1) : 1;
const minPrice = minRaw && /^\d+$/.test(minRaw) ? minRaw : undefined;
const maxPrice = maxRaw && /^\d+$/.test(maxRaw) ? maxRaw : undefined;

const title = `${t("products.list.title")} — mt-commerce`;
const apiUrl = resolveApiUrl();
const detailHrefBase = localePath(locale, "/products");
const intlLocale = locale === "id" ? "id-ID" : "en-US";

const activeFilters = {
  category,
  search,
  minPrice: minRaw ?? undefined,
  maxPrice: maxRaw ?? undefined,
  sort: sortRaw ?? undefined,
};

// Single request-time fetch — drives both the SEO `ItemList` JSON-LD and
// the island's `initialData`. Using the same query args the island would
// have requested means visitors hit zero "Memuat produk…" flash on first
// paint while search engines still see a real product list in the source.
//
// Resilience: on API failure `listProducts` returns an empty result; we
// omit the `ItemList` payload AND pass nothing as `initialData` so the
// island falls back to a client-side fetch (offline-build behaviour).
const seoListing = await listProducts(locale, {
  ...(category ? { category } : {}),
  ...(search ? { search } : {}),
  ...(minPrice ? { minPrice: BigInt(minPrice) } : {}),
  ...(maxPrice ? { maxPrice: BigInt(maxPrice) } : {}),
  page,
  sort,
});
const seoCards = toProductCardListing(seoListing, locale);
const initialGridData = seoCards.items.length > 0 ? seoCards : undefined;

const siteUrl = Astro.site?.toString() ?? Astro.url.origin;
const productsUrl = new URL(
  localePath(locale, "/products"),
  siteUrl,
).toString();
const homeUrl = new URL(localePath(locale, "/"), siteUrl).toString();

// `BreadcrumbList` covers the navigation trail; `ItemList` enumerates
// the products visible on the page. Both shapes follow schema.org
// minimal examples and Google's rich-results requirements.
const jsonLd: object[] = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: t("products.detail.breadcrumbs.home"),
        item: homeUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: t("products.list.title"),
        item: productsUrl,
      },
    ],
  },
];

if (seoListing.items.length > 0) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: seoListing.items.map((p, idx) => ({
      "@type": "ListItem",
      position: idx + 1,
      url: new URL(`${detailHrefBase}/${p.slug}`, siteUrl).toString(),
      name: p.title[locale],
    })),
  });
}
---

<BaseLayout
  title={title}
  description={t("products.list.title")}
  jsonLd={jsonLd}
>
  <div
    class="mx-auto max-w-[1280px] px-5 pt-16 pb-24 md:px-8 md:pt-20 md:pb-32"
  >
    {/* Page title — display weight 400, generous bottom margin. */}
    <header class="mb-12 md:mb-16">
      <h1 class="t-display text-fg">{t("products.list.title")}</h1>
    </header>

    {/* Horizontal filter bar — search + categories + sort/price disclosure. */}
    <div class="mb-10 md:mb-14">
      <Filters active={activeFilters} />
    </div>

    {
      /*
      Visually-hidden section heading. Cards inside the grid use `h3`; this
      `h2` keeps the heading order valid (h1 → h2 → h3) without adding
      another visible label above the grid.
    */
    }
    <h2 class="sr-only">{t("products.list.title")}</h2>
    {
      /* Grid — 4 columns lg, 3 tablet, 2 mobile. Tighter rhythm than the
        prior 3-up to feel more like Muji's product browse. */
    }
    <ProductGrid
      client:load
      apiUrl={apiUrl}
      locale={intlLocale}
      apiLocale={locale}
      detailHrefBase={detailHrefBase}
      emptyLabel={t("products.list.empty")}
      errorLabel={t("products.list.error")}
      skeletonLabel={t("products.list.skeleton_aria")}
      photoComingSoonLabel={t("products.card.photo_coming_soon")}
      query={{
        ...(category ? { categorySlug: category } : {}),
        ...(search ? { search } : {}),
        ...(minPrice ? { minPriceAmount: minPrice } : {}),
        ...(maxPrice ? { maxPriceAmount: maxPrice } : {}),
        page,
        sort,
      }}
      skeletonCount={9}
      showCount
      showingCountTemplate={t("products.list.showing_count")}
      initialData={initialGridData}
    />
  </div>
</BaseLayout>
