---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductDetail from "@/islands/ProductDetail.tsx";
import { getProductBySlug, listProducts, resolveApiUrl } from "@/lib/api";
import { createTranslator, resolveLocale, localePath, type Locale } from "@/lib/i18n";

/**
 * `getStaticPaths` runs at build time. It tries to enumerate slugs through
 * the SDK; if the API is unreachable (common for offline builds in CI), it
 * returns an empty array — no detail pages are generated, and the listing
 * page's empty state is what visitors see. When the API is up at build
 * time, every active product slug is pre-rendered for SEO.
 */
export async function getStaticPaths() {
  // Pull a generous first page; finer pagination at build time would mean
  // chasing every page just to know slugs. The catalog ships with far fewer
  // than 100 products at v0.1, so a single request is enough. The default
  // locale is fine for slug enumeration — slugs are not localized in v0.1.
  const result = await listProducts("id", { pageSize: 100, sort: "newest" });
  return result.items.map((p) => ({ params: { slug: p.slug } }));
}

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);
const intlLocale = locale === "id" ? "id-ID" : "en-US";

const { slug } = Astro.params as { slug: string };

// Best-effort build-time fetch to populate <title>, <meta>, OG image, and
// the JSON-LD product structured data. If the build-time fetch fails the
// React island re-fetches on the client.
const product = await getProductBySlug(locale, slug);

const pageTitle = product ? product.title[locale] : slug;
const description = product ? product.description[locale] : "";
const ogImage = product?.hasImage ? product.imageUrl : undefined;

const apiUrl = resolveApiUrl();
const detailHrefBase = localePath(locale, "/products");

// Build absolute URLs for the JSON-LD payload. Schema.org consumers
// (Google's Rich Results Test, Bing) accept relative URLs but penalise
// them; absolute is the safe default. Use `Astro.site` and fall back to
// the current request origin for development where `site` may be
// unset.
const siteUrl = Astro.site?.toString() ?? Astro.url.origin;
const homeUrl = new URL(localePath(locale, "/"), siteUrl).toString();
const productsUrl = new URL(localePath(locale, "/products"), siteUrl).toString();
const productUrl = new URL(`${detailHrefBase}/${slug}`, siteUrl).toString();

// `Product` schema — name, description, image, sku, brand, offers.
// We construct the payload only when `product` is non-null; an empty
// build-time fetch (offline build) skips the structured data along
// with the title/description fallbacks.
//
// `brand` is hard-coded to "mt-commerce" for v0.1 because the catalog
// API does not yet expose a per-product brand. When the API grows a
// `brand` field, swap in `product.brand ?? "mt-commerce"`.
const jsonLd = product
  ? [
      {
        "@context": "https://schema.org",
        "@type": "Product",
        name: pageTitle,
        description,
        // Only emit `image` when we have a real CDN URL — embedding the
        // transparent placeholder data URI would be misleading to crawlers.
        ...(product.hasImage ? { image: product.imageUrl } : {}),
        sku: product.id,
        brand: {
          "@type": "Brand",
          name: "mt-commerce",
        },
        offers: {
          "@type": "Offer",
          url: productUrl,
          // `price` is the lowest variant price as a decimal string —
          // the format Google's Product rich result expects. We rely on
          // `Money.amount` being a `bigint` of the smallest currency
          // unit; for IDR (no minor units) the integer value is the
          // human price. For currencies with minor units this would
          // need a divide-by-100; mt-commerce's v0.1 catalogue is
          // single-currency (IDR), and we leave the conversion to be
          // handled when multi-currency lands.
          price: product.basePrice.amount.toString(),
          priceCurrency: product.basePrice.currency,
          availability: product.variants.some((v) => v.available)
            ? "https://schema.org/InStock"
            : "https://schema.org/OutOfStock",
        },
      },
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: t("products.detail.breadcrumbs.home"),
            item: homeUrl,
          },
          {
            "@type": "ListItem",
            position: 2,
            name: t("products.list.title"),
            item: productsUrl,
          },
          {
            "@type": "ListItem",
            position: 3,
            name: pageTitle,
            item: productUrl,
          },
        ],
      },
    ]
  : undefined;
---

<BaseLayout
  title={`${pageTitle} — mt-commerce`}
  description={description}
  ogImage={ogImage}
  ogType="product"
  jsonLd={jsonLd}
>
  <ProductDetail
    client:load
    apiUrl={apiUrl}
    slug={slug}
    locale={intlLocale}
    apiLocale={locale}
    loadingLabel={t("products.detail.loading")}
    errorLabel={t("products.list.error")}
    notFoundLabel={t("products.detail.not_found")}
    variantsHeading={t("products.detail.variants")}
    compareAtLabel={t("products.detail.compare_at")}
    addToCartLabel={t("products.detail.add_to_cart")}
    outOfStockLabel={t("products.detail.out_of_stock")}
    addedLabel={t("cart.added_feedback")}
    cartErrorLabel={t("cart.error_generic")}
    breadcrumbHomeLabel={t("products.detail.breadcrumbs.home")}
    relatedTitle={t("products.detail.related_title")}
    detailHrefBase={detailHrefBase}
  />
</BaseLayout>
