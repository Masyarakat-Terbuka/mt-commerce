---
/**
 * Checkout confirmation page.
 *
 * URL shape — note: the spec calls for `/checkout/<orderIntentId>/confirmed`
 * but the storefront ships as `output: "static"`. Astro requires
 * `getStaticPaths` for dynamic segments under static output, and order intent
 * IDs are not known at build time. The pragmatic shape is a single static
 * page that reads the id from a query string (`?id=<orderIntentId>`); the
 * checkout flow navigates here on success, and the island rehydrates the
 * order summary from sessionStorage. Once an SSR adapter is wired in we can
 * graduate to the path-segment shape without changing the component.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import CheckoutConfirmed from "@/islands/CheckoutConfirmed.tsx";
import { createTranslator, resolveLocale, localePath, type Locale } from "@/lib/i18n";

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);
const intlLocale = locale === "id" ? "id-ID" : "en-US";

const homeHref = localePath(locale, "/");
const orderIntentId = Astro.url.searchParams.get("id") ?? "";

const title = `${t("checkout.confirmed.title")} — mt-commerce`;
---

<BaseLayout title={title} description={t("checkout.confirmed.subtitle")}>
  <CheckoutConfirmed
    client:load
    orderIntentId={orderIntentId}
    locale={intlLocale}
    homeHref={homeHref}
    titleLabel={t("checkout.confirmed.title")}
    subtitleLabel={t("checkout.confirmed.subtitle")}
    orderNumberLabel={t("checkout.confirmed.order_number_label")}
    nextStepsLabel={t("checkout.confirmed.next_steps")}
    backHomeLabel={t("checkout.confirmed.back_home")}
    missingLabel={t("checkout.confirmed.missing")}
    itemsLabel={t("checkout.review.items_label")}
    addressLabel={t("checkout.review.address_label")}
    totalsLabels={{
      subtotal: t("cart.subtotal"),
      tax: t("cart.tax"),
      shipping: t("cart.shipping"),
      total: t("cart.total"),
    }}
  />
</BaseLayout>
