---
/**
 * /search — Indonesian (default) search results.
 *
 * Why a dedicated page rather than re-using `/products?search=…`:
 *   - Browse and search are different intents. Browse comes with filters,
 *     sort, and a "Semua produk" frame; search starts with a query string
 *     and is centered on results for that exact query.
 *   - Search results should not pollute the index. We emit `noindex,follow`
 *     on `/search?q=…` so crawlers do not enumerate every typed query.
 *   - The breadcrumb reads "Beranda → Pencarian" rather than the catalog
 *     trail, which only makes sense on category pages.
 *
 * Static-build note — the storefront builds with `output: "static"`, so
 * `Astro.url.searchParams` is empty at build time and `?q=...` cannot be
 * observed on the server. The dynamic body of the page (heading echo,
 * count, results, no-results state, pagination) is delegated to the
 * `SearchResults` island, which reads `q` and `page` from
 * `window.location` on the visitor's machine and queries the SDK live.
 * The breadcrumb stays server-rendered because it does not depend on the
 * query.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import SearchResults from "@/islands/SearchResults.tsx";
import { resolveApiUrl, toIntlLocale } from "@/lib/api";
import {
  createTranslator,
  resolveLocale,
  localePath,
  type Locale,
} from "@/lib/i18n";

const locale: Locale = resolveLocale(Astro.currentLocale);
const t = createTranslator(locale);

const productsHref = localePath(locale, "/products");
const homeHref = localePath(locale, "/");
const searchHref = localePath(locale, "/search");
const detailHrefBase = localePath(locale, "/products");
const apiUrl = resolveApiUrl();

// Title and description fall back to the empty-state copy because the page
// is statically prerendered without access to `?q=...`. The island updates
// the visible H1 once it reads the URL on the client; the document <title>
// stays generic, which is the correct behaviour for a `noindex` page.
const title = `${t("search.title")} — mt-commerce`;
const description = t("search.empty.headline");

// Search result pages should not be indexed regardless of query — the URL
// space is unbounded. Always emit `noindex,follow`.
const labels = {
  emptyHeading: t("search.empty.headline"),
  emptyBody: t("search.empty.body"),
  resultsHeadingTemplate: t("search.title_with_query"),
  countTemplate: t("search.count"),
  noResultsHeadingTemplate: t("search.no_results.headline"),
  noResultsBody: t("search.no_results.body"),
  loading: t("search.loading"),
  error: t("search.error"),
  browseAll: t("search.browse_all"),
  prevLabel: t("products.list.pagination.prev"),
  nextLabel: t("products.list.pagination.next"),
};
---

<BaseLayout title={title} description={description} noindex={true}>
  <div
    class="mx-auto max-w-[1280px] px-5 pt-12 pb-24 md:px-8 md:pt-16 md:pb-32"
  >
    {
      /*
      Breadcrumb — calm, text-only. Uses the small overline scale to read
      as a label rather than a navigation bar competing with the heading.
    */
    }
    <nav class="t-caption text-muted mb-8 md:mb-10" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-2">
        <li>
          <a
            class="hover:text-accent transition-colors duration-150"
            href={homeHref}
          >
            {t("breadcrumb.home")}
          </a>
        </li>
        <li aria-hidden="true" class="text-faint">/</li>
        <li class="text-fg" aria-current="page">{t("breadcrumb.search")}</li>
      </ol>
    </nav>

    <SearchResults
      client:load
      apiUrl={apiUrl}
      locale={toIntlLocale(locale)}
      apiLocale={locale}
      detailHrefBase={detailHrefBase}
      productsHref={productsHref}
      searchHref={searchHref}
      labels={labels}
    />
  </div>
</BaseLayout>
