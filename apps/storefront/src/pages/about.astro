---
/**
 * About page — Indonesian.
 *
 * Why a flat `.astro` page rather than a content collection entry: there
 * is one about page per locale. The collection ceremony does not pay for
 * itself at n=1, and inlining the prose here keeps the page self-
 * contained for future maintainers — the next person editing this can
 * see everything in one file.
 *
 * Tone reference: `PRODUCT.md`. Calm, factual, no pitch-deck language.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { createTranslator, localePath } from "@/lib/i18n";

const locale = "id" as const;
const t = createTranslator(locale);

const title = `${t("about.title")} — mt-commerce`;
const description = t("about.subhead");
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-[64ch] px-5 pb-24 pt-16 md:px-8 md:pb-32 md:pt-24">
    <p class="t-overline text-muted">{t("about.title")}</p>
    <h1 class="mt-4 t-display text-fg">{t("about.title")}</h1>
    <p class="mt-5 t-body text-muted">{t("about.subhead")}</p>

    {/*
      Body uses the same `.prose-mt` rule as MDX-rendered pages, so the
      typography stays consistent across help, about, and legal.
    */}
    <div class="prose-mt mt-12">
      <p>
        mt-commerce adalah platform commerce sumber terbuka yang dibangun untuk
        Indonesia. Pembayaran lokal, pengiriman lokal, struktur alamat, bahasa,
        dan pajak ada di inti — bukan tambahan opsional. Lisensi MIT membuat
        siapa pun bebas menjalankan, memodifikasi, dan membangun di atasnya.
      </p>

      <p>
        Proyek ini dikelola oleh komunitas sumber terbuka. Tidak ada perusahaan
        tunggal yang memilikinya; tidak ada model langganan yang menguncinya.
        Roadmap, keputusan, dan diskusi terjadi di publik. Pertanyaan dan
        kontribusi sama-sama diterima.
      </p>

      <p>
        Kontribusi berupa kode, dokumentasi, terjemahan, atau laporan bug
        diterima melalui{" "}
        <a href="https://github.com/masyarakat-terbuka/mt-commerce">
          repositori di GitHub
        </a>
        . Untuk gambaran lengkap tentang prinsip dan arah proyek, lihat{" "}
        <a href={localePath(locale, "/help/faq")}>halaman pertanyaan umum</a>{" "}
        atau dokumen <code>PRODUCT.md</code> di repositori.
      </p>
    </div>
  </article>
</BaseLayout>
