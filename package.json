{
  "name": "mt-commerce",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/plugins/*"
  ],
  "packageManager": "bun@1.3.7",
  "scripts": {
    "setup": "./scripts/setup.sh",
    "reset": "./scripts/reset.sh",
    "dev": "bun --filter '*' dev",
    "build": "bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck",
    "lint": "bun --filter '*' lint",
    "format": "bun --filter '*' format"
  }
}
